{
  "schemaVersion": "1.5",
  "business": {
    "id": "plumber-001",
    "name": "t:business.name",
    "industry": "plumber",
    "assets": {
      "favicon": "/images/plumber/favicon.svg"
    },
    "contact": {
      "address": "123 Main Street, Suite 100, Anytown, USA",
      "phone": "(555) 123-4567",
      "email": "service@quickfixplumbing.com",
      "hours": "Mon-Fri: 7AM-8PM, Sat-Sun: 8AM-6PM"
    }
  },
  "theme": {
    "preset": "industrial",
    "mode": "light",
    "colors": {
      "light": {
        "primary": "#0066CC",
        "surface": {
          "base": "#F8FAFC",
          "alt": "#003D7A"
        },
        "text": {
          "main": "#0F172A",
          "muted": "#64748B",
          "onPrimary": "#FFFFFF"
        }
      }
    },
    "typography": {
      "primary": "'Inter', system-ui, -apple-system, sans-serif",
      "secondary": "'Inter', system-ui, -apple-system, sans-serif"
    },
    "ui": {
      "radius": "0.5rem"
    }
  },
  "layout": {
    "navbar": { "variant": "standard" },
    "footer": {
      "variant": "branded",
      "copyright": "t:footer.copyright",
      "tagline": "t:footer.tagline",
      "links": [
        { "label": "t:footer.privacy", "target": { "type": "page", "value": "privacy" } },
        { "label": "t:footer.terms", "target": { "type": "page", "value": "terms" } }
      ],
      "columns": [
        {
          "title": "t:footer.columns.services.title",
          "links": [
            { "label": "t:footer.columns.services.emergency", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.services.drain", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.services.heater", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.services.pipe", "target": { "type": "page", "value": "services" } }
          ]
        },
        {
          "title": "t:footer.columns.company.title",
          "links": [
            { "label": "t:footer.columns.company.about", "target": { "type": "page", "value": "about" } },
            { "label": "t:footer.columns.company.contact", "target": { "type": "page", "value": "contact" } },
            { "label": "t:footer.columns.company.careers", "target": { "type": "page", "value": "careers" } }
          ]
        }
      ]
    }
  },
  "navigation": {
    "cta": { "label": "t:nav.cta", "target": { "type": "phone" } }
  },
  "pages": {
    "home": {
      "title": "t:pages.home.title",
      "sections": [
        {
          "type": "hero",
          "variant": "cards",
          "header": {
            "badge": "t:hero.badge",
            "title": "t:hero.title",
            "subtitle": "t:hero.subtitle"
          },
          "backgroundImage": "/images/plumber/hero.jpg",
          "cta": { "label": "t:hero.cta", "target": { "type": "page", "value": "contact" } },
          "secondaryCta": { "label": "t:hero.secondaryCta", "target": { "type": "page", "value": "services" } }
        },
        {
          "type": "categories",
          "variant": "featured",
          "header": {
            "title": "t:categories.title",
            "subtitle": "t:categories.subtitle"
          },
          "items": [
            { "title": "t:categories.items.emergency.title", "description": "t:categories.items.emergency.description", "image": "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.drain.title", "description": "t:categories.items.drain.description", "image": "https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.heater.title", "description": "t:categories.items.heater.description", "image": "https://images.unsplash.com/photo-1513694203232-719a280e022f?w=400&h=300&fit=crop" }
          ]
        }
      ]
    },
    "services": {
      "title": "t:pages.services.title",
      "sections": [
        {
          "type": "services",
          "variant": "list",
          "header": {
            "title": "t:services.title",
            "subtitle": "t:services.subtitle"
          },
          "items": [
            {
              "title": "t:services.items.emergency.title",
              "description": "t:services.items.emergency.description",
              "price": "t:services.items.emergency.price"
            },
            {
              "title": "t:services.items.drain.title",
              "description": "t:services.items.drain.description",
              "price": "t:services.items.drain.price"
            },
            {
              "title": "t:services.items.heater.title",
              "description": "t:services.items.heater.description",
              "price": "t:services.items.heater.price"
            },
            {
              "title": "t:services.items.pipe.title",
              "description": "t:services.items.pipe.description",
              "price": "t:services.items.pipe.price"
            }
          ]
        }
      ]
    },
    "about": {
      "title": "t:pages.about.title",
      "sections": [
        {
          "type": "about",
          "variant": "story",
          "header": {
            "title": "t:about.title"
          },
          "story": {
            "title": "t:about.story.title",
            "content": "t:about.story.content"
          },
          "stats": [
            { "value": "24/7", "label": "t:about.stats.service" },
            { "value": "100%", "label": "t:about.stats.satisfaction" },
            { "value": "15+", "label": "t:about.stats.experience" }
          ],
          "commitment": {
            "title": "t:about.commitment.title",
            "content": "t:about.commitment.content"
          },
          "cta": { "label": "t:about.cta", "target": { "type": "page", "value": "contact" } }
        }
      ]
    },
    "contact": {
      "title": "t:pages.contact.title",
      "sections": [
        {
          "type": "contact",
          "variant": "split",
          "header": {
            "title": "t:contact.title",
            "subtitle": "t:contact.subtitle"
          },
          "info": {
            "address": "123 Main Street, Suite 100, Anytown, USA",
            "phone": "(555) 123-4567",
            "email": "service@quickfixplumbing.com",
            "hours": "Mon-Fri: 7AM-8PM, Sat-Sun: 8AM-6PM"
          },
          "form": {
            "namePlaceholder": "t:contact.form.name",
            "emailPlaceholder": "t:contact.form.email",
            "messagePlaceholder": "t:contact.form.message",
            "submitButton": "t:contact.form.submit"
          }
        }
      ]
    }
  }
}
