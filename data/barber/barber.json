{
  "schemaVersion": "1.5",
  "business": {
    "id": "barber-001",
    "name": "t:business.name",
    "industry": "barber",
    "assets": {
      "favicon": "/images/barber/favicon.svg"
    },
    "contact": {
      "phone": "(555) 123-4567",
      "email": "info@classiccutsbarbershop.com"
    }
  },
  "theme": {
    "preset": "wellness",
    "mode": "light",
    "colors": {
      "light": {
        "primary": "#8B4513",
        "surface": {
          "base": "#FDFBF7",
          "alt": "#2C1810"
        },
        "text": {
          "main": "#1C1210",
          "muted": "#6B5B4F",
          "onPrimary": "#FFFFFF"
        }
      }
    },
    "typography": {
      "primary": "system-ui, -apple-system, sans-serif",
      "secondary": "'Playfair Display', Georgia, serif"
    },
    "ui": {
      "radius": "0.5rem"
    }
  },
  "layout": {
    "navbar": { "variant": "standard" },
    "footer": {
      "variant": "minimal",
      "copyright": "t:footer.copyright",
      "links": [
        { "label": "t:footer.privacy", "target": { "type": "page", "value": "privacy" } },
        { "label": "t:footer.terms", "target": { "type": "page", "value": "terms" } }
      ]
    }
  },
  "navigation": {
    "cta": { "label": "t:nav.cta", "target": { "type": "page", "value": "contact" } }
  },
  "pages": {
    "home": {
      "title": "t:pages.home.title",
      "sections": [
        {
          "type": "hero",
          "variant": "gradient",
          "header": {
            "badge": "t:hero.badge",
            "title": "t:hero.title",
            "subtitle": "t:hero.subtitle"
          },
          "backgroundImage": "/images/barber/hero.jpg",
          "cta": { "label": "t:hero.cta", "target": { "type": "page", "value": "contact" } },
          "secondaryCta": { "label": "t:hero.secondaryCta", "target": { "type": "page", "value": "services" } }
        },
        {
          "type": "categories",
          "variant": "carousel",
          "header": {
            "title": "t:categories.title",
            "subtitle": "t:categories.subtitle"
          },
          "items": [
            { "title": "t:categories.items.haircut.title", "description": "t:categories.items.haircut.description", "image": "https://images.unsplash.com/photo-1599351431202-1e0f0137899a?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.beard.title", "description": "t:categories.items.beard.description", "image": "https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.shave.title", "description": "t:categories.items.shave.description", "image": "https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.styling.title", "description": "t:categories.items.styling.description", "image": "https://images.unsplash.com/photo-1622286342621-4bd786c2447c?w=400&h=300&fit=crop" }
          ]
        }
      ]
    },
    "services": {
      "title": "t:pages.services.title",
      "sections": [
        {
          "type": "services",
          "variant": "grid",
          "header": {
            "title": "t:services.title",
            "subtitle": "t:services.subtitle"
          },
          "items": [
            {
              "title": "t:services.items.haircut.title",
              "description": "t:services.items.haircut.description",
              "price": "t:services.items.haircut.price"
            },
            {
              "title": "t:services.items.beard.title",
              "description": "t:services.items.beard.description",
              "price": "t:services.items.beard.price"
            },
            {
              "title": "t:services.items.shave.title",
              "description": "t:services.items.shave.description",
              "price": "t:services.items.shave.price"
            },
            {
              "title": "t:services.items.works.title",
              "description": "t:services.items.works.description",
              "price": "t:services.items.works.price"
            }
          ]
        }
      ]
    },
    "about": {
      "title": "t:pages.about.title",
      "sections": [
        {
          "type": "about",
          "variant": "story",
          "header": {
            "title": "t:about.title"
          },
          "story": {
            "title": "t:about.story.title",
            "content": "t:about.story.content"
          },
          "stats": [
            { "value": "28+", "label": "t:about.stats.experience" },
            { "value": "50K+", "label": "t:about.stats.clients" },
            { "value": "5", "label": "t:about.stats.barbers" }
          ],
          "commitment": {
            "title": "t:about.commitment.title",
            "content": "t:about.commitment.content"
          },
          "cta": { "label": "t:about.cta", "target": { "type": "page", "value": "contact" } }
        }
      ]
    },
    "contact": {
      "title": "t:pages.contact.title",
      "sections": [
        {
          "type": "contact",
          "variant": "centered",
          "header": {
            "title": "t:contact.title",
            "subtitle": "t:contact.subtitle"
          },
          "form": {
            "namePlaceholder": "t:contact.form.name",
            "emailPlaceholder": "t:contact.form.email",
            "messagePlaceholder": "t:contact.form.message",
            "submitButton": "t:contact.form.submit"
          }
        }
      ]
    }
  }
}
