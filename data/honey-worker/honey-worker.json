{
  "schemaVersion": "1.5",
  "business": {
    "id": "honey-worker-001",
    "name": "t:business.name",
    "industry": "honey-producer",
    "contact": {
      "phone": "(555) 234-5678",
      "email": "hello@goldenhivehoney.com"
    }
  },
  "theme": {
    "mode": "light",
    "colors": {
      "light": {
        "primary": "#F59E0B",
        "surface": {
          "base": "#FFFBEB",
          "alt": "#92400E"
        },
        "text": {
          "main": "#451A03",
          "muted": "#78716C",
          "onPrimary": "#FFFFFF"
        }
      }
    },
    "typography": {
      "primary": "'Nunito', system-ui, -apple-system, sans-serif",
      "secondary": "'Fraunces', Georgia, serif"
    },
    "ui": {
      "radius": "0.75rem"
    }
  },
  "layout": {
    "navbar": { "variant": "centered" },
    "footer": {
      "variant": "simple",
      "copyright": "t:footer.copyright",
      "links": [
        { "label": "t:footer.privacy", "target": { "type": "page", "value": "privacy" } },
        { "label": "t:footer.terms", "target": { "type": "page", "value": "terms" } }
      ]
    }
  },
  "navigation": {
    "cta": { "label": "t:nav.cta", "target": { "type": "page", "value": "contact" } }
  },
  "pages": {
    "home": {
      "title": "t:pages.home.title",
      "sections": [
        {
          "type": "hero",
          "variant": "default",
          "header": {
            "badge": "t:hero.badge",
            "title": "t:hero.title",
            "subtitle": "t:hero.subtitle"
          },
          "backgroundImage": "/images/honey-worker/hero.jpg",
          "cta": { "label": "t:hero.cta", "target": { "type": "page", "value": "services" } },
          "secondaryCta": { "label": "t:hero.secondaryCta", "target": { "type": "page", "value": "about" } }
        }
      ]
    },
    "services": {
      "title": "t:pages.services.title",
      "sections": [
        {
          "type": "services",
          "variant": "grid",
          "header": {
            "title": "t:services.title",
            "subtitle": "t:services.subtitle"
          },
          "items": [
            {
              "title": "t:services.items.raw.title",
              "description": "t:services.items.raw.description",
              "price": "t:services.items.raw.price"
            },
            {
              "title": "t:services.items.honeycomb.title",
              "description": "t:services.items.honeycomb.description",
              "price": "t:services.items.honeycomb.price"
            },
            {
              "title": "t:services.items.pollen.title",
              "description": "t:services.items.pollen.description",
              "price": "t:services.items.pollen.price"
            },
            {
              "title": "t:services.items.candles.title",
              "description": "t:services.items.candles.description",
              "price": "t:services.items.candles.price"
            }
          ]
        }
      ]
    },
    "about": {
      "title": "t:pages.about.title",
      "sections": [
        {
          "type": "about",
          "variant": "timeline",
          "header": {
            "title": "t:about.title"
          },
          "stats": [
            { "value": "100%", "label": "t:about.stats.pure" },
            { "value": "Local", "label": "t:about.stats.family" },
            { "value": "25+", "label": "t:about.stats.experience" }
          ],
          "timeline": [
            {
              "year": "1998",
              "title": "t:about.timeline.1998.title",
              "description": "t:about.timeline.1998.description"
            },
            {
              "year": "2005",
              "title": "t:about.timeline.2005.title",
              "description": "t:about.timeline.2005.description"
            },
            {
              "year": "2012",
              "title": "t:about.timeline.2012.title",
              "description": "t:about.timeline.2012.description"
            },
            {
              "year": "2020",
              "title": "t:about.timeline.2020.title",
              "description": "t:about.timeline.2020.description"
            }
          ],
          "cta": { "label": "t:about.cta", "target": { "type": "page", "value": "contact" } }
        }
      ]
    },
    "contact": {
      "title": "t:pages.contact.title",
      "sections": [
        {
          "type": "contact",
          "variant": "centered",
          "header": {
            "title": "t:contact.title",
            "subtitle": "t:contact.subtitle"
          },
          "form": {
            "namePlaceholder": "t:contact.form.name",
            "emailPlaceholder": "t:contact.form.email",
            "messagePlaceholder": "t:contact.form.message",
            "submitButton": "t:contact.form.submit"
          }
        }
      ]
    }
  }
}
