{
  "schemaVersion": "1.5",
  "business": {
    "id": "game-selector-001",
    "name": "t:business.name",
    "industry": "gaming",
    "assets": {
      "favicon": "/images/game-selector/favicon.svg"
    },
    "contact": {
      "email": "hello@gamepick.io"
    },
    "socials": {
      "discord": "https://discord.gg/gamepick",
      "twitter": "https://twitter.com/gamepick"
    }
  },
  "theme": {
    "preset": "minimal",
    "mode": "dark",
    "colors": {
      "light": {
        "primary": "#8B5CF6",
        "surface": {
          "base": "#0F0E1A",
          "alt": "#1E1B4B"
        },
        "text": {
          "main": "#F8FAFC",
          "muted": "#94A3B8",
          "onPrimary": "#FFFFFF"
        }
      }
    },
    "typography": {
      "primary": "'Inter', system-ui, -apple-system, sans-serif",
      "secondary": "'Orbitron', 'Inter', sans-serif"
    },
    "ui": {
      "radius": "0.75rem"
    }
  },
  "layout": {
    "navbar": { "variant": "centered" },
    "footer": {
      "variant": "stacked",
      "copyright": "t:footer.copyright",
      "tagline": "t:footer.tagline",
      "links": [
        { "label": "t:footer.privacy", "target": { "type": "page", "value": "privacy" } },
        { "label": "t:footer.terms", "target": { "type": "page", "value": "terms" } }
      ],
      "columns": [
        {
          "title": "t:footer.columns.categories.title",
          "links": [
            { "label": "t:footer.columns.categories.coop", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.categories.party", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.categories.competitive", "target": { "type": "page", "value": "services" } },
            { "label": "t:footer.columns.categories.mmo", "target": { "type": "page", "value": "services" } }
          ]
        },
        {
          "title": "t:footer.columns.resources.title",
          "links": [
            { "label": "t:footer.columns.resources.about", "target": { "type": "page", "value": "about" } },
            { "label": "t:footer.columns.resources.contact", "target": { "type": "page", "value": "contact" } },
            { "label": "t:footer.columns.resources.blog", "target": { "type": "page", "value": "blog" } }
          ]
        }
      ]
    }
  },
  "navigation": {
    "cta": { "label": "t:nav.cta", "target": { "type": "page", "value": "services" } }
  },
  "pages": {
    "home": {
      "title": "t:pages.home.title",
      "sections": [
        {
          "type": "hero",
          "variant": "video",
          "header": {
            "badge": "t:hero.badge",
            "title": "t:hero.title",
            "subtitle": "t:hero.subtitle"
          },
          "backgroundImage": "/images/game-selector/hero.jpg",
          "cta": { "label": "t:hero.cta", "target": { "type": "page", "value": "services" } },
          "secondaryCta": { "label": "t:hero.secondaryCta", "target": { "type": "page", "value": "about" } }
        },
        {
          "type": "categories",
          "variant": "featured",
          "header": {
            "title": "t:categories.title",
            "subtitle": "t:categories.subtitle"
          },
          "items": [
            { "title": "t:categories.items.coop.title", "description": "t:categories.items.coop.description", "image": "https://images.unsplash.com/photo-1493711662062-fa541f7f3d24?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.party.title", "description": "t:categories.items.party.description", "image": "https://images.unsplash.com/photo-1511882150382-421056c89033?w=400&h=300&fit=crop" },
            { "title": "t:categories.items.competitive.title", "description": "t:categories.items.competitive.description", "image": "https://images.unsplash.com/photo-1542751371-adc38448a05e?w=400&h=300&fit=crop" }
          ]
        }
      ]
    },
    "services": {
      "title": "t:pages.services.title",
      "sections": [
        {
          "type": "services",
          "variant": "grid",
          "header": {
            "title": "t:services.title",
            "subtitle": "t:services.subtitle"
          },
          "items": [
            {
              "title": "t:services.items.coop.title",
              "description": "t:services.items.coop.description",
              "price": "t:services.items.coop.price"
            },
            {
              "title": "t:services.items.party.title",
              "description": "t:services.items.party.description",
              "price": "t:services.items.party.price"
            },
            {
              "title": "t:services.items.competitive.title",
              "description": "t:services.items.competitive.description",
              "price": "t:services.items.competitive.price"
            },
            {
              "title": "t:services.items.mmo.title",
              "description": "t:services.items.mmo.description",
              "price": "t:services.items.mmo.price"
            }
          ]
        }
      ]
    },
    "about": {
      "title": "t:pages.about.title",
      "sections": [
        {
          "type": "about",
          "variant": "story",
          "header": {
            "title": "t:about.title"
          },
          "story": {
            "title": "t:about.story.title",
            "content": "t:about.story.content"
          },
          "stats": [
            { "value": "500+", "label": "t:about.stats.games" },
            { "value": "50K+", "label": "t:about.stats.gamers" },
            { "value": "24/7", "label": "t:about.stats.community" }
          ],
          "commitment": {
            "title": "t:about.commitment.title",
            "content": "t:about.commitment.content"
          },
          "cta": { "label": "t:about.cta", "target": { "type": "page", "value": "services" } }
        }
      ]
    },
    "contact": {
      "title": "t:pages.contact.title",
      "sections": [
        {
          "type": "contact",
          "variant": "centered",
          "header": {
            "title": "t:contact.title",
            "subtitle": "t:contact.subtitle"
          },
          "form": {
            "namePlaceholder": "t:contact.form.name",
            "emailPlaceholder": "t:contact.form.email",
            "messagePlaceholder": "t:contact.form.message",
            "submitButton": "t:contact.form.submit"
          }
        }
      ]
    }
  }
}
