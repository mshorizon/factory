---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate } from "../lib/i18n";
import { deepResolveImages } from "../lib/images";
import type { BusinessProfile } from "@mshorizon/schema";

const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

const translatedData = deepTranslate(translations, businessData) as BusinessProfile;
const business = deepResolveImages(translatedData, businessId);
const layout = getLayoutConfig(business);

const navLinksRaw = getNavLinks(business);
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));
const navCta = business.navigation?.cta
  ? { label: business.navigation.cta.label, href: resolveTarget(business.navigation.cta.target, business) }
  : undefined;

const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label, href: link.href || resolveTarget(link.target, business),
})) || [];
const footerColumns = layout.footer.columns?.map((col: any) => ({
  title: col.title,
  links: col.links?.map((link: any) => ({ label: link.label, href: link.href || resolveTarget(link.target, business) })) || [],
})) || [];

const pageTitle = `Zamówienie anulowane | ${business.business.name}`;
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered"}
    showCart={true}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
    showAddress={layout.navbar.showAddress}
    showAdditionalInfo={layout.navbar.showAdditionalInfo}
  />
  <main class="flex-1" data-nav-offset>
    <div class="flex flex-col items-center justify-center py-24 px-6 text-center">
      <div class="h-20 w-20 rounded-full bg-yellow-500/10 flex items-center justify-center mb-6">
        <svg class="h-10 w-10 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
      </div>

      <h1 class="text-2xl lg:text-3xl font-bold text-foreground mb-3">
        Zamówienie nie zostało opłacone
      </h1>

      <p class="text-foreground/70 mb-8 max-w-md">
        Płatność została anulowana lub wygasła. Twój koszyk jest nadal zapisany — możesz spróbować ponownie.
      </p>

      <div class="flex gap-3">
        <a
          href="/checkout"
          class="inline-flex items-center px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:opacity-90 transition"
        >
          Spróbuj ponownie
        </a>
        <a
          href="/cart"
          class="inline-flex items-center px-6 py-3 rounded-lg border border-border text-foreground font-medium hover:bg-muted transition"
        >
          Wróć do koszyka
        </a>
      </div>
    </div>
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    footerLogoIcon={business.business.assets?.footerIcon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    background={layout.footer.background}
  />
</BaseLayout>
