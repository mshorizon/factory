---
import { NavbarStandard, NavbarCentered, FooterSimple, FooterMultiColumn } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionDispatcher from "../components/SectionDispatcher.astro";
import { findPageBySlug, getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate } from "../lib/i18n";
import type { BusinessProfileV15, Target } from "@mshorizon/schema";

// Get route params
const { slug } = Astro.params;

// Get business context from middleware
const { businessData, theme, currentLang, t: translations } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const business = deepTranslate(translations, businessData) as BusinessProfileV15;

// Resolve the page (v1.5: "home" instead of "index")
const normalizedSlug = slug || "home";
const page = findPageBySlug(business, normalizedSlug);

// 404 if page not found
if (!page) {
  return Astro.redirect("/404");
}

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinks = getNavLinks(business);

// Build page title
const pageTitle = normalizedSlug === "home" ? business.business.name : `${page.title} | ${business.business.name}`;

// Target resolver function for navbar/footer
const targetResolver = (target: Target) => resolveTarget(target, business);

// Prepare navbar props
const navbarProps = {
  logo: business.business.name,
  links: navLinks,
  cta: business.navigation?.cta,
  currentLanguage: currentLang,
  resolveTarget: targetResolver,
};

// Prepare footer props
const footerProps = {
  businessName: business.business.name,
  links: layout.footer.links,
  copyright: layout.footer.copyright,
  columns: layout.footer.columns,
  tagline: layout.footer.tagline,
  resolveTarget: targetResolver,
};
---

<BaseLayout title={pageTitle} theme={theme}>
  {layout.navbar.variant === "centered" ? (
    <NavbarCentered client:load {...navbarProps} />
  ) : (
    <NavbarStandard client:load {...navbarProps} />
  )}
  <main class="flex-1">
    <SectionDispatcher sections={page.sections} />
  </main>
  {layout.footer.variant === "multiColumn" ? (
    <FooterMultiColumn {...footerProps} />
  ) : (
    <FooterSimple {...footerProps} />
  )}
</BaseLayout>
