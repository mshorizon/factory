---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionDispatcher from "../components/SectionDispatcher.astro";
import PageHero from "../components/PageHero.astro";
import { findPageBySlug, getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate, t } from "../lib/i18n";
import { deepResolveImages } from "../lib/images";
import type { BusinessProfile } from "@mshorizon/schema";

// Get route params
const { slug } = Astro.params;

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Resolve the page ("home" is the default slug)
const normalizedSlug = slug || "home";
const page = findPageBySlug(business, normalizedSlug);

// 404 if page not found
if (!page) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

// Build page title
const pageTitle = normalizedSlug === "home" ? business.business.name : `${page.title} | ${business.business.name}`;

// Build meta description from first hero/section subtitle, or page title
const firstSection = page.sections?.[0];
const metaDescription = (firstSection as any)?.header?.subtitle
  || (firstSection as any)?.subtitle
  || (normalizedSlug !== "home" ? `${page.title} - ${business.business.name}` : undefined);

// Canonical URL (strip internal query params)
const canonicalUrl = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete('_preview');
  u.searchParams.delete('business');
  return u.toString();
})();

// OG Image from first section
const ogImage = (() => {
  const s = page.sections?.[0] as any;
  return s?.image || s?.backgroundImage || undefined;
})();

// JSON-LD Structured Data
const jsonLd = normalizedSlug === 'home' ? {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.business.name,
  "url": new URL(canonicalUrl).origin + '/',
  ...(business.business.contact?.phone && { "telephone": business.business.contact.phone }),
  ...(business.business.contact?.email && { "email": business.business.contact.email }),
  ...(business.business.contact?.address && {
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.business.contact.address
    }
  }),
  ...(business.business.contact?.location && {
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": (business.business.contact.location as any).latitude,
      "longitude": (business.business.contact.location as any).longitude
    }
  }),
  ...((business.business as any).googleRating && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": (business.business as any).googleRating.score,
      "reviewCount": (business.business as any).googleRating.count
    }
  }),
  ...(business.business.socials && {
    "sameAs": Object.values(business.business.socials as Record<string, string>).filter(Boolean)
  })
} : {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  ...(metaDescription && { "description": metaDescription }),
  "url": canonicalUrl,
  "isPartOf": {
    "@type": "WebSite",
    "name": business.business.name,
    "url": new URL(canonicalUrl).origin + '/'
  }
};

// Pre-resolve footer links
const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

// Auto-build pages column from nav links + footer legal links
const pagesColumn = {
  title: t(translations, "footer.columns.pages.title", "Strony"),
  links: [...navLinks, ...footerLinks],
};

// Pre-resolve footer columns (prepend auto pages column, then JSON columns)
const footerColumns = [
  pagesColumn,
  ...(layout.footer.columns?.map((col: any) => ({
    title: col.title,
    links: col.links?.map((link: any) => ({
      label: link.label,
      href: link.href || resolveTarget(link.target, business),
    })) || [],
  })) || []),
];

// Check if business has any shop sections (to show cart button)
const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

// Convert socials Record<string, string> to SocialLink[] for footer
const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang} description={metaDescription} canonical={canonicalUrl} ogImage={ogImage} siteName={business.business.name} jsonLd={jsonLd}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
  />
  <main class:list={["flex-1", normalizedSlug !== 'home' && "pt-14 lg:pt-16"]}>
    <SectionDispatcher sections={page.sections} business={business} isHomePage={normalizedSlug === 'home'} />
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
    background={layout.footer.background}
  />
</BaseLayout>
