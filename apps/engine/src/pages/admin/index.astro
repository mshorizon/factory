---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminForm from "../../components/admin/AdminForm";
import { businessSchema } from "@mshorizon/schema";
import { getSiteBySubdomain } from "@mshorizon/db";

const { businessId, businessData, t: translations } = Astro.locals;

// Get fresh data from database for admin editing
const site = await getSiteBySubdomain(businessId);
const rawBusinessData = site ? site.config : businessData;
const allTranslations = (site?.translations || {}) as Record<string, Record<string, unknown>>;
const enTranslations = allTranslations.en || {};
const plTranslations = allTranslations.pl || {};

// Get translated business name for display
const businessName = businessData.business.name.startsWith("t:")
  ? translations?.business?.name || businessId
  : businessData.business.name;
---

<AdminLayout title={`Admin - ${businessName}`}>
  <AdminForm
    client:load
    businessId={businessId}
    initialData={rawBusinessData}
    schema={businessSchema}
    translations={{ en: enTranslations, pl: plTranslations }}
  />
</AdminLayout>
