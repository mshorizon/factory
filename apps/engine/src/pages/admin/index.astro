---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminForm from "../../components/admin/AdminForm";
import { businessSchema } from "@mshorizon/schema";
import { getSiteBySubdomain, getAllSubdomains } from "@mshorizon/db";

const { businessId, businessData, t: translations, auth } = Astro.locals;

// Get fresh data from database for admin editing
const site = await getSiteBySubdomain(businessId);
const rawBusinessData = site ? site.config : businessData;
const allTranslations = (site?.translations || {}) as Record<string, Record<string, unknown>>;
const currentTemplate = (rawBusinessData as any)?.theme?.majorTheme || (rawBusinessData as any)?.business?.template || (rawBusinessData as any)?.template || "specialist";
const availableDomains = auth?.role === "super-admin" ? await getAllSubdomains() : [businessId];

// Get translated business name for display
const businessName = businessData.business.name.startsWith("t:")
  ? translations?.business?.name || businessId
  : businessData.business.name;
---

<AdminLayout title={`Admin - ${businessName}`} favicon={rawBusinessData.business?.assets?.favicon}>
  <AdminForm
    client:load
    businessId={businessId}
    initialData={rawBusinessData}
    schema={businessSchema}
    translations={allTranslations}
    auth={auth ? { email: auth.email as string, role: auth.role as string, userId: auth.userId as number } : undefined}
    availableDomains={availableDomains}
    currentTemplate={currentTemplate}
  />
</AdminLayout>
