---
import { getAllUsers, getAllSubdomains, createUser, deleteUser, updateUserRole, updateUserBusinessId } from '@mshorizon/db';
import { hashPassword } from '../../lib/auth';

const auth = Astro.locals.auth;

// Only super-admin can manage users
if (!auth || auth.role !== 'super-admin') {
  return Astro.redirect('/admin');
}

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('action') || '');

  if (action === 'create') {
    const email = String(formData.get('email') || '').trim().toLowerCase();
    const password = String(formData.get('password') || '');
    const role = String(formData.get('role') || 'admin') as 'super-admin' | 'admin' | 'editor';
    const businessId = String(formData.get('businessId') || '').trim() || undefined;

    if (!email || !password) {
      errorMessage = 'Email i hasło są wymagane.';
    } else if (password.length < 8) {
      errorMessage = 'Hasło musi mieć co najmniej 8 znaków.';
    } else {
      try {
        const passwordHash = await hashPassword(password);
        await createUser({ email, passwordHash, role, businessId });
        successMessage = `Użytkownik ${email} został utworzony.`;
      } catch (err: any) {
        if (err?.message?.includes('unique')) {
          errorMessage = 'Użytkownik z tym adresem email już istnieje.';
        } else {
          errorMessage = 'Błąd podczas tworzenia użytkownika.';
          console.error(err);
        }
      }
    }
  } else if (action === 'delete') {
    const userId = Number(formData.get('userId'));
    if (userId === auth.userId) {
      errorMessage = 'Nie możesz usunąć własnego konta.';
    } else if (userId) {
      await deleteUser(userId);
      successMessage = 'Użytkownik został usunięty.';
    }
  } else if (action === 'update-role') {
    const userId = Number(formData.get('userId'));
    const role = String(formData.get('role') || '') as 'super-admin' | 'admin' | 'editor';
    if (userId && role) {
      await updateUserRole(userId, role);
      successMessage = 'Rola użytkownika została zaktualizowana.';
    }
  } else if (action === 'update-business') {
    const userId = Number(formData.get('userId'));
    const businessId = String(formData.get('businessId') || '').trim() || null;
    if (userId) {
      await updateUserBusinessId(userId, businessId);
      successMessage = 'Przypisanie biznesu zostało zaktualizowane.';
    }
  }
}

const allUsers = await getAllUsers();
const allBusinesses = await getAllSubdomains();
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Zarządzanie użytkownikami — Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #f8fafc;
      min-height: 100vh;
      color: #0f172a;
      -webkit-font-smoothing: antialiased;
    }

    .page-header {
      background: #ffffff;
      border-bottom: 1px solid #e2e8f0;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .page-header-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .back-link {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.8125rem;
      font-weight: 500;
      color: #64748b;
      text-decoration: none;
      padding: 0.375rem 0.625rem;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
    }

    .back-link:hover {
      background: #f1f5f9;
      color: #0f172a;
    }

    h1 {
      font-size: 1.125rem;
      font-weight: 700;
      color: #0f172a;
      letter-spacing: -0.01em;
    }

    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 1.5rem;
      align-items: start;
    }

    @media (max-width: 900px) {
      .page-container {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      overflow: hidden;
    }

    .card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid #f1f5f9;
    }

    .card-title {
      font-size: 0.9375rem;
      font-weight: 600;
      color: #0f172a;
    }

    .card-body {
      padding: 1.5rem;
    }

    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1.25rem;
      font-size: 0.8125rem;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .alert-success {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #15803d;
    }

    .alert-error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
    }

    .form-row {
      margin-bottom: 1rem;
    }

    label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 500;
      color: #374151;
      margin-bottom: 0.375rem;
    }

    input[type="email"],
    input[type="password"],
    input[type="text"],
    select {
      width: 100%;
      padding: 0.5rem 0.75rem;
      border: 1px solid #d1d5db;
      border-radius: 7px;
      font-size: 0.875rem;
      color: #0f172a;
      background: #ffffff;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
    }

    input:focus, select:focus {
      border-color: #6366f1;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .btn {
      padding: 0.5rem 1rem;
      border-radius: 7px;
      font-size: 0.8125rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: background 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
    }

    .btn-primary {
      background: #0f172a;
      color: #ffffff;
      width: 100%;
      justify-content: center;
      padding: 0.625rem 1rem;
    }

    .btn-primary:hover { background: #1e293b; }

    .btn-danger {
      background: #fef2f2;
      color: #dc2626;
      border: 1px solid #fecaca;
      padding: 0.375rem 0.625rem;
    }

    .btn-danger:hover { background: #fee2e2; }

    .btn-secondary {
      background: #f8fafc;
      color: #374151;
      border: 1px solid #e2e8f0;
      padding: 0.375rem 0.625rem;
    }

    .btn-secondary:hover { background: #f1f5f9; }

    .users-table {
      width: 100%;
      border-collapse: collapse;
    }

    .users-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.625rem 1rem;
      border-bottom: 1px solid #f1f5f9;
      white-space: nowrap;
    }

    .users-table td {
      padding: 0.875rem 1rem;
      font-size: 0.875rem;
      color: #374151;
      border-bottom: 1px solid #f8fafc;
      vertical-align: middle;
    }

    .users-table tr:last-child td { border-bottom: none; }

    .users-table tr:hover td { background: #f8fafc; }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.625rem;
      border-radius: 9999px;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .badge-super-admin { background: #fef3c7; color: #92400e; }
    .badge-admin { background: #ede9fe; color: #6d28d9; }
    .badge-editor { background: #dbeafe; color: #1d4ed8; }

    .user-email {
      font-weight: 500;
      color: #0f172a;
    }

    .user-date {
      font-size: 0.75rem;
      color: #94a3b8;
    }

    .inline-form {
      display: flex;
      align-items: center;
      gap: 0.375rem;
    }

    .inline-form select {
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      width: auto;
    }

    .empty-state {
      padding: 3rem;
      text-align: center;
      color: #94a3b8;
      font-size: 0.875rem;
    }
  </style>
</head>
<body>
  <header class="page-header">
    <div class="page-header-left">
      <a href="/admin" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Panel admina
      </a>
      <h1>Zarządzanie użytkownikami</h1>
    </div>
    <form method="POST" action="/api/auth/logout" style="display:inline;">
      <button type="submit" class="btn btn-secondary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Wyloguj
      </button>
    </form>
  </header>

  <div class="page-container">
    <!-- Users list -->
    <div>
      {successMessage && (
        <div class="alert alert-success" style="margin-bottom: 1rem;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          {successMessage}
        </div>
      )}
      {errorMessage && (
        <div class="alert alert-error" style="margin-bottom: 1rem;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          {errorMessage}
        </div>
      )}

      <div class="card">
        <div class="card-header">
          <span class="card-title">Użytkownicy ({allUsers.length})</span>
        </div>

        {allUsers.length === 0 ? (
          <div class="empty-state">Brak użytkowników.</div>
        ) : (
          <table class="users-table">
            <thead>
              <tr>
                <th>Email</th>
                <th>Rola</th>
                <th>Biznes</th>
                <th>Ostatnie logowanie</th>
                <th>Akcje</th>
              </tr>
            </thead>
            <tbody>
              {allUsers.map(user => (
                <tr>
                  <td>
                    <div class="user-email">{user.email}</div>
                    {user.id === auth.userId && (
                      <div class="user-date">to Ty</div>
                    )}
                  </td>
                  <td>
                    <form method="POST" class="inline-form">
                      <input type="hidden" name="action" value="update-role" />
                      <input type="hidden" name="userId" value={user.id} />
                      <select name="role" onchange="this.form.submit()">
                        <option value="super-admin" selected={user.role === 'super-admin'}>Super Admin</option>
                        <option value="admin" selected={user.role === 'admin'}>Admin</option>
                        <option value="editor" selected={user.role === 'editor'}>Editor</option>
                      </select>
                    </form>
                  </td>
                  <td>
                    <form method="POST" class="inline-form">
                      <input type="hidden" name="action" value="update-business" />
                      <input type="hidden" name="userId" value={user.id} />
                      <select name="businessId" onchange="this.form.submit()">
                        <option value="" selected={!user.businessId}>— brak —</option>
                        {allBusinesses.map(b => (
                          <option value={b} selected={user.businessId === b}>{b}</option>
                        ))}
                      </select>
                    </form>
                  </td>
                  <td>
                    <div class="user-date">
                      {user.lastLoginAt
                        ? new Date(user.lastLoginAt).toLocaleDateString('pl-PL', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })
                        : 'Nigdy'}
                    </div>
                  </td>
                  <td>
                    {user.id !== auth.userId && (
                      <form method="POST" onsubmit="return confirm('Czy na pewno chcesz usunąć tego użytkownika?')">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="userId" value={user.id} />
                        <button type="submit" class="btn btn-danger">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                            <path d="M10 11v6"></path>
                            <path d="M14 11v6"></path>
                          </svg>
                          Usuń
                        </button>
                      </form>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

    <!-- Create user form -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Dodaj użytkownika</span>
      </div>
      <div class="card-body">
        <form method="POST">
          <input type="hidden" name="action" value="create" />

          <div class="form-row">
            <label for="new-email">Adres email</label>
            <input type="email" id="new-email" name="email" placeholder="user@example.com" required />
          </div>

          <div class="form-row">
            <label for="new-password">Hasło (min. 8 znaków)</label>
            <input type="password" id="new-password" name="password" placeholder="••••••••" required minlength="8" />
          </div>

          <div class="form-row">
            <label for="new-role">Rola</label>
            <select id="new-role" name="role">
              <option value="admin">Admin</option>
              <option value="editor">Editor</option>
              <option value="super-admin">Super Admin</option>
            </select>
          </div>

          <div class="form-row">
            <label for="new-business">Przypisz do biznesu</label>
            <select id="new-business" name="businessId">
              <option value="">— brak —</option>
              {allBusinesses.map(b => (
                <option value={b}>{b}</option>
              ))}
            </select>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Utwórz użytkownika
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Handle logout redirect after form submission
    document.querySelector('form[action="/api/auth/logout"]')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
