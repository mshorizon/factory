---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getLayoutConfig, getNavLinks } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";
import { deepTranslate } from "../../lib/i18n";
import { deepResolveImages } from "../../lib/images";
import { getBlogsBySiteId } from "@mshorizon/db";
import { BlogGrid } from "@mshorizon/ui";
import type { BusinessProfile } from "@mshorizon/schema";
import type { BlogPost } from "@mshorizon/ui/sections/blog/types";

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations, site } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Fetch all published blogs from database in current language
const blogs = site ? await getBlogsBySiteId(site.id, true, currentLang) : [];

// Transform blogs to BlogPost[] format for BlogGrid component
const blogPosts: BlogPost[] = blogs.map((blog) => ({
  title: blog.title,
  description: blog.description || "",
  image: blog.image || undefined,
  date: blog.publishedAt ? new Date(blog.publishedAt).toLocaleDateString(currentLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }) : undefined,
  href: `/blog/${blog.slug}`,
}));

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

// Build page title
const pageTitle = `Blog | ${business.business.name}`;

// Pre-resolve footer links
const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

// Pre-resolve footer columns
const footerColumns = layout.footer.columns?.map((col: any) => ({
  title: col.title,
  links: col.links?.map((link: any) => ({
    label: link.label,
    href: link.href || resolveTarget(link.target, business),
  })) || [],
})) || [];

// Check if business has any shop sections (to show cart button)
const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

// Extract phone for sticky mobile CTA
const businessPhone = business.business.contact?.phone;

// Convert socials Record<string, string> to SocialLink[] for footer
const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang}>
  <Navbar
    logo={business.business.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
  />
  <!-- Navbar height spacer -->
  <div class:list={[
    "bg-secondary",
    "h-16 md:h-24",
    layout.navbar.extensions?.some((ext: any) => ext.type === 'upper-bar') && "md:h-[136px]"
  ]} />
  <main class="flex-1">
    <!-- Dark Hero Section -->
    <section class="relative bg-secondary py-spacing-section-sm overflow-visible">
      <!-- Decorative dot pattern -->
      <div class="absolute top-8 left-8 w-24 h-24 opacity-20">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <pattern id="dots-1" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="currentColor" class="text-primary" />
          </pattern>
          <rect width="100%" height="100%" fill="url(#dots-1)" />
        </svg>
      </div>
      <div class="absolute bottom-8 right-8 w-32 h-32 opacity-20">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <pattern id="dots-2" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="currentColor" class="text-primary" />
          </pattern>
          <rect width="100%" height="100%" fill="url(#dots-2)" />
        </svg>
      </div>

      <div class="container mx-auto px-spacing-container relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white uppercase">
            Blog
          </h1>
          <p class="text-lg md:text-xl text-muted mt-spacing-lg max-w-2xl mx-auto">
            Najnowsze artykuły, porady i aktualności
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="bg-background py-spacing-section-sm">
      <div class="container mx-auto px-spacing-container">
        {blogPosts.length > 0 ? (
          <BlogGrid client:load posts={blogPosts} ctaLabel="Czytaj więcej" />
        ) : (
          <div class="text-center py-spacing-3xl">
            <p class="text-muted text-lg">Brak opublikowanych artykułów</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer
    businessName={business.business.name}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
  />
</BaseLayout>
