---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getLayoutConfig, getNavLinks } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";
import { deepTranslate, t } from "../../lib/i18n";
import { deepResolveImages } from "../../lib/images";
import { getBlogsBySiteId } from "@mshorizon/db";
import { BlogCards, BlogGrid, SectionHeader } from "@mshorizon/ui";
import type { BusinessProfile } from "@mshorizon/schema";
import type { BlogPost } from "@mshorizon/ui/sections/blog/types";
import { getSectionVariant } from "../../lib/pages";

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations, site } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Fetch all published blogs from database in current language, fallback to all languages
let blogs = site ? await getBlogsBySiteId(site.id, true, currentLang) : [];
if (blogs.length === 0 && site) {
  blogs = await getBlogsBySiteId(site.id, true);
}

// Transform blogs to BlogPost[] format
const blogPosts: BlogPost[] = blogs.map((blog) => ({
  title: blog.title,
  description: blog.description || "",
  image: blog.image || undefined,
  category: (blog as any).category || "Article",
  date: blog.publishedAt ? new Date(blog.publishedAt).toLocaleDateString(currentLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }) : undefined,
  href: `/blog/${blog.slug}`,
}));

// Get badge variant from theme
const badgeVariant = (business as any).theme?.badgeVariant || "accent";
const majorTheme = (business as any).theme?.majorTheme;

// Resolve the same variant as the home page blog section uses
const homeBlogSection = (business.pages?.home as any)?.sections?.find((s: any) => s.type === "blog");
const blogVariant = homeBlogSection ? getSectionVariant(homeBlogSection as any, majorTheme) : "default";
const isCards = blogVariant === "cards";
const isCardsLight = blogVariant === "cards-light";

// Get blog page config from template
const blogPage = business.pages?.blog;
const blogHeader = blogPage?.sections?.[0]?.header || {};
const blogBadge = blogHeader.badge || t(translations, "blog.badge", "Blog");
const blogTitle = blogHeader.title || t(translations, "blog.title", "Blog");
const blogSubtitle = blogHeader.subtitle || t(translations, "blog.subtitle", "");
const ctaLabel = homeBlogSection?.ctaLabel || t(translations, "blog.readMore", "Czytaj więcej");

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

// Build page title
const pageTitle = `Blog | ${business.business.name}`;

// Canonical URL
const canonicalUrl = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete('_preview');
  u.searchParams.delete('business');
  return u.toString();
})();

const blogMetaDescription = `Najnowsze artykuły, porady i aktualności — ${business.business.name}`;

// Pre-resolve footer links
const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

// Auto-build pages column from nav links
const pagesColumn = {
  title: t(translations, "footer.columns.pages.title", "Strony"),
  links: navLinks,
};

// Pre-resolve footer columns (prepend auto pages column, then JSON columns
// — filter out any JSON column that duplicates the auto navbar-based one)
const footerColumns = [
  pagesColumn,
  ...(layout.footer.columns
    ?.filter((col: any) => col.title !== pagesColumn.title)
    .map((col: any) => ({
      title: col.title,
      links: col.links?.map((link: any) => ({
        label: link.label,
        href: link.href || resolveTarget(link.target, business),
      })) || [],
    })) || []),
];

// Check if business has any shop sections (to show cart button)
const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

// Extract phone for sticky mobile CTA
const businessPhone = business.business.contact?.phone;

// Convert socials Record<string, string> to SocialLink[] for footer
const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang} description={blogMetaDescription} canonical={canonicalUrl} siteName={business.business.name}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
  />
  <main class="flex-1 pt-14 lg:pt-16">
    <section class="pt-[120px] pb-spacing-section-sm">
      <div class="container mx-auto px-spacing-container">
        {isCards || isCardsLight ? (
          <SectionHeader
            badge={blogBadge}
            title={blogTitle}
            subtitle={blogSubtitle}
            layout="stacked"
            align="center"
            badgeVariant="text"
          />
        ) : (
          <SectionHeader
            badge={blogBadge}
            title={blogTitle}
            subtitle={blogSubtitle}
            layout="split"
            align="left"
            badgeVariant={badgeVariant as any}
          />
        )}
        {blogPosts.length > 0 ? (
          isCards || isCardsLight ? (
            <BlogCards client:load posts={blogPosts} ctaLabel={ctaLabel} withCard={isCardsLight} />
          ) : (
            <BlogGrid client:load posts={blogPosts} ctaLabel={ctaLabel} />
          )
        ) : (
          <div class="text-center py-spacing-3xl">
            <p class="text-muted text-lg">Brak opublikowanych artykułów</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
    background={layout.footer.background}
  />
</BaseLayout>
