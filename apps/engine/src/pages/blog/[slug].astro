---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getLayoutConfig, getNavLinks } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";
import { deepTranslate, t } from "../../lib/i18n";
import { deepResolveImages } from "../../lib/images";
import { getBlogBySlug } from "@mshorizon/db";
import CommentSection from "../../components/blog/CommentSection.astro";
import type { BusinessProfile } from "@mshorizon/schema";

// Get route params
const { slug } = Astro.params;

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations, site } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Find the blog by slug in current language (fallback to any language)
let blog = site && slug ? await getBlogBySlug(site.id, slug, currentLang) : null;
if (!blog && site && slug) {
  blog = await getBlogBySlug(site.id, slug);
}

// 404 if blog not found or not published
if (!blog || blog.status !== "published") {
  return new Response(null, { status: 404, statusText: "Blog Post Not Found" });
}

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

// Build page title and meta description
const pageTitle = blog.metaTitle || `${blog.title} | ${business.business.name}`;
const metaDescription = blog.metaDescription || blog.description;

// Canonical URL
const canonicalUrl = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete('_preview');
  u.searchParams.delete('business');
  return u.toString();
})();

// Article JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": blog.title,
  ...(blog.description && { "description": blog.description }),
  ...(blog.image && { "image": blog.image }),
  ...(blog.publishedAt && { "datePublished": new Date(blog.publishedAt).toISOString() }),
  ...(blog.author && { "author": { "@type": "Person", "name": blog.author } }),
  "publisher": {
    "@type": "Organization",
    "name": business.business.name,
    "url": new URL(canonicalUrl).origin + '/'
  },
  "url": canonicalUrl
};

// Social share URLs (built client-side via script, but encode title here)
const shareTitle = encodeURIComponent(blog.title);

// Pre-resolve footer links
const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

// Auto-build pages column from nav links
const pagesColumn = {
  title: t(translations, "footer.columns.pages.title", "Strony"),
  links: navLinks,
};

// Pre-resolve footer columns (prepend auto pages column, then JSON columns
// — filter out any JSON column that duplicates the auto navbar-based one)
const footerColumns = [
  pagesColumn,
  ...(layout.footer.columns
    ?.filter((col: any) => col.title !== pagesColumn.title)
    .map((col: any) => ({
      title: col.title,
      links: col.links?.map((link: any) => ({
        label: link.label,
        href: link.href || resolveTarget(link.target, business),
      })) || [],
    })) || []),
];

// Check if business has any shop sections (to show cart button)
const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

// Determine back link: use ?from= param if present, otherwise fall back to /blog
const fromParam = Astro.url.searchParams.get("from");
const backHref = fromParam ? decodeURIComponent(fromParam) : "/blog";

// Convert socials Record<string, string> to SocialLink[] for footer
const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];

// Format date
const formattedDate = blog.publishedAt ? new Date(blog.publishedAt).toLocaleDateString(currentLang, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : null;

const majorTheme = (business as any).theme?.majorTheme;
const isPortfolioLaw = majorTheme === "portfolio-law";

// Find about section image for contact card sidebar (portfolio-law)
// Match both "about" and "about-summary" types; search home first, then other pages as fallback
const aboutTypes = new Set(["about", "about-summary"]);
const findAboutImage = (sections: any[] | undefined) =>
  sections?.find((s: any) => aboutTypes.has(s?.type) && s?.image)?.image as string | undefined;
let contactCardImage = findAboutImage((business.pages?.home as any)?.sections);
if (!contactCardImage) {
  for (const page of Object.values(business.pages ?? {})) {
    const img = findAboutImage((page as any)?.sections);
    if (img) { contactCardImage = img; break; }
  }
}
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang} description={metaDescription || undefined} canonical={canonicalUrl} ogImage={blog.image || undefined} ogType="article" siteName={business.business.name} jsonLd={jsonLd}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
    showAddress={layout.navbar.showAddress}
    showAdditionalInfo={layout.navbar.showAdditionalInfo}
  />
  <main class="flex-1" data-nav-offset>
    {isPortfolioLaw ? (
      <!-- Portfolio-Law: BlogStandalone-style layout with contact sidebar, no comments -->
      <section class="py-spacing-section-sm">
        <div class="container mx-auto px-spacing-container">
          <div class="flex flex-col lg:flex-row gap-spacing-2xl lg:gap-spacing-3xl items-start">

            <!-- Main content -->
            <div class="min-w-0 flex-1">
              <!-- Go back link -->
              <a data-reveal data-reveal-delay="0" href={backHref} class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-foreground transition-colors mb-spacing-xl">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                {t(translations, "blog.back", "Go back")}
              </a>

              <!-- Category + Date -->
              {(blog.category || formattedDate) && (
                <div data-reveal data-reveal-delay="100" class="flex items-center gap-spacing-sm mb-spacing-lg">
                  {blog.category && (
                    <span class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                      {blog.category}
                    </span>
                  )}
                  {formattedDate && (
                    <time datetime={blog.publishedAt?.toISOString()} class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                      {formattedDate}
                    </time>
                  )}
                </div>
              )}

              <!-- Title -->
              <h1 data-reveal data-reveal-delay="200" class="text-4xl md:text-5xl font-heading text-foreground mb-spacing-lg">
                {blog.title}
              </h1>

              <!-- Description -->
              {blog.description && (
                <p data-reveal data-reveal-delay="300" class="text-lg text-muted leading-relaxed mb-spacing-2xl">
                  {blog.description}
                </p>
              )}

              <!-- Cover Image -->
              {blog.image && (
                <div data-reveal data-reveal-delay="400" class="mb-spacing-2xl">
                  <div class="relative w-full rounded-lg overflow-hidden">
                    <img
                      src={blog.image}
                      alt={blog.title}
                      class="w-full h-auto max-h-[400px] object-cover"
                      loading="eager"
                      decoding="async"
                    />
                  </div>
                </div>
              )}

              <!-- Content -->
              <div data-reveal data-reveal-delay="0" class="prose prose-lg prose-headings:uppercase prose-headings:font-bold prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl prose-p:text-foreground prose-strong:text-foreground prose-ul:text-foreground prose-li:text-foreground prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
                <Fragment set:html={blog.content?.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>') ?? ''} />
              </div>
            </div>

            <!-- Sidebar contact card -->
            <aside data-reveal data-reveal-delay="200" class="w-full lg:w-[368px] shrink-0 lg:sticky lg:top-24">
              <div class="bg-card rounded-xl flex flex-col items-start text-left">
                {contactCardImage && (
                  <div class="w-full p-spacing-md">
                    <img
                      src={contactCardImage}
                      alt={business.business.name}
                      class="w-full max-w-[336px] max-h-[256px] object-cover rounded-radius"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="p-spacing-md pb-spacing-lg flex flex-col items-start text-left gap-spacing-md w-full">
                {business.business.name && (
                  <p class="text-[20px] text-foreground leading-snug font-heading">
                    {business.business.name}
                  </p>
                )}

                {(business.business.contact?.phone || business.business.contact?.email) && (
                  <div class="w-full flex flex-col gap-spacing-sm">
                    {business.business.contact?.phone && (
                      <a href={`tel:${business.business.contact.phone}`} class="flex items-center gap-spacing-sm text-sm text-foreground hover:text-primary transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0 text-muted"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.05-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.24 1.05l-2.21 2.17z"/></svg>
                        <span>{business.business.contact.phone}</span>
                      </a>
                    )}
                    {business.business.contact?.email && (
                      <a href={`mailto:${business.business.contact.email}`} class="flex items-center gap-spacing-sm text-sm text-foreground hover:text-primary transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0 text-muted"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.24-8 5-8-5V6l8 5 8-5z"/></svg>
                        <span class="break-all">{business.business.contact.email}</span>
                      </a>
                    )}
                  </div>
                )}

                <a
                  href="/contact"
                  class="mt-spacing-xs inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline transition-colors"
                >
                  {t(translations, "nav.contact", "Kontakt")}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                </div>
              </div>
            </aside>

          </div>
        </div>
      </section>
    ) : (
      <Fragment>
        <!-- Blog Header -->
        <section class="py-spacing-section-sm">
          <div class="container mx-auto">
            <div class="max-w-3xl mx-auto">
              <!-- Go back link -->
              <a data-reveal data-reveal-delay="0" href={backHref} class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-foreground transition-colors mb-spacing-xl">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                {t(translations, "blog.back", "Go back")}
              </a>

              <!-- Category + Date -->
              <div data-reveal data-reveal-delay="100" class="flex items-center gap-spacing-sm mb-spacing-lg">
                {blog.category && (
                  <span class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                    {blog.category}
                  </span>
                )}
                {formattedDate && (
                  <time datetime={blog.publishedAt?.toISOString()} class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                    {formattedDate}
                  </time>
                )}
              </div>

              <!-- Title -->
              <h1 data-reveal data-reveal-delay="200" class="text-4xl md:text-5xl lg:text-6xl font-heading text-foreground mb-spacing-lg">
                {blog.title}
              </h1>

              <!-- Description -->
              {blog.description && (
                <p data-reveal data-reveal-delay="300" class="text-lg text-muted leading-relaxed">
                  {blog.description}
                </p>
              )}
            </div>
          </div>
        </section>

        <!-- Cover Image -->
        {blog.image && (
          <div data-reveal data-reveal-delay="0" class="container mx-auto mb-spacing-3xl">
            <div class="max-w-5xl mx-auto">
              <div class="relative w-full rounded-lg overflow-hidden">
                <div class="absolute left-0 top-0 bottom-0 w-16 md:w-24 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none" />
                <div class="absolute right-0 top-0 bottom-0 w-16 md:w-24 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none" />
                <img
                  src={blog.image}
                  alt={blog.title}
                  class="w-full h-auto max-h-[500px] object-cover"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        )}

        <!-- Content Section -->
        <section class="relative pb-16 md:pb-24">

          <!-- Blog Content -->
          <div data-reveal data-reveal-delay="0" class="container mx-auto px-spacing-container mt-spacing-lg">
            <div class="max-w-3xl mx-auto prose prose-lg prose-headings:uppercase prose-headings:font-bold prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl prose-p:text-foreground prose-strong:text-foreground prose-ul:text-foreground prose-li:text-foreground prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
              <Fragment set:html={blog.content?.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>') ?? ''} />
            </div>
          </div>

          <!-- Social Share + Copy Link -->
          <div class="container mx-auto px-spacing-container mt-spacing-2xl">
            <div class="max-w-3xl mx-auto">
              <div class="flex flex-wrap items-center gap-3 pt-spacing-xl border-t border-border">
                <span class="text-sm text-muted font-medium">Udostępnij:</span>
                <!-- X (Twitter) -->
                <a
                  id="share-x"
                  href={`https://x.com/intent/tweet?text=${shareTitle}&url=`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-radius-sm border border-border text-sm text-muted hover:text-foreground hover:border-foreground transition-colors"
                  aria-label="Udostępnij na X"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  X
                </a>
                <!-- Facebook -->
                <a
                  id="share-fb"
                  href={`https://www.facebook.com/sharer/sharer.php?u=`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-radius-sm border border-border text-sm text-muted hover:text-foreground hover:border-foreground transition-colors"
                  aria-label="Udostępnij na Facebook"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  Facebook
                </a>
                <!-- LinkedIn -->
                <a
                  id="share-li"
                  href={`https://www.linkedin.com/sharing/share-offsite/?url=`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-radius-sm border border-border text-sm text-muted hover:text-foreground hover:border-foreground transition-colors"
                  aria-label="Udostępnij na LinkedIn"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
                <!-- Copy Link -->
                <button
                  id="copy-link-btn"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-radius-sm border border-border text-sm text-muted hover:text-foreground hover:border-foreground transition-colors cursor-pointer"
                  aria-label="Kopiuj link do artykułu"
                >
                  <svg id="copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                  </svg>
                  <svg id="check-icon" class="w-4 h-4 hidden text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span id="copy-label">Kopiuj link</span>
                </button>
              </div>
            </div>
          </div>

          <!-- Comments Section -->
          <div class="container mx-auto px-spacing-container mt-spacing-3xl">
            <div class="max-w-3xl mx-auto">
              <CommentSection blogId={blog.id} />
            </div>
          </div>
        </section>
      </Fragment>
    )}
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
    background={layout.footer.background}
  />
</BaseLayout>

<script>
  // Append current page URL to share links
  const url = encodeURIComponent(window.location.href);
  const xLink = document.getElementById('share-x') as HTMLAnchorElement;
  const fbLink = document.getElementById('share-fb') as HTMLAnchorElement;
  const liLink = document.getElementById('share-li') as HTMLAnchorElement;
  if (xLink) xLink.href += url;
  if (fbLink) fbLink.href += url;
  if (liLink) liLink.href += url;

  // Copy link button
  const copyBtn = document.getElementById('copy-link-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const copyLabel = document.getElementById('copy-label');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        if (copyLabel) copyLabel.textContent = 'Skopiowano!';
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          if (copyLabel) copyLabel.textContent = 'Kopiuj link';
        }, 2000);
      } catch {}
    });
  }
</script>

<style>
  /* Ensure proper styling for the rich text content */
  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.75rem;
  }

  .prose :global(strong) {
    font-weight: var(--fw-semibold, 600);
  }

  .prose :global(a) {
    transition: all 0.2s ease;
  }

  .prose :global(img) {
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: var(--radius);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--muted-foreground);
    margin: 2rem 0;
  }

  .prose :global(code) {
    background: var(--secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--secondary);
    padding: 1.5rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
