---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate } from "../lib/i18n";
import { deepResolveImages } from "../lib/images";
import type { BusinessProfile } from "@mshorizon/schema";

const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

const translatedData = deepTranslate(translations, businessData) as BusinessProfile;
const business = deepResolveImages(translatedData, businessId);
const layout = getLayoutConfig(business);

const navLinksRaw = getNavLinks(business);
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

const pagesColumn = {
  title: "Strony",
  links: navLinks,
};

const footerColumns = [
  pagesColumn,
  ...(layout.footer.columns?.map((col: any) => ({
    title: col.title,
    links: col.links?.map((link: any) => ({
      label: link.label,
      href: link.href || resolveTarget(link.target, business),
    })) || [],
  })) || []),
];

const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];

const businessName = business.business.name;
const email = business.business.contact?.email;
const year = new Date().getFullYear();
---

<BaseLayout title={`Polityka prywatności | ${businessName}`} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang}>
  <Navbar
    logo={businessName}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
  />
  <main class="flex-1">
    <PageHero title="Polityka prywatności" hasUpperBar={layout.navbar.extensions?.some((ext: any) => ext.type === 'upper-bar') ?? false} />
    <div class="container mx-auto py-spacing-section-sm">
      <div class="max-w-3xl mx-auto prose prose-neutral">

        <h2>1. Informacje ogólne</h2>
        <p>
          Niniejsza polityka dotyczy serwisu internetowego prowadzonego przez <strong>{businessName}</strong>.
          {email && <> W sprawach związanych z ochroną danych osobowych można kontaktować się pod adresem e-mail: <a href={`mailto:${email}`}>{email}</a>.</>}
        </p>
        <p>
          Operator serwisu jest administratorem danych osobowych w odniesieniu do danych podanych dobrowolnie w ramach serwisu oraz zbieranych automatycznie podczas korzystania ze stron.
        </p>
        <p>
          Dane osobowe przetwarzane są zgodnie z Rozporządzeniem Parlamentu Europejskiego i Rady (UE) 2016/679 z dnia 27 kwietnia 2016 r. (RODO).
        </p>

        <h2>2. Wybrane metody ochrony danych</h2>
        <p>Serwis stosuje następujące środki techniczne i organizacyjne w celu ochrony danych:</p>
        <ul>
          <li>szyfrowanie połączenia za pomocą certyfikatu SSL,</li>
          <li>regularne aktualizacje oprogramowania i systemów bezpieczeństwa,</li>
          <li>ograniczony dostęp do danych wyłącznie dla upoważnionych osób,</li>
          <li>regularne tworzenie kopii zapasowych danych.</li>
        </ul>

        <h2>3. Hosting</h2>
        <p>
          Serwis jest hostowany na serwerach zewnętrznego dostawcy usług hostingowych. Dostawca ten może przetwarzać dane zawarte w logach serwera, takie jak: adresy IP odwiedzających, czas żądań, adresy URL, kody odpowiedzi HTTP oraz informacje o przeglądarce. Dane te służą wyłącznie celom technicznym i administracyjnym.
        </p>

        <h2>4. Prawa użytkownika i wykorzystanie danych</h2>
        <p>Osobie, której dane dotyczą, przysługują następujące prawa:</p>
        <ul>
          <li>prawo dostępu do swoich danych oraz otrzymania ich kopii,</li>
          <li>prawo do sprostowania (poprawiania) danych,</li>
          <li>prawo do usunięcia danych (prawo do bycia zapomnianym),</li>
          <li>prawo do ograniczenia przetwarzania,</li>
          <li>prawo do przenoszenia danych,</li>
          <li>prawo do wniesienia sprzeciwu wobec przetwarzania,</li>
          <li>prawo do wniesienia skargi do organu nadzorczego – Prezesa Urzędu Ochrony Danych Osobowych (ul. Stawki 2, 00-193 Warszawa).</li>
        </ul>
        <p>
          Dane przetwarzane w celach marketingowych przechowywane są przez okres nie dłuższy niż 3 lata od ostatniego kontaktu, chyba że wcześniej zostanie wniesiony skuteczny sprzeciw.
        </p>

        <h2>5. Informacje w formularzach</h2>
        <p>
          Serwis zbiera informacje podawane dobrowolnie przez użytkowników za pośrednictwem formularzy kontaktowych i innych formularzy dostępnych w serwisie. Podanie danych jest dobrowolne, lecz może być niezbędne do realizacji określonej usługi lub udzielenia odpowiedzi na zapytanie.
        </p>
        <p>
          Dane podane w formularzach są przetwarzane w celu wynikającym z funkcji konkretnego formularza, np. udzielenia odpowiedzi na zapytanie, realizacji zamówienia lub nawiązania kontaktu handlowego.
        </p>

        <h2>6. Logi administratora</h2>
        <p>
          Informacje o zachowaniu użytkowników w serwisie mogą być przedmiotem logowania. Dane te są wykorzystywane wyłącznie w celu administrowania serwisem i zapewnienia jego prawidłowego działania.
        </p>

        <h2>7. Istotne techniki marketingowe</h2>
        <p>Operator serwisu może stosować następujące techniki marketingowe:</p>
        <ul>
          <li><strong>Google Analytics</strong> – analiza statystyczna ruchu w serwisie w sposób zanonimizowany (dane nie pozwalają na identyfikację użytkownika),</li>
          <li><strong>remarketing</strong> – wyświetlanie reklam użytkownikom, którzy odwiedzili serwis, za pośrednictwem sieci reklamowych,</li>
          <li><strong>pixel Facebooka</strong> – anonimowa analiza działań użytkowników na potrzeby kampanii reklamowych w serwisie Facebook,</li>
          <li><strong>mapy ciepła i nagrywanie sesji</strong> – zanonimizowane śledzenie zachowania użytkownika w celu optymalizacji serwisu.</li>
        </ul>

        <h2>8. Informacja o plikach cookies</h2>
        <p>
          Serwis korzysta z plików cookies (ciasteczek). Pliki cookies to małe pliki tekstowe zapisywane na urządzeniu użytkownika przez przeglądarkę internetową.
        </p>
        <p>Wyróżniamy następujące rodzaje plików cookies:</p>
        <ul>
          <li><strong>cookies sesyjne</strong> – przechowywane przez czas trwania sesji przeglądarki i usuwane po jej zakończeniu,</li>
          <li><strong>cookies stałe</strong> – przechowywane przez określony czas lub do momentu ręcznego usunięcia przez użytkownika.</li>
        </ul>
        <p>
          Pliki cookies służą do utrzymania sesji użytkownika, personalizacji treści, realizacji celów statystycznych i marketingowych. Użytkownik może zmienić ustawienia dotyczące plików cookies w swojej przeglądarce internetowej lub je usunąć.
        </p>

        <h2>9. Zarządzanie plikami cookies</h2>
        <p>
          Każda przeglądarka internetowa umożliwia zarządzanie plikami cookies w ustawieniach. Instrukcje dla poszczególnych przeglądarek dostępne są w dokumentacji lub pomocy danej przeglądarki (m.in. Chrome, Firefox, Safari, Edge, Opera). Wyłączenie obsługi plików cookies może ograniczyć niektóre funkcjonalności serwisu.
        </p>
        <p>
          W przypadku urządzeń mobilnych zarządzanie plikami cookies odbywa się przez ustawienia systemowe lub ustawienia używanej przeglądarki mobilnej.
        </p>

        <p class="text-sm text-muted mt-8">Ostatnia aktualizacja: {year}</p>
      </div>
    </div>
  </main>
  <Footer
    businessName={businessName}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
  />
</BaseLayout>

<style>
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--foreground);
  }
  .prose p, .prose li {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }
  .prose ul {
    padding-left: 1.5rem;
    list-style-type: disc;
    margin-bottom: 1rem;
  }
  .prose a {
    color: var(--primary);
    text-decoration: underline;
  }
  .prose strong {
    color: var(--foreground);
    font-weight: 600;
  }
</style>
