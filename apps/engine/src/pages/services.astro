---
import { Navbar, Footer, Card, CardHeader, CardTitle, CardDescription, CardContent, Button } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { businessData, theme } from "../lib/business";

const { name, navigation, sections } = businessData;
const { services, footer } = sections;
---

<BaseLayout title={`${services.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links}
    cta={navigation.cta}
  />
  <main class="bg-background py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-foreground mb-4 text-center">{services.title}</h1>
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">
        {services.subtitle}
      </p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.items.map((item: any) => (
          <Card className="group hover:shadow-lg transition-all hover:-translate-y-1">
            <CardHeader>
              <CardTitle>{item.title}</CardTitle>
              <CardDescription>{item.description}</CardDescription>
            </CardHeader>
            <CardContent>
              {item.price && <p class="text-2xl font-bold text-primary">{item.price}</p>}
              <Button asChild variant="outline" size="sm" className="mt-4 w-full">
                <a href="/contact">{navigation.cta.label}</a>
              </Button>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </main>
  <Footer
    businessName={name}
    links={footer?.links}
    copyright={footer?.copyright}
  />
</BaseLayout>
