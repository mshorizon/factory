---
import { Navbar, Footer, Card, CardHeader, CardTitle, CardDescription, CardContent, Button } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBusinessContext } from "../lib/business";

const { businessId, businessData, theme, t, currentLang, allBusinesses } = getBusinessContext(Astro.request);
const { name, navigation } = businessData;
---

<BaseLayout title={`${t.services.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links.map((link: any, i: number) => ({
      ...link,
      label: [t.nav.home, t.nav.services, t.nav.about, t.nav.contact][i] || link.label
    }))}
    cta={{ ...navigation.cta, label: t.nav.cta }}
    currentLanguage={currentLang}
    businesses={allBusinesses}
    currentBusinessId={businessId}
  />
  <main class="flex-1 bg-background py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-foreground mb-4 text-center">{t.services.title}</h1>
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">
        {t.services.subtitle}
      </p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {t.services.items.map((item: any) => (
          <Card className="group hover:shadow-lg transition-all hover:-translate-y-1">
            <CardHeader>
              <CardTitle>{item.title}</CardTitle>
              <CardDescription>{item.description}</CardDescription>
            </CardHeader>
            <CardContent>
              {item.price && <p class="text-2xl font-bold text-primary">{item.price}</p>}
              <Button asChild variant="outline" size="sm" className="mt-4 w-full">
                <a href="/contact">{t.nav.cta}</a>
              </Button>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </main>
  <Footer
    businessName={name}
    links={[
      { label: t.footer.privacy, href: "/privacy" },
      { label: t.footer.terms, href: "/terms" }
    ]}
    copyright={t.footer.copyright}
  />
</BaseLayout>
