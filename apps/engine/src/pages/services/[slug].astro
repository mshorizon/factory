---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getLayoutConfig, getNavLinks } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";
import { deepTranslate, t } from "../../lib/i18n";
import { deepResolveImages } from "../../lib/images";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BlogStandaloneSection from "../../components/sections/BlogStandaloneSection.astro";
import type { BusinessProfile, Service } from "@mshorizon/schema";

// Get route params
const { slug } = Astro.params;

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Find the service by slug
const service = business.data.services?.find((s: Service) => s.slug === slug);

// 404 if service not found
if (!service) {
  return new Response(null, { status: 404, statusText: "Service Not Found" });
}

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta ? {
  label: business.navigation.cta.label,
  href: resolveTarget(business.navigation.cta.target, business),
} : undefined;

// Build page title
const pageTitle = `${service.title} | ${business.business.name}`;

// Canonical URL
const canonicalUrl = (() => {
  const u = new URL(Astro.url.href);
  u.searchParams.delete('_preview');
  u.searchParams.delete('business');
  return u.toString();
})();

// Meta description
const metaDescription = service.description || undefined;

// Service JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  ...(service.description && { "description": service.description }),
  ...(service.image && { "image": service.image }),
  "provider": {
    "@type": "LocalBusiness",
    "name": business.business.name,
    "url": new URL(canonicalUrl).origin + '/'
  },
  "url": canonicalUrl
};

// Breadcrumbs
const breadcrumbs = [
  { label: t(translations, "nav.home", "Strona główna"), href: "/" },
  { label: t(translations, "nav.services", "Usługi"), href: "/services" },
  { label: service.title },
];

// Pre-resolve footer links
const footerLinks = layout.footer.links?.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
})) || [];

// Pre-resolve footer columns
const footerColumns = layout.footer.columns?.map((col: any) => ({
  title: col.title,
  links: col.links?.map((link: any) => ({
    label: link.label,
    href: link.href || resolveTarget(link.target, business),
  })) || [],
})) || [];

// Check if business has any shop sections (to show cart button)
const hasShopSection = Object.values(business.pages).some((p: any) =>
  p.sections?.some((s: any) => s.type === "shop")
);

// Convert socials Record<string, string> to SocialLink[] for footer
const socialLinks = business.business.socials
  ? Object.entries(business.business.socials).map(([platform, url]) => ({ platform, url }))
  : [];
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang} description={metaDescription} canonical={canonicalUrl} ogImage={service.image || undefined} siteName={business.business.name} jsonLd={jsonLd}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered" | "transparent"}
    showCart={hasShopSection}
    extensions={layout.navbar.extensions}
    contact={business.business.contact}
    socials={business.business.socials}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
    showAddress={layout.navbar.showAddress}
    showAdditionalInfo={layout.navbar.showAdditionalInfo}
  />
  <main class="flex-1 pt-14 lg:pt-16">
    <!-- White Content Section -->
    <section class="relative bg-background pt-16 md:pt-24 pb-16 md:pb-24">
      <!-- Breadcrumbs -->
      {!layout.hideBreadcrumbs && <Breadcrumbs items={breadcrumbs} />}

      <!-- Service Content -->
      {service.content && (
        <div class="container mx-auto px-4 mt-spacing-lg">
          <div class="max-w-3xl mx-auto prose prose-lg prose-headings:uppercase prose-headings:font-bold prose-h3:text-2xl prose-h4:text-xl prose-p:text-foreground prose-strong:text-foreground prose-ul:text-foreground prose-li:text-foreground">
            <Fragment set:html={service.content} />
          </div>
        </div>
      )}
    </section>

    <!-- Blog standalone section (linked via service.blogSlug) -->
    {service.blogSlug && (
      <BlogStandaloneSection section={{ type: "blog-standalone", blogSlug: service.blogSlug } as any} />
    )}
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    logoIcon={business.business.assets?.icon || business.business.assets?.favicon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    socialLinks={socialLinks}
    extensions={layout.footer.extensions}
    background={layout.footer.background}
  />
</BaseLayout>

<style>
  /* Ensure proper styling for the rich text content */
  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .prose :global(ul) {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.75rem;
  }

  .prose :global(strong) {
    font-weight: var(--fw-semibold, 600);
  }
</style>
