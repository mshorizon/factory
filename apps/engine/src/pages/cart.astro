---
// The cart and checkout views were merged into a single ordering page
// (/checkout) — one step less before placing an order. Keep /cart as a
// permanent redirect so navbar cart buttons and old links keep working.
// Query params are preserved (e.g. the ?business= dev override).
const search = Astro.url.search;
return Astro.redirect(`/checkout${search}`, 301);
---
