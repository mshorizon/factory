---
import { Navbar, Footer, Button, Input, Label, Textarea } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { businessData, theme } from "../lib/business";

const { name, navigation, sections } = businessData;
const { contact, footer } = sections;
---

<BaseLayout title={`${contact.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links}
    cta={navigation.cta}
  />
  <main class="bg-background py-16">
    <div class="container mx-auto px-4 max-w-2xl">
      <h1 class="text-4xl font-bold text-foreground mb-2 text-center">{contact.title}</h1>
      <p class="text-muted text-center mb-8">{contact.subtitle}</p>

      <form class="space-y-6 bg-background border border-border rounded-radius p-8 shadow-sm">
        <div class="space-y-2">
          <Label htmlFor="name" className="text-foreground">Name</Label>
          <Input
            type="text"
            id="name"
            name="name"
            placeholder={contact.form.namePlaceholder}
            required
          />
        </div>
        <div class="space-y-2">
          <Label htmlFor="email" className="text-foreground">Email</Label>
          <Input
            type="email"
            id="email"
            name="email"
            placeholder={contact.form.emailPlaceholder}
            required
          />
        </div>
        <div class="space-y-2">
          <Label htmlFor="message" className="text-foreground">Message</Label>
          <Textarea
            id="message"
            name="message"
            placeholder={contact.form.messagePlaceholder}
            rows={5}
            required
          />
        </div>
        <Button type="submit" size="lg" className="w-full">
          {contact.form.submitButton}
        </Button>
      </form>
    </div>
  </main>
  <Footer
    businessName={name}
    links={footer?.links}
    copyright={footer?.copyright}
  />
</BaseLayout>
