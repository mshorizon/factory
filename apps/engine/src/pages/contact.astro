---
import { Navbar, Footer } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";

import businessData from "../../../../data/honey-worker/honey-worker.json";
import theme from "../../../../data/honey-worker/theme.json";

const { name } = businessData;
---

<BaseLayout title={`Contact | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "About", href: "/about" },
      { label: "Contact", href: "/contact" },
    ]}
    cta={{ label: "Book Now", href: "/contact" }}
  />
  <main class="bg-background py-16">
    <div class="container mx-auto px-4 max-w-2xl">
      <h1 class="text-4xl font-bold text-foreground mb-8 text-center">Contact Us</h1>
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-foreground mb-2">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full px-4 py-2 border border-border rounded-radius bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            required
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-foreground mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="w-full px-4 py-2 border border-border rounded-radius bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            required
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-foreground mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            class="w-full px-4 py-2 border border-border rounded-radius bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            required
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-primary text-white py-3 rounded-radius font-medium hover:opacity-90 transition-opacity"
        >
          Send Message
        </button>
      </form>
    </div>
  </main>
  <Footer businessName={name} />
</BaseLayout>
