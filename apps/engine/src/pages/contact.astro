---
import { Navbar, Footer, Button, Input, Label, Textarea } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBusinessContext } from "../lib/business";

const { businessData, theme, t, currentLang } = getBusinessContext(Astro.request);
const { name, navigation } = businessData;
---

<BaseLayout title={`${t.contact.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links.map((link: any, i: number) => ({
      ...link,
      label: [t.nav.home, t.nav.services, t.nav.about, t.nav.contact][i] || link.label
    }))}
    cta={{ ...navigation.cta, label: t.nav.cta }}
    currentLanguage={currentLang}
  />
  <main class="bg-background py-16">
    <div class="container mx-auto px-4 max-w-2xl">
      <h1 class="text-4xl font-bold text-foreground mb-2 text-center">{t.contact.title}</h1>
      <p class="text-muted text-center mb-8">{t.contact.subtitle}</p>

      <form class="space-y-6 bg-background border border-border rounded-radius p-8 shadow-sm">
        <div class="space-y-2">
          <Label htmlFor="name" className="text-foreground">{t.contact.form.nameLabel}</Label>
          <Input
            type="text"
            id="name"
            name="name"
            placeholder={t.contact.form.namePlaceholder}
            required
          />
        </div>
        <div class="space-y-2">
          <Label htmlFor="email" className="text-foreground">{t.contact.form.emailLabel}</Label>
          <Input
            type="email"
            id="email"
            name="email"
            placeholder={t.contact.form.emailPlaceholder}
            required
          />
        </div>
        <div class="space-y-2">
          <Label htmlFor="message" className="text-foreground">{t.contact.form.messageLabel}</Label>
          <Textarea
            id="message"
            name="message"
            placeholder={t.contact.form.messagePlaceholder}
            rows={5}
            required
          />
        </div>
        <Button type="submit" size="lg" className="w-full">
          {t.contact.form.submitButton}
        </Button>
      </form>
    </div>
  </main>
  <Footer
    businessName={name}
    links={[
      { label: t.footer.privacy, href: "/privacy" },
      { label: t.footer.terms, href: "/terms" }
    ]}
    copyright={t.footer.copyright}
  />
</BaseLayout>
