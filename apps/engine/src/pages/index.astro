---
import { Navbar, Hero, Footer } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { businessData, theme } from "../lib/business";

const { name, navigation, sections } = businessData;
const { hero, footer } = sections;
---

<BaseLayout title={name} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links}
    cta={navigation.cta}
  />
  <Hero
    badge={hero.badge}
    title={hero.title}
    subtitle={hero.subtitle}
    backgroundImage={hero.backgroundImage}
    cta={hero.cta}
    secondaryCta={hero.secondaryCta}
    fullHeight
  />
  <Footer
    businessName={name}
    links={footer?.links}
    copyright={footer?.copyright}
  />
</BaseLayout>
