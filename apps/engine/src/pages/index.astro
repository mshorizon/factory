---
import { Navbar, Hero, Footer } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";

// Load business data and theme
import businessData from "../../../../data/honey-worker/honey-worker.json";
import theme from "../../../../data/honey-worker/theme.json";

const { name, sections } = businessData;
---

<BaseLayout title={name} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={[
      { label: "Services", href: "/services" },
      { label: "About", href: "/about" },
      { label: "Contact", href: "/contact" },
    ]}
    cta={{ label: "Book Now", href: "/contact" }}
  />
  <Hero
    badge="Now Open"
    title={sections.hero.title}
    subtitle={sections.hero.subtitle}
    backgroundImage={sections.hero.backgroundImage}
    cta={{ label: "Book Appointment", href: "/contact" }}
    secondaryCta={{ label: "View Services", href: "/services", variant: "outline" }}
    fullHeight
  />
  <Footer businessName={name} />
</BaseLayout>
