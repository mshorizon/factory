---
import { Navbar, Hero, Footer } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBusinessContext } from "../lib/business";

const { businessData, theme, t, currentLang } = getBusinessContext(Astro.request);
const { name, navigation } = businessData;
---

<BaseLayout title={name} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links.map((link: any, i: number) => ({
      ...link,
      label: [t.nav.home, t.nav.services, t.nav.about, t.nav.contact][i] || link.label
    }))}
    cta={{ ...navigation.cta, label: t.nav.cta }}
    currentLanguage={currentLang}
  />
  <main class="flex-1">
    <Hero
      badge={t.hero.badge}
      title={t.hero.title}
      subtitle={t.hero.subtitle}
      backgroundImage={businessData.sections.hero.backgroundImage}
      cta={{ href: navigation.cta.href, label: t.hero.cta }}
      secondaryCta={{ href: "/services", label: t.hero.secondaryCta }}
      fullHeight
    />
  </main>
  <Footer
    businessName={name}
    links={[
      { label: t.footer.privacy, href: "/privacy" },
      { label: t.footer.terms, href: "/terms" }
    ]}
    copyright={t.footer.copyright}
  />
</BaseLayout>
