---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { CheckoutPageContent } from "@mshorizon/ui";
import { getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate } from "../lib/i18n";
import { deepResolveImages } from "../lib/images";
import type { BusinessProfile } from "@mshorizon/schema";

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
}));

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta
  ? {
      label: business.navigation.cta.label,
      href: resolveTarget(business.navigation.cta.target, business),
    }
  : undefined;

// Build page title
const pageTitle = `${translations["checkout.title"] || "Checkout"} | ${business.business.name}`;

// Pre-resolve footer links
const footerLinks =
  layout.footer.links?.map((link: any) => ({
    label: link.label,
    href: link.href || resolveTarget(link.target, business),
  })) || [];

// Pre-resolve footer columns
const footerColumns =
  layout.footer.columns?.map((col: any) => ({
    title: col.title,
    links:
      col.links?.map((link: any) => ({
        label: link.label,
        href: link.href || resolveTarget(link.target, business),
      })) || [],
  })) || [];

// Get translated checkout labels
const checkoutLabels = {
  pageTitle: translations["checkout.title"] || "Checkout",
  backToCartLabel: translations["checkout.backToCart"] || "Back to cart",
  contactSectionTitle: translations["checkout.contact.title"] || "Contact Information",
  emailLabel: translations["checkout.contact.email"] || "Email",
  emailPlaceholder: translations["checkout.contact.emailPlaceholder"] || "your@email.com",
  phoneLabel: translations["checkout.contact.phone"] || "Phone",
  phonePlaceholder: translations["checkout.contact.phonePlaceholder"] || "+48 123 456 789",
  shippingSectionTitle: translations["checkout.shipping.title"] || "Shipping Address",
  firstNameLabel: translations["checkout.shipping.firstName"] || "First Name",
  firstNamePlaceholder: translations["checkout.shipping.firstNamePlaceholder"] || "Jan",
  lastNameLabel: translations["checkout.shipping.lastName"] || "Last Name",
  lastNamePlaceholder: translations["checkout.shipping.lastNamePlaceholder"] || "Kowalski",
  addressLabel: translations["checkout.shipping.address"] || "Address",
  addressPlaceholder: translations["checkout.shipping.addressPlaceholder"] || "ul. Przykładowa 12/3",
  cityLabel: translations["checkout.shipping.city"] || "City",
  cityPlaceholder: translations["checkout.shipping.cityPlaceholder"] || "Warszawa",
  postalCodeLabel: translations["checkout.shipping.postalCode"] || "Postal Code",
  postalCodePlaceholder: translations["checkout.shipping.postalCodePlaceholder"] || "00-001",
  orderSummaryTitle: translations["checkout.summary.title"] || "Order Summary",
  subtotalLabel: translations["checkout.summary.subtotal"] || "Subtotal",
  shippingLabel: translations["checkout.summary.shipping"] || "Shipping",
  shippingValue: translations["checkout.summary.shippingValue"] || "Free",
  totalLabel: translations["checkout.summary.total"] || "Total",
  placeOrderLabel: translations["checkout.placeOrder"] || "Place Order",
  currency: translations["currency"] || "zł",
};
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered"}
    showCart={true}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
  />
  <main class="flex-1">
    <div id="page-hero" class="py-8 lg:py-12">
      <div class="container mx-auto mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-foreground">
          {checkoutLabels.pageTitle}
        </h1>
      </div>
      <CheckoutPageContent
        client:load
        businessId={businessId}
        backToCartLabel={checkoutLabels.backToCartLabel}
        contactSectionTitle={checkoutLabels.contactSectionTitle}
        emailLabel={checkoutLabels.emailLabel}
        emailPlaceholder={checkoutLabels.emailPlaceholder}
        phoneLabel={checkoutLabels.phoneLabel}
        phonePlaceholder={checkoutLabels.phonePlaceholder}
        shippingSectionTitle={checkoutLabels.shippingSectionTitle}
        firstNameLabel={checkoutLabels.firstNameLabel}
        firstNamePlaceholder={checkoutLabels.firstNamePlaceholder}
        lastNameLabel={checkoutLabels.lastNameLabel}
        lastNamePlaceholder={checkoutLabels.lastNamePlaceholder}
        addressLabel={checkoutLabels.addressLabel}
        addressPlaceholder={checkoutLabels.addressPlaceholder}
        cityLabel={checkoutLabels.cityLabel}
        cityPlaceholder={checkoutLabels.cityPlaceholder}
        postalCodeLabel={checkoutLabels.postalCodeLabel}
        postalCodePlaceholder={checkoutLabels.postalCodePlaceholder}
        orderSummaryTitle={checkoutLabels.orderSummaryTitle}
        subtotalLabel={checkoutLabels.subtotalLabel}
        shippingLabel={checkoutLabels.shippingLabel}
        shippingValue={checkoutLabels.shippingValue}
        totalLabel={checkoutLabels.totalLabel}
        placeOrderLabel={checkoutLabels.placeOrderLabel}
        currency={checkoutLabels.currency}
      />
    </div>
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient"}
    background={layout.footer.background}
  />
</BaseLayout>
