---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { CheckoutPageContent } from "@mshorizon/ui";
import { getLayoutConfig, getNavLinks } from "../lib/pages";
import { resolveTarget } from "../lib/target";
import { deepTranslate } from "../lib/i18n";
import { deepResolveImages } from "../lib/images";
import type { BusinessProfile } from "@mshorizon/schema";

// Get business context from middleware
const { businessId, businessData, theme, currentLang, t: translations } = Astro.locals;

// Translate all "t:" prefixed strings in business data
const translatedData = deepTranslate(translations, businessData) as BusinessProfile;

// Resolve image paths (relative paths become /data/{businessId}/...)
const business = deepResolveImages(translatedData, businessId);

// Get layout configuration
const layout = getLayoutConfig(business);

// Get navigation links from pages object
const navLinksRaw = getNavLinks(business);

// Pre-resolve all navigation links on the server
const navLinks = navLinksRaw.map((link: any) => ({
  label: link.label,
  href: link.href || resolveTarget(link.target, business),
  ...(link.external ? { external: true } : {}),
}))

// Pre-resolve CTA on the server
const navCta = business.navigation?.cta
  ? {
      label: business.navigation.cta.label,
      href: resolveTarget(business.navigation.cta.target, business),
    }
  : undefined;

// Build page title
const pageTitle = `${translations["checkout.title"] || "Zamówienie"} | ${business.business.name}`;

// Pre-resolve footer links
const footerLinks =
  layout.footer.links?.map((link: any) => ({
    label: link.label,
    href: link.href || resolveTarget(link.target, business),
  })) || [];

// Pre-resolve footer columns
const footerColumns =
  layout.footer.columns?.map((col: any) => ({
    title: col.title,
    links:
      col.links?.map((link: any) => ({
        label: link.label,
        href: link.href || resolveTarget(link.target, business),
      })) || [],
  })) || [];

const payments = (business as any).payments || {};

// Translated labels — every string can be overridden per language in translations
const tt = (key: string, fallback: string) => translations[key] || fallback;
const checkoutLabels = {
  emptyCartMessage: tt("checkout.empty", "Twoje zamówienie jest puste"),
  continueShoppingLabel: tt("checkout.continueShopping", "Zobacz menu"),
  itemsSectionTitle: tt("checkout.items.title", "Twoje zamówienie"),
  editLabel: tt("checkout.items.edit", "Zmień"),
  removeItemLabel: tt("checkout.items.remove", "Usuń pozycję"),
  fulfillmentSectionTitle: tt("checkout.fulfillment.title", "Sposób realizacji"),
  contactSectionTitle: tt("checkout.contact.title", "Dane kontaktowe"),
  emailLabel: tt("checkout.contact.email", "Email"),
  emailPlaceholder: tt("checkout.contact.emailPlaceholder", "twoj@email.com"),
  phoneLabel: tt("checkout.contact.phone", "Telefon"),
  phonePlaceholder: tt("checkout.contact.phonePlaceholder", "+48 123 456 789"),
  firstNameLabel: tt("checkout.contact.firstName", "Imię"),
  firstNamePlaceholder: tt("checkout.contact.firstNamePlaceholder", "Jan"),
  lastNameLabel: tt("checkout.contact.lastName", "Nazwisko"),
  lastNamePlaceholder: tt("checkout.contact.lastNamePlaceholder", "Kowalski"),
  shippingSectionTitle: tt("checkout.shipping.title", "Adres dostawy"),
  addressLabel: tt("checkout.shipping.address", "Adres"),
  addressPlaceholder: tt("checkout.shipping.addressPlaceholder", "ul. Przykładowa 12/3"),
  cityLabel: tt("checkout.shipping.city", "Miasto"),
  cityPlaceholder: tt("checkout.shipping.cityPlaceholder", "Warszawa"),
  postalCodeLabel: tt("checkout.shipping.postalCode", "Kod pocztowy"),
  postalCodePlaceholder: tt("checkout.shipping.postalCodePlaceholder", "00-001"),
  pickupTimeLabel: tt("checkout.pickup.title", "Godzina odbioru"),
  pickupTimeOptionalLabel: tt("checkout.pickup.optional", "Godzina (opcjonalnie)"),
  pickupTimeHint: tt("checkout.pickup.hint", "Zostaw puste, aby odebrać najszybciej jak to możliwe."),
  tableNumberLabel: tt("checkout.dineIn.table", "Numer stolika"),
  tableNumberPlaceholder: tt("checkout.dineIn.tablePlaceholder", "np. 5"),
  paymentSectionTitle: tt("checkout.payment.title", "Płatność"),
  notesLabel: tt("checkout.notes.title", "Uwagi do zamówienia (opcjonalnie)"),
  notesPlaceholder: tt("checkout.notes.placeholder", "np. bez cebuli, dzwonek nie działa..."),
  orderSummaryTitle: tt("checkout.summary.title", "Podsumowanie"),
  subtotalLabel: tt("checkout.summary.subtotal", "Wartość zamówienia"),
  shippingLabel: tt("checkout.summary.shipping", "Dostawa"),
  shippingValue: tt("checkout.summary.shippingValue", "Za darmo"),
  totalLabel: tt("checkout.summary.total", "Razem"),
  placeOrderLabel: tt("checkout.placeOrder", "Złóż zamówienie"),
  processingLabel: tt("checkout.processing", "Przetwarzanie..."),
  minOrderLabel: tt("checkout.minOrder", "Minimalna wartość zamówienia"),
  submitNoteOnline: tt("checkout.note.online", "Po akceptacji przez restaurację otrzymasz link do płatności — na tej stronie i e-mailem."),
  submitNoteOffline: tt("checkout.note.offline", "Zapłacisz przy odbiorze zamówienia."),
  errorContactMessage: tt("checkout.error.contact", "Wypełnij dane kontaktowe"),
  errorAddressMessage: tt("checkout.error.address", "Uzupełnij adres dostawy"),
  errorTableMessage: tt("checkout.error.table", "Podaj numer stolika"),
  errorSubmitMessage: tt("checkout.error.submit", "Nie udało się złożyć zamówienia"),
  currency: tt("currency", "zł"),
};

const fulfillmentLabels = {
  delivery: tt("checkout.fulfillment.delivery", "Dostawa"),
  pickup: tt("checkout.fulfillment.pickup", "Odbiór osobisty"),
  dine_in: tt("checkout.fulfillment.dineIn", "W lokalu"),
};

const paymentMethodLabels = {
  online: tt("checkout.payment.online", "Płatność online (BLIK / karta)"),
  cash: tt("checkout.payment.cash", "Gotówka przy odbiorze"),
  card_on_site: tt("checkout.payment.cardOnSite", "Karta przy odbiorze"),
};

// Only offer "online" when Stripe is actually configured for this business.
const configuredMethods: string[] = payments.paymentMethods?.length
  ? payments.paymentMethods
  : ["cash"];
const paymentMethods = configuredMethods.filter(
  (m) => m !== "online" || !!payments.stripeSecretKey
);
---

<BaseLayout title={pageTitle} theme={theme} favicon={business.business.assets?.favicon} lang={currentLang}>
  <Navbar
    logo={layout.navbar.logoText || business.business.name}
    logoSubtext={layout.navbar.logoSubtext}
    hideLogoIcon={layout.navbar.hideLogoIcon}
    links={navLinks}
    cta={navCta}
    variant={layout.navbar.variant as "standard" | "centered"}
    showCart={true}
    hideBorderOnTop={layout.navbar.hideBorderOnTop}
    hideCta={layout.navbar.hideCta}
    showSocials={layout.navbar.showSocials}
    showAvailability={layout.navbar.showAvailability}
    showAddress={layout.navbar.showAddress}
    showAdditionalInfo={layout.navbar.showAdditionalInfo}
  />
  <main class="flex-1" data-nav-offset style="padding-top: var(--main-nav-offset, 64px)">
    <div class="py-8 lg:py-12">
      <div class="container mx-auto mb-spacing-lg">
        <h1 class="text-3xl lg:text-4xl font-heading font-semibold text-foreground">
          {translations["checkout.title"] || "Zamówienie"}
        </h1>
      </div>
      <CheckoutPageContent
        client:load
        businessId={businessId}
        {...checkoutLabels}
        fulfillmentTypes={payments.fulfillmentTypes || ["pickup"]}
        fulfillmentLabels={fulfillmentLabels}
        paymentMethods={paymentMethods as ("online" | "cash" | "card_on_site")[]}
        paymentMethodLabels={paymentMethodLabels}
        deliveryFee={payments.deliveryFee || 0}
        minOrderValue={payments.minOrderValue || 0}
      />
    </div>
  </main>
  <Footer
    businessName={business.business.name}
    footerName={layout.footer.name}
    footerLogoIcon={business.business.assets?.footerIcon}
    links={footerLinks}
    columns={footerColumns}
    copyright={layout.footer.copyright}
    tagline={layout.footer.tagline}
    flag={layout.footer.flag}
    findUsTitle={layout.footer.findUsTitle}
    hoursTitle={layout.footer.hoursTitle}
    hours={layout.footer.hours}
    signature={layout.footer.signature}
    currentLanguage={currentLang}
    variant={layout.footer.variant as "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns"}
    background={layout.footer.background}
    contact={business.business.contact}
  />
</BaseLayout>
