---
import { Navbar, Footer, Card, CardContent, Button } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBusinessContext } from "../lib/business";

const { businessId, businessData, theme, t, currentLang, allBusinesses } = getBusinessContext(Astro.request);
const { name, navigation } = businessData;
---

<BaseLayout title={`${t.about.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links.map((link: any, i: number) => ({
      ...link,
      label: [t.nav.home, t.nav.services, t.nav.about, t.nav.contact][i] || link.label
    }))}
    cta={{ ...navigation.cta, label: t.nav.cta }}
    currentLanguage={currentLang}
    businesses={allBusinesses}
    currentBusinessId={businessId}
  />
  <main class="flex-1 bg-background py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold text-foreground mb-8 text-center">{t.about.title}</h1>

      <div class="space-y-12">
        {t.about.story && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-4">{t.about.story.title}</h2>
            <p class="text-muted leading-relaxed">{t.about.story.content}</p>
          </section>
        )}

        {t.about.stats && t.about.stats.length > 0 && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-6">{t.about.whyChooseUs}</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {t.about.stats.map((stat: any) => (
                <Card className="text-center hover:shadow-lg transition-shadow">
                  <CardContent className="pt-6">
                    <div class="text-4xl font-bold text-primary mb-2">{stat.value}</div>
                    <p class="text-muted">{stat.label}</p>
                  </CardContent>
                </Card>
              ))}
            </div>
          </section>
        )}

        {t.about.commitment && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-4">{t.about.commitment.title}</h2>
            <p class="text-muted leading-relaxed mb-6">{t.about.commitment.content}</p>
            <Button asChild size="lg">
              <a href="/contact">{t.about.cta}</a>
            </Button>
          </section>
        )}
      </div>
    </div>
  </main>
  <Footer
    businessName={name}
    links={[
      { label: t.footer.privacy, href: "/privacy" },
      { label: t.footer.terms, href: "/terms" }
    ]}
    copyright={t.footer.copyright}
  />
</BaseLayout>
