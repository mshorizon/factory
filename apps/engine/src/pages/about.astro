---
import { Navbar, Footer, Card, CardContent, Button } from "@mshorizon/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { businessData, theme } from "../lib/business";

const { name, navigation, sections } = businessData;
const { about, footer } = sections;
---

<BaseLayout title={`${about.title} | ${name}`} theme={theme}>
  <Navbar
    client:load
    logo={name}
    links={navigation.links}
    cta={navigation.cta}
  />
  <main class="bg-background py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold text-foreground mb-8 text-center">{about.title}</h1>

      <div class="space-y-12">
        {about.story && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-4">{about.story.title}</h2>
            <p class="text-muted leading-relaxed">{about.story.content}</p>
          </section>
        )}

        {about.stats && about.stats.length > 0 && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-6">Why Choose Us</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {about.stats.map((stat: any) => (
                <Card className="text-center hover:shadow-lg transition-shadow">
                  <CardContent className="pt-6">
                    <div class="text-4xl font-bold text-primary mb-2">{stat.value}</div>
                    <p class="text-muted">{stat.label}</p>
                  </CardContent>
                </Card>
              ))}
            </div>
          </section>
        )}

        {about.commitment && (
          <section>
            <h2 class="text-2xl font-bold text-foreground mb-4">{about.commitment.title}</h2>
            <p class="text-muted leading-relaxed mb-6">{about.commitment.content}</p>
            {about.cta && (
              <Button asChild size="lg">
                <a href={about.cta.href}>{about.cta.label}</a>
              </Button>
            )}
          </section>
        )}
      </div>
    </div>
  </main>
  <Footer
    businessName={name}
    links={footer?.links}
    copyright={footer?.copyright}
  />
</BaseLayout>
