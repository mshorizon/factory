---
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { getSectionVariant } from "../lib/pages";
import HeroSection from "./sections/HeroSection.astro";
import ServicesSection from "./sections/ServicesSection.astro";
import CategoriesSection from "./sections/CategoriesSection.astro";
import AboutSection from "./sections/AboutSection.astro";
import AboutSummarySection from "./sections/AboutSummarySection.astro";
import MissionSection from "./sections/MissionSection.astro";
import ContactSection from "./sections/ContactSection.astro";
import ShopSection from "./sections/ShopSection.astro";
import ProcessSection from "./sections/ProcessSection.astro";
import ServiceAreaSection from "./sections/ServiceAreaSection.astro";
import TrustBarSection from "./sections/TrustBarSection.astro";
import GalleryBASection from "./sections/GalleryBASection.astro";
import GallerySection from "./sections/GallerySection.astro";
import TestimonialsSection from "./sections/TestimonialsSection.astro";
import FAQSection from "./sections/FAQSection.astro";
import FeaturesSection from "./sections/FeaturesSection.astro";
import CTABannerSection from "./sections/CTABannerSection.astro";
import BlogSection from "./sections/BlogSection.astro";
import BlogStandaloneSection from "./sections/BlogStandaloneSection.astro";
import MapSection from "./sections/MapSection.astro";
import BookingSection from "./sections/BookingSection.astro";
import PricingSection from "./sections/PricingSection.astro";
import ProjectSection from "./sections/ProjectSection.astro";
import ComparisonSection from "./sections/ComparisonSection.astro";
import TeamSection from "./sections/TeamSection.astro";
import EventsSection from "./sections/EventsSection.astro";
import FilesSection from "./sections/FilesSection.astro";

interface Props {
  sections: Section[];
  business: BusinessProfile;
  isHomePage?: boolean;
}

const { sections, business, isHomePage = false } = Astro.props;
const majorTheme = (business as any).theme?.majorTheme;
const badgeVariant = (business as any).theme?.badgeVariant || "accent";

// Map section types to components
const sectionComponents: Record<string, any> = {
  hero: HeroSection,
  services: ServicesSection,
  categories: CategoriesSection,
  about: AboutSection,
  "about-summary": AboutSummarySection,
  mission: MissionSection,
  contact: ContactSection,
  shop: ShopSection,
  process: ProcessSection,
  serviceArea: ServiceAreaSection,
  trustBar: TrustBarSection,
  galleryBA: GalleryBASection,
  gallery: GallerySection,
  testimonials: TestimonialsSection,
  faq: FAQSection,
  features: FeaturesSection,
  ctaBanner: CTABannerSection,
  blog: BlogSection,
  "blog-standalone": BlogStandaloneSection,
  map: MapSection,
  booking: BookingSection,
  pricing: PricingSection,
  project: ProjectSection,
  comparison: ComparisonSection,
  team: TeamSection,
  events: EventsSection,
  files: FilesSection,
};

// Map background prop to CSS class
function getBgClass(bg?: string): string {
  if (bg === "dark") return "section-bg-dark";
  if (bg === "dark-padded") return "section-bg-dark-padded";
  if (bg === "light-padded") return "section-bg-light-padded";
  if (bg === "gradient") return "section-bg-gradient";
  if (bg === "primary") return "section-bg-primary";
  return "";
}
---

{sections.map((section, index) => {
  // Resolve ref sections by looking up sharedSections
  const resolvedSection = section.type === 'ref'
    ? (business as any).sharedSections?.[section.sectionId as string]
    : section;
  if (!resolvedSection) return null;

  const Component = sectionComponents[resolvedSection.type];
  if (!Component) return null;
  const bgClass = getBgClass(resolvedSection.background);

  // Inject majorTheme-resolved variant so section components get the right variant
  const sectionWithVariant = {
    ...resolvedSection,
    variant: getSectionVariant(resolvedSection, majorTheme),
  };

  // Only pass business prop to sections that need it
  const needsBusiness = ['services', 'shop', 'map', 'testimonials', 'booking', 'contact'].includes(resolvedSection.type);
  const props = needsBusiness ? { section: sectionWithVariant, business, isHomePage, badgeVariant } : { section: sectionWithVariant, isHomePage, badgeVariant };

  const firstSectionClass = index === 0 && !isHomePage ? "pt-[120px]" : "";
  return <div data-section-index={index} data-section-type={resolvedSection.type} id={`${resolvedSection.type}-${index}`} class={[bgClass, firstSectionClass].filter(Boolean).join(" ")}><Component {...props} /></div>;
})}
