---
import { getCommentsByBlogId } from "@mshorizon/db";
import { CommentForm } from "./CommentForm";

interface Props {
  blogId: number;
}

const { blogId } = Astro.props;
const { currentLang } = Astro.locals;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// Fetch approved comments only
const comments = await getCommentsByBlogId(blogId, true);
---

<div class="space-y-spacing-2xl">
  <div>
    <h2 class="text-2xl font-bold text-foreground uppercase mb-spacing-xl">
      Komentarze ({comments.length})
    </h2>

    {comments.length > 0 ? (
      <div class="space-y-spacing-xl">
        {comments.map((comment) => {
          const date = new Date(comment.createdAt).toLocaleDateString(currentLang, {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          });

          // Generate avatar with first letter of name
          const initial = comment.authorName.charAt(0).toUpperCase();

          return (
            <div class="flex gap-spacing-lg p-spacing-lg bg-card rounded-radius border border-border">
              <!-- Avatar -->
              <div class="flex-shrink-0">
                <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center text-textOnPrimary font-bold">
                  {initial}
                </div>
              </div>

              <!-- Comment Content -->
              <div class="flex-1">
                <div class="flex items-center gap-spacing-sm mb-spacing-xs">
                  <span class="font-semibold text-foreground">{comment.authorName}</span>
                  <span class="text-xs text-muted">•</span>
                  <time class="text-xs text-muted" datetime={comment.createdAt.toISOString()}>
                    {date}
                  </time>
                </div>
                <p class="text-foreground leading-relaxed whitespace-pre-wrap">{comment.content}</p>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="text-muted py-spacing-xl">
        Brak komentarzy. Bądź pierwszą osobą, która skomentuje!
      </p>
    )}
  </div>

  <!-- Comment Form -->
  <div class="border-t border-border pt-spacing-2xl">
    <h3 class="text-xl font-bold text-foreground uppercase mb-spacing-lg">
      Dodaj komentarz
    </h3>
    <CommentForm client:load blogId={blogId} turnstileSiteKey={turnstileSiteKey} />
  </div>
</div>
