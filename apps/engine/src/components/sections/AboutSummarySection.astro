---
import type { Section } from "@mshorizon/schema";
import { AboutSummary, AboutSummaryStats } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant: themeBadgeVariant } = Astro.props;
const header = getSectionHeader(section);

const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.target ? resolveTarget(section.cta.target) : "/about";

// Section-level badgeVariant overrides theme-level
const sectionBadgeVariant = (section as any).badgeVariant || themeBadgeVariant || "accent";
const sectionBadgeColor = (section as any).badgeColor;
const sectionDescriptionColor = (section as any).descriptionColor;
const sectionCtaColor = (section as any).ctaColor;
const sectionStatsInverted = (section as any).statsInverted;
const sectionImagePaddingY = (section as any).imagePaddingY;
const sectionCtaPaddingBottom = (section as any).ctaPaddingBottom;

// Use section.description if available, fall back to header.subtitle
const description = (section as any).description || header.subtitle;

// Resolve background: treat "dark-padded" as "dark" for component internal logic
const componentBackground = section.background === "dark-padded" ? "dark" : section.background;
---

<section class="overflow-hidden">
  <div class="container mx-auto">
    <AboutSummary
      client:visible
      badge={header.badge}
      title={header.title}
      description={description}
      image={section.image}
      experienceYears={(section as any).experienceYears}
      experienceLabel={(section as any).experienceLabel}
      cta={ctaLabel}
      ctaHref={ctaHref}
      stats={section.stats}
      background={componentBackground}
      hideDots={section.hideDots}
      badgeVariant={sectionBadgeVariant as any}
      badgeColor={sectionBadgeColor}
      descriptionColor={sectionDescriptionColor}
      ctaColor={sectionCtaColor}
      statsInverted={sectionStatsInverted}
      imagePaddingY={sectionImagePaddingY}
      ctaPaddingBottom={sectionCtaPaddingBottom}
    />
  </div>
</section>
{sectionStatsInverted && section.stats && section.stats.length > 0 && (
  <div data-stats-breakout class={`mt-spacing-md pt-spacing-3xl pb-spacing-3xl`}>
    <div class="container mx-auto">
      <AboutSummaryStats client:visible stats={section.stats} />
    </div>
  </div>
)}

<style>
  :global([data-stats-breakout]) {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  :global([data-stats-breakout].stats-revealed) {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  const panels = document.querySelectorAll('[data-stats-breakout]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('stats-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { rootMargin: '-50px' });
  panels.forEach(el => observer.observe(el));
</script>
