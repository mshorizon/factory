---
import type { Section } from "@mshorizon/schema";
import { CategoriesCarousel, CategoriesFeatured, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const items = section.items || [];
const header = getSectionHeader(section);
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    {variant === "featured" ? (
      <CategoriesFeatured items={items} exploreLabel={section.exploreLabel} />
    ) : (
      <CategoriesCarousel items={items} />
    )}
  </div>
</section>
