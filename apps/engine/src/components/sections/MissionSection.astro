---
import type { Section } from "@mshorizon/schema";
import { MissionContent } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const items = (section.items || []) as Array<{ title?: string; label?: string }>;
---

<section class="overflow-hidden">
  <div class="container mx-auto">
    <MissionContent
      client:visible
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      items={items}
      image={section.image}
    />
  </div>
</section>
