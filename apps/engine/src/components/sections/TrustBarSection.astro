---
import type { SectionV15 } from "@mshorizon/schema";
import { TrustBar, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
---

<section class="bg-background py-16">
  <div class="container mx-auto px-4">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <TrustBar
      client:visible
      trustSignals={section.trustSignals}
      googleRating={section.googleRating}
    />
  </div>
</section>
