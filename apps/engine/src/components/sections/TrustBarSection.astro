---
import type { Section } from "@mshorizon/schema";
import { TrustBar, TrustBarLogos, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const header = getSectionHeader(section);
const variant = section.variant;
---

<section class={`py-${isHomePage ? "spacing-3xl" : "spacing-2xl"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      badgeVariant={badgeVariant as any}
      className="[&_h2]:text-sm [&_h2]:font-medium [&_h2]:text-muted mb-spacing-xl"
    />
    {variant === "logos" ? (
      <TrustBarLogos
        client:visible
        clientLogos={section.clientLogos || []}
      />
    ) : (
      <TrustBar
        client:visible
        trustSignals={section.trustSignals}
        googleRating={section.googleRating}
      />
    )}
  </div>
</section>
