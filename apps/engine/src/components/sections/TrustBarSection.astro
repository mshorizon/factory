---
import type { Section } from "@mshorizon/schema";
import { TrustBar, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const header = getSectionHeader(section);
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <TrustBar
      client:visible
      trustSignals={section.trustSignals}
      googleRating={section.googleRating}
    />
  </div>
</section>
