---
import type { SectionV15 } from "@mshorizon/schema";
import { BlogGrid, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const posts = section.blogPosts || [];
const ctaLabel = section.ctaLabel;
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      layout="split"
      align="left"
    />
    <BlogGrid client:visible posts={posts} ctaLabel={ctaLabel} />
  </div>
</section>
