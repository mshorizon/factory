---
import type { Section } from "@mshorizon/schema";
import { BlogGrid, BlogCards, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";
import { getLatestBlogs, getBlogsBySlugs } from "@mshorizon/db";
import type { BlogPost } from "@mshorizon/ui/sections/blog/types";
import { t } from "../../lib/i18n";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const { site, currentLang, t: translations } = Astro.locals;

const header = getSectionHeader(section);
const ctaLabel = section.ctaLabel || t(translations, "blog.readMore", "Czytaj więcej");
const isCards = section.variant === "cards";
const isCardsLight = section.variant === "cards-light";

const blogSlugs = (section as any).blogSlugs as string[] | undefined;

let blogs: Awaited<ReturnType<typeof getLatestBlogs>> = [];
if (site) {
  if (blogSlugs && blogSlugs.length > 0) {
    // Render only the explicitly listed blogs (includes standalone), preserving order
    blogs = await getBlogsBySlugs(site.id, blogSlugs, currentLang);
  } else {
    // Fetch latest blogs — cards variants show 3, default shows 2
    const postCount = isCards || isCardsLight ? 3 : 2;
    blogs = await getLatestBlogs(site.id, postCount, currentLang);
    if (blogs.length === 0) {
      blogs = await getLatestBlogs(site.id, postCount);
    }
  }
}

// Transform blogs to BlogPost[] format
const posts: BlogPost[] = blogs.map((blog) => ({
  title: blog.title,
  description: blog.description || "",
  image: blog.image || undefined,
  date: blog.publishedAt ? new Date(blog.publishedAt).toLocaleDateString(currentLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }) : undefined,
  href: `/blog/${blog.slug}`,
}));
---

{posts.length > 0 && (
  <section class={`${isHomePage ? "pb-spacing-section" : "py-spacing-section-sm"}`}>
    <div class="container mx-auto px-spacing-container">
      {isCards || isCardsLight ? (
        <>
          <SectionHeader
            badge={header.badge}
            title={header.title}
            subtitle={header.subtitle}
            layout="stacked"
            align="center"
            background={section.background}
            badgeVariant={badgeVariant as any}
          />
          <BlogCards client:visible posts={posts} ctaLabel={ctaLabel} withCard={isCardsLight} />
        </>
      ) : (
        <>
          <SectionHeader
            badge={header.badge}
            title={header.title}
            subtitle={header.subtitle}
            layout="split"
            align="left"
            background={section.background}
            badgeVariant={badgeVariant as any}
          />
          <BlogGrid client:visible posts={posts} ctaLabel={ctaLabel} />
        </>
      )}
    </div>
  </section>
)}
