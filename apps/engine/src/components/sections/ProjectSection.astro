---
import type { Section } from "@mshorizon/schema";
import { ProjectGrid, ProjectCarousel, ProjectHorizontal, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const projects = (section.projects || []).map((p: any) => ({
  ...p,
  metrics: p.metrics || (p.metric ? [p.metric + (p.metricLabel ? ' ' + p.metricLabel : '')] : undefined),
}));
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class={variant === "carousel" ? "container mx-auto" : "container mx-auto"}>
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      background={section.background}
    />
    {variant === "carousel" ? (
      <ProjectCarousel client:load projects={projects} />
    ) : variant === "horizontal" ? (
      <ProjectHorizontal client:visible projects={projects} />
    ) : (
      <ProjectGrid client:visible projects={projects} />
    )}
  </div>
</section>
