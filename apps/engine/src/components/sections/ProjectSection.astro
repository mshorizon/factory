---
import type { Section } from "@mshorizon/schema";
import { ProjectGrid, ProjectCarousel, ProjectHorizontal, ProjectShowcase, ProjectCaseStudy, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const projects = (section.projects || []).map((p: any) => ({
  ...p,
  metrics: p.metrics || (p.metric ? [p.metric + (p.metricLabel ? ' ' + p.metricLabel : '')] : undefined),
}));
---

<section>
  <div class={variant === "carousel" ? "container mx-auto" : "container mx-auto"}>
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    {variant === "caseStudy" ? (
      <ProjectCaseStudy
        client:visible
        quote={section.quote as any}
        image={section.image}
        imageDescription={section.imageDescription as any}
        items={(section.items as any) || []}
      />
    ) : variant === "showcase" ? (
      <ProjectShowcase client:visible projects={projects} />
    ) : variant === "carousel" ? (
      <ProjectCarousel client:load projects={projects} />
    ) : variant === "horizontal" ? (
      <ProjectHorizontal client:visible projects={projects} />
    ) : (
      <ProjectGrid client:visible projects={projects} columns={(section as any).gridColumns} footerCta={(section as any).footerCta} />
    )}
  </div>
</section>
