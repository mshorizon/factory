---
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { GoogleMap } from "@mshorizon/ui";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business: BusinessProfile;
  badgeVariant?: string;
}

const { section, business, isHomePage = false, badgeVariant: themeBadgeVariant } = Astro.props;
const sectionBadgeVariant = (section as any).badgeVariant || themeBadgeVariant || "accent";

// Get location from business contact
const contact = business.business.contact;
const location = contact?.location;

if (!location) {
  console.warn("Map section requires location data in business.contact.location");
}

const businessName = (business.business as any).name;
const address = contact?.address;
const openInMapsLabel = (section as any).openInMapsLabel;
const directionsLabel = (section as any).directionsLabel;
---

{location && (
  <section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <GoogleMap
      client:load
      latitude={location.latitude}
      longitude={location.longitude}
      width={1136}
      height={500}
      zoom={15}
      badge={section.header?.badge}
      title={section.header?.title}
      subtitle={section.header?.subtitle}
      badgeVariant={sectionBadgeVariant as any}
      badgeLayout={(section as any).badgeLayout}
      businessName={businessName}
      address={address}
      openInMapsLabel={openInMapsLabel}
      directionsLabel={directionsLabel}
    />
  </section>
)}
