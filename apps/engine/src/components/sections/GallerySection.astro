---
import type { Section } from "@mshorizon/schema";
import { GalleryGrid, GalleryShowcase, GalleryMosaic, SectionHeader, buttonVariants, cn } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const items = section.items || [];
const exploreHref = section.cta?.target ? resolveTarget(section.cta.target) : undefined;
const exploreLabel = section.cta?.label || section.exploreLabel;

// Optional ghost button below the gallery. The full text is shown uppercase;
// the `highlight` substring within it (e.g. a social handle) is colored.
const socialCta = section.socialCta;
const socialParts = socialCta?.text && socialCta.highlight
  ? socialCta.text.split(socialCta.highlight)
  : undefined;
---

<section>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    {variant === "showcase" ? (
      <GalleryShowcase
        client:visible
        items={items}
        exploreLabel={exploreLabel}
        exploreHref={exploreHref}
      />
    ) : variant === "mosaic" ? (
      <GalleryMosaic client:visible items={items} />
    ) : (
      <GalleryGrid client:visible items={items} />
    )}
    {socialCta?.text && (
      <div class="mt-spacing-2xl flex justify-center">
        <a
          href={socialCta.href || "#"}
          target={socialCta.href?.startsWith("http") ? "_blank" : undefined}
          rel={socialCta.href?.startsWith("http") ? "noopener noreferrer" : undefined}
          class={cn(
            buttonVariants({ variant: "outline", size: "lg" }),
            // Gray, highly transparent border; white label that flips to black on a white fill.
            // Hover is gated to hover-capable devices so touch devices don't get the sticky
            // :hover that swallows the first tap (the "button needs a double tap" mobile bug);
            // `active:` gives touch users immediate press feedback on a single tap instead.
            "border-white/20 text-white [@media(hover:hover)]:hover:bg-white [@media(hover:hover)]:hover:text-black active:bg-white active:text-black uppercase tracking-wide h-auto min-h-12 w-full max-w-full whitespace-normal py-spacing-sm text-center sm:w-auto"
          )}
        >
          {socialParts ? (
            <span>
              {socialParts[0]}
              <span style={socialCta.highlightColor ? `color:${socialCta.highlightColor}` : undefined}>
                {socialCta.highlight}
              </span>
              {socialParts.slice(1).join(socialCta.highlight)}
            </span>
          ) : (
            <span>{socialCta.text}</span>
          )}
        </a>
      </div>
    )}
  </div>
</section>
