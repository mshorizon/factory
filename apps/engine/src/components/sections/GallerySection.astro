---
import type { Section } from "@mshorizon/schema";
import { GalleryGrid, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const items = section.items || [];
---

<section class="py-[120px]">
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <GalleryGrid client:visible items={items} />
  </div>
</section>
