---
import type { Section } from "@mshorizon/schema";
import { GalleryBA, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const header = getSectionHeader(section);
const pairs = section.pairs || [];
---

<section>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      badgeVariant={badgeVariant as any}
    />
    <GalleryBA client:visible pairs={pairs} />
  </div>
</section>
