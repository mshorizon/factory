---
import type { Section } from "@mshorizon/schema";
import { GalleryBA, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const pairs = section.pairs || [];
---

<section class="py-[120px]">
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <GalleryBA client:visible pairs={pairs} />
  </div>
</section>
