---
import type { SectionV15 } from "@mshorizon/schema";
import { ServiceArea, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const areas = section.areas || [];
const stats = section.stats || [];
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <ServiceArea client:visible areas={areas} stats={stats} />
  </div>
</section>
