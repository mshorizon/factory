---
import type { Section } from "@mshorizon/schema";
import { Badge } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";
import { SERVICE_AREA_DOTS } from "@mshorizon/ui";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const header = getSectionHeader(section);
const stats = section.stats || [];

// Get pre-calculated area data based on section configuration
const areaKey = section.area?.country && section.area?.region
  ? `${section.area.country}-${section.area.region}` as keyof typeof SERVICE_AREA_DOTS
  : 'polska-mazowsze' as const;

const areaData = SERVICE_AREA_DOTS[areaKey] || SERVICE_AREA_DOTS['polska-mazowsze'];
const { width, height, dots } = areaData;
---

<section class={`py-${isHomePage ? "spacing-section-sm" : "spacing-3xl"} overflow-hidden`}>
  <div class="container mx-auto">
    <div class="grid lg:grid-cols-2 gap-spacing-3xl items-center">
      {/* Content side */}
      <div style="max-width: 34rem;">
        {header.badge && (
          <div class="flex items-center gap-spacing-sm mb-spacing-lg">
            <span
              class="w-12 h-[2px]"
              style={`background-color: ${section.background === "dark" ? "var(--primary)" : "var(--primary-dark)"}`}
            ></span>
            <Badge
              variant="accent"
              data-field="header.badge"
              style={{ color: section.background === "dark" ? "var(--primary)" : "var(--primary-dark)" }}
            >
              {header.badge}
            </Badge>
          </div>
        )}
        {header.title && (
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-spacing-md font-heading" data-field="header.title">
            {header.title}
          </h2>
        )}
        {header.subtitle && (
          <p class="text-muted mb-spacing-2xl" data-field="header.subtitle">
            {header.subtitle}
          </p>
        )}
        {stats.length > 0 && (
          <div class="flex gap-spacing-3xl">
            {stats.map((stat: any, index: number) => (
              <div data-field={`stats.${index}`}>
                <div class="text-4xl md:text-5xl lg:text-6xl font-bold text-foreground mb-spacing-xs font-heading" data-field={`stats.${index}.value`}>
                  {stat.value}
                </div>
                <p class="text-sm text-muted" data-field={`stats.${index}.label`}>
                  {stat.label}
                </p>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* Poland map with dots */}
      <div class="relative flex items-center justify-center">
        <svg viewBox={`0 0 ${width} ${height}`} class="poland-map w-full max-w-[350px] md:max-w-[450px] lg:max-w-[500px] h-auto">
          {/* Render all dots - grey for country, yellow for region */}
          {dots.map((dot, i) => (
            <circle
              key={i}
              cx={dot.x}
              cy={dot.y}
              r="2.4"
              fill={dot.inRegion ? "var(--primary)" : "currentColor"}
              opacity={dot.inRegion ? "0.8" : "0.4"}
            />
          ))}
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .poland-map {
    color: var(--foreground);
  }
</style>
