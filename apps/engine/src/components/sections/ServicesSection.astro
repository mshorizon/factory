---
import type { Section } from "@mshorizon/schema";
import { ServicesGrid, ServicesList, ServicesImageGrid, ServicesDarkCards, SectionHeader, Button } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const items = section.items || [];
const header = getSectionHeader(section);
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      layout={variant === "darkCards" ? "split" : "center"}
      align={variant === "darkCards" ? "left" : "center"}
    />
    {variant === "list" ? (
      <ServicesList client:visible items={items} />
    ) : variant === "imageGrid" ? (
      <ServicesImageGrid client:visible items={items} />
    ) : variant === "darkCards" ? (
      <ServicesDarkCards client:visible items={items} />
    ) : (
      <ServicesGrid client:visible items={items} />
    )}
    {ctaLabel && (
      <div class={`mt-10 ${variant === "darkCards" ? "text-left" : "text-center"}`}>
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center gap-2 rounded-radius bg-primary text-on-primary px-8 py-3 text-base font-medium shadow hover:bg-primary/90 transition-all"
          data-field="cta"
        >
          {ctaLabel}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
