---
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { ServicesGrid, ServicesList, ServicesImageGrid, ServicesDarkCards, ServicesFeatured, ServicesAlternating, SectionHeader, Button } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business: BusinessProfile;
  badgeVariant?: string;
}

const { section, business, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);

// Use section.items if provided, otherwise fallback to business.data.services
const items = (section.items && section.items.length > 0)
  ? section.items
  : (business?.data?.services || []);

const header = getSectionHeader(section);
const headerLayout = header.layout || (variant === "darkCards" || variant === "imageGrid" ? "split" : undefined);
const headerAlign = headerLayout === "most-minimalistic" || variant === "darkCards" || variant === "imageGrid" ? "left" : "center";
const minimal = headerLayout === "most-minimalistic";
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);
---

<section class={
  minimal
    ? (isHomePage ? "pb-spacing-section" : "pb-spacing-section-sm")
    : (isHomePage ? "py-spacing-section" : "py-spacing-section-sm")
}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      layout={headerLayout as any}
      align={headerAlign as any}
      background={section.background}
      badgeVariant={badgeVariant as any}
      className={variant === "alternating" ? "[&_h2]:max-w-[700px] [&_h2]:mx-auto" : undefined}
    />
    {variant === "list" ? (
      <ServicesList client:visible items={items} />
    ) : variant === "imageGrid" ? (
      <ServicesImageGrid client:visible items={items} />
    ) : variant === "darkCards" ? (
      <ServicesDarkCards client:visible items={items} />
    ) : variant === "featured" ? (
      <ServicesFeatured client:visible items={items} />
    ) : variant === "alternating" ? (
      <ServicesAlternating client:visible items={items} />
    ) : (
      <ServicesGrid client:visible items={items} minimal={minimal} />
    )}
    {ctaLabel && (
      <div class={`mt-spacing-2xl ${headerAlign === "left" ? "text-left" : "text-center"}`}>
        <a
          href={ctaHref}
          class={`inline-flex items-center justify-center gap-spacing-xs bg-primary-light text-on-primary px-spacing-2xl py-3 text-base font-medium shadow hover:bg-primary-light/90 transition-all ${minimal ? "rounded-full" : "rounded-radius"}`}
          data-field="cta"
        >
          {ctaLabel}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
