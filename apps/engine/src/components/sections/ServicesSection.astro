---
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { ServicesGrid, ServicesList, ServicesImageGrid, ServicesDarkCards, SectionHeader, Button } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business: BusinessProfile;
}

const { section, business, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);

// Use section.items if provided, otherwise fallback to business.data.services
const items = (section.items && section.items.length > 0)
  ? section.items
  : (business?.data?.services || []);

const header = getSectionHeader(section);
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      layout={variant === "darkCards" || variant === "imageGrid" ? "split" : "center"}
      align={variant === "darkCards" || variant === "imageGrid" ? "left" : "center"}
      background={section.background}
    />
    {variant === "list" ? (
      <ServicesList client:visible items={items} />
    ) : variant === "imageGrid" ? (
      <ServicesImageGrid client:visible items={items} />
    ) : variant === "darkCards" ? (
      <ServicesDarkCards client:visible items={items} />
    ) : (
      <ServicesGrid client:visible items={items} />
    )}
    {ctaLabel && (
      <div class={`mt-spacing-2xl ${variant === "darkCards" || variant === "imageGrid" ? "text-left" : "text-center"}`}>
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center gap-spacing-xs rounded-radius bg-primary text-on-primary px-spacing-2xl py-3 text-base font-medium shadow hover:bg-primary/90 transition-all"
          data-field="cta"
        >
          {ctaLabel}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
