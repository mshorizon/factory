---
import type { Section } from "@mshorizon/schema";
import { ServicesGrid, ServicesList } from "@mshorizon/ui";
import { getSectionVariant } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const items = section.items || [];
---

<section class="bg-background py-16">
  <div class="container mx-auto px-4">
    {section.title && (
      <h1 class="text-4xl font-bold text-foreground mb-4 text-center">{section.title}</h1>
    )}
    {section.subtitle && (
      <p class="text-muted text-center mb-12 max-w-2xl mx-auto">
        {section.subtitle}
      </p>
    )}
    {variant === "list" ? (
      <ServicesList items={items} />
    ) : (
      <ServicesGrid items={items} />
    )}
  </div>
</section>
