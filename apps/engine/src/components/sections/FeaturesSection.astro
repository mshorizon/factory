---
import type { SectionV15 } from "@mshorizon/schema";
import { FeaturesGrid, Badge } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
import { resolveTarget } from "../../lib/target";

const rawItems = section.items || [];
const items = rawItems.map((item: any) => ({
  ...item,
  linkLabel: item.linkLabel,
  linkHref: item.linkHref || (item.linkTarget ? resolveTarget(item.linkTarget) : undefined),
}));
---

<section class="py-[120px]">
  <div class="container mx-auto">
    <div class="mb-12">
      {header.badge && (
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-0.5 bg-primary"></span>
          <Badge variant="accent" data-field="header.badge">
            {header.badge}
          </Badge>
        </div>
      )}
      <div class="grid md:grid-cols-2 gap-8 items-start">
        {header.title && (
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground font-heading" data-field="header.title">
            {header.title}
          </h2>
        )}
        {header.subtitle && (
          <p class="text-muted leading-relaxed" data-field="header.subtitle">
            {header.subtitle}
          </p>
        )}
      </div>
    </div>
    <FeaturesGrid client:visible items={items} />
  </div>
</section>
