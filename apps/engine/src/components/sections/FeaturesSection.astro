---
import type { Section } from "@mshorizon/schema";
import { FeaturesGrid, FeaturesCompact, FeaturesGradient, FeaturesIconTiles, FeaturesNumberedSplit, FeaturesChecklistSplit, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant: themeBadgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const sectionBadgeVariant = (section as any).badgeVariant || themeBadgeVariant || "accent";
import { resolveTarget } from "../../lib/target";

const rawItems = section.items || [];
const items = rawItems.map((item: any) => ({
  ...item,
  linkLabel: item.linkLabel,
  linkHref: item.linkHref || item.href || (item.linkTarget ? resolveTarget(item.linkTarget) : undefined),
}));
---

<section>
  <div class="container mx-auto">
    {variant === "checklist-split" ? (
      <FeaturesChecklistSplit
        client:visible
        items={items}
        title={header.title}
        secondaryTitle={(section as any).secondaryTitle}
        secondaryItems={(section as any).secondaryItems || []}
      />
    ) : variant === "numbered-split" ? (
      <FeaturesNumberedSplit
        client:visible
        items={items}
        badge={header.badge}
        title={header.title}
        background={section.background}
        image={section.image}
        imageBlend={(section as any).imageBlend}
        imageBorder={(section as any).imageBorder}
        imageDescription={(section as any).imageDescription}
        marker={(section as any).marker}
        imageShadow={(section as any).imageShadow}
      />
    ) : (
      <>
        <SectionHeader
          badge={header.badge}
          title={header.title}
          subtitle={header.subtitle}
          background={section.background}
          badgeVariant={sectionBadgeVariant as any}
        />
        {variant === "compact" ? (
          <FeaturesCompact client:visible items={items} />
        ) : variant === "gradient" ? (
          <FeaturesGradient client:visible items={items} />
        ) : variant === "icon-tiles" ? (
          <FeaturesIconTiles client:visible items={items} />
        ) : (
          <FeaturesGrid client:visible items={items} />
        )}
      </>
    )}
  </div>
</section>
