---
import type { Section } from "@mshorizon/schema";
import { CtaBannerDefault, CtaBannerTicker } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);

// Resolve CTA href from target
const ctaHref = section.cta?.target?.type === "phone"
  ? `tel:${section.cta.target.value || ""}`
  : section.cta?.target?.value
    ? `/${section.cta.target.value}`
    : "/contact";
---

{variant === "ticker" ? (
  <section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <CtaBannerTicker
      client:visible
      marqueeText={section.marqueeText || header.title}
    />
  </section>
) : (
  <section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <div class="container mx-auto">
      <CtaBannerDefault
        client:visible
        title={header.title}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
)}
