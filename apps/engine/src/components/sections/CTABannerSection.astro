---
import type { Section } from "@mshorizon/schema";
import { CtaBannerDefault, CtaBannerTicker, CtaBannerCard, CtaBannerAgency } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);

// Resolve CTA href from target
const ctaHref = section.cta?.target?.type === "phone"
  ? `tel:${section.cta.target.value || ""}`
  : section.cta?.target?.value
    ? `/${section.cta.target.value}`
    : "/contact";
---

{variant === "agency" ? (
  <CtaBannerAgency
    client:visible
    title={header.title}
    subtitle={header.subtitle}
    badge={header.badge}
    ctaLabel={section.cta?.label}
    ctaHref={ctaHref}
    secondaryCtaLabel={(section as any).secondaryCta?.label}
    secondaryCtaHref={(section as any).secondaryCta?.target?.value ? ((section as any).secondaryCta.target.type === "phone" ? `tel:${(section as any).secondaryCta.target.value}` : `/${(section as any).secondaryCta.target.value}`) : undefined}
    calendarTitle={(section as any).calendarTitle}
    calendarSubtitle={(section as any).calendarSubtitle}
    timeSlots={(section as any).timeSlots}
    trustLabels={(section as any).trustLabels}
  />
) : variant === "ticker" ? (
  <CtaBannerTicker
    client:visible
    marqueeText={section.marqueeText || header.title}
  />
) : variant === "card" ? (
  <section>
    <div class="container mx-auto">
      <CtaBannerCard
        client:visible
        title={header.title}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : (
  <section>
    <div class="container mx-auto">
      <CtaBannerDefault
        client:visible
        title={header.title}
        badge={header.badge}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
)}
