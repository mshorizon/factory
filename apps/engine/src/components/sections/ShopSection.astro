---
import { ShopGrid } from "@mshorizon/ui";
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section & {
    currency?: string;
    outOfStockLabel?: string;
    outOfStockCtaLabel?: string;
    outOfStockCtaHref?: string;
  };
  business?: BusinessProfile;
}

const { section, business } = Astro.props;

// Products come from section override or fall back to business data.products
const products = (section as any).products ?? business?.data?.products ?? [];

// Extract section header
const header = getSectionHeader(section);
---

<ShopGrid
  client:load
  header={header}
  products={products}
  ctaLabel={section.ctaLabel}
  currency={section.currency || "zł"}
  outOfStockLabel={section.outOfStockLabel || "Out of Stock"}
  outOfStockCtaLabel={section.outOfStockCtaLabel}
  outOfStockCtaHref={section.outOfStockCtaHref}
/>
