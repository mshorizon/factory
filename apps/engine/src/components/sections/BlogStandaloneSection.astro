---
import type { Section } from "@mshorizon/schema";
import { getBlogBySlug } from "@mshorizon/db";
import { t } from "../../lib/i18n";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const { site, currentLang, t: translations } = Astro.locals;

const blogSlug = (section as any).blogSlug as string | undefined;
const sidebarContact = section.sidebarContact;

let blog = null;
if (site && blogSlug) {
  blog = await getBlogBySlug(site.id, blogSlug, currentLang);
  if (!blog) {
    blog = await getBlogBySlug(site.id, blogSlug);
  }
}

const ctaHref = sidebarContact?.cta?.target?.type === "email"
  ? `mailto:${sidebarContact.cta.target.value}`
  : sidebarContact?.cta?.target?.type === "phone"
  ? `tel:${sidebarContact.cta.target.value}`
  : sidebarContact?.cta?.target?.value ?? "#";
---

{blog && (
  <section class="py-spacing-section-sm">
    <div class="container mx-auto px-spacing-container">
      <div class={sidebarContact ? "flex flex-col lg:flex-row gap-spacing-2xl lg:gap-spacing-3xl items-start" : "max-w-3xl mx-auto"}>

        <!-- Main content -->
        <div class={sidebarContact ? "min-w-0 flex-1" : ""}>

          <!-- Go back link -->
          <a data-reveal data-reveal-delay="0" href="/" class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-foreground transition-colors mb-spacing-xl">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
            {t(translations, "blog.back", "Go back")}
          </a>

          <!-- Category + Date -->
          {(blog.category || blog.publishedAt) && (
            <div data-reveal data-reveal-delay="0" class="flex items-center gap-spacing-sm mb-spacing-lg">
              {blog.category && (
                <span class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                  {blog.category}
                </span>
              )}
            </div>
          )}

          <!-- Title -->
          <h1 data-reveal data-reveal-delay="100" class="text-4xl md:text-5xl font-heading text-foreground mb-spacing-lg">
            {blog.title}
          </h1>

          <!-- Description -->
          {blog.description && (
            <p data-reveal data-reveal-delay="400" class="text-lg text-muted leading-relaxed mb-spacing-2xl">
              {blog.description}
            </p>
          )}

          <!-- Cover Image -->
          {blog.image && (
            <div data-reveal data-reveal-delay="650" class="mb-spacing-2xl">
              <div class="relative w-full rounded-lg overflow-hidden">
                <img
                  src={blog.image}
                  alt={blog.title}
                  class="w-full h-auto max-h-[400px] object-cover"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          )}

          <!-- Content -->
          <div data-reveal data-reveal-delay="1000" class="prose prose-lg prose-headings:uppercase prose-headings:font-bold prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl prose-p:text-foreground prose-strong:text-foreground prose-ul:text-foreground prose-li:text-foreground prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
            <Fragment set:html={blog.content} />
          </div>
        </div>

        <!-- Sidebar contact card -->
        {sidebarContact && (
          <aside data-reveal data-reveal-delay="900" class="w-full max-w-[368px] lg:w-[368px] shrink-0 lg:sticky lg:top-24">
            <div class="bg-card rounded-2xl p-spacing-md pb-spacing-lg flex flex-col items-start text-left gap-spacing-md">

              {sidebarContact.image && (
                <div class="w-full max-w-[336px] aspect-[336/256] rounded-lg overflow-hidden shrink-0">
                  <img
                    src={sidebarContact.image}
                    alt={sidebarContact.name ?? ""}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              {(sidebarContact.name || sidebarContact.role) && (
                <p class="text-[20px] text-foreground leading-snug">
                  {[sidebarContact.name, sidebarContact.role].filter(Boolean).join(", ")}
                </p>
              )}

              {(sidebarContact.phone || sidebarContact.email) && (
                <div class="w-full flex flex-col gap-spacing-sm">
                  {sidebarContact.phone && (
                    <a href={`tel:${sidebarContact.phone}`} class="flex items-center gap-spacing-sm text-base text-foreground hover:text-primary transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0 text-primary-light"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.05-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.24 1.05l-2.21 2.17z"/></svg>
                      <span>{sidebarContact.phone}</span>
                    </a>
                  )}
                  {sidebarContact.email && (
                    <a href={`mailto:${sidebarContact.email}`} class="flex items-center gap-spacing-sm text-base text-foreground hover:text-primary transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="shrink-0 text-primary-light"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.24-8 5-8-5V6l8 5 8-5z"/></svg>
                      <span class="break-all">{sidebarContact.email}</span>
                    </a>
                  )}
                </div>
              )}

              {sidebarContact.cta && (
                <a
                  href={ctaHref}
                  class="mt-spacing-xs inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline transition-colors"
                >
                  {sidebarContact.cta.label}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              )}

            </div>
          </aside>
        )}

      </div>
    </div>
  </section>
)}

<style>
  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.75rem;
  }

  .prose :global(strong) {
    font-weight: var(--fw-semibold, 600);
  }

  .prose :global(a) {
    transition: all 0.2s ease;
  }

  .prose :global(img) {
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: var(--radius);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--muted-foreground);
    margin: 2rem 0;
  }

  .prose :global(code) {
    background: var(--secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--secondary);
    padding: 1.5rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
