---
import type { Section } from "@mshorizon/schema";
import { getBlogBySlug } from "@mshorizon/db";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const { site, currentLang } = Astro.locals;

const blogSlug = (section as any).blogSlug as string | undefined;
const sidebarContact = section.sidebarContact;

let blog = null;
if (site && blogSlug) {
  blog = await getBlogBySlug(site.id, blogSlug, currentLang);
  if (!blog) {
    blog = await getBlogBySlug(site.id, blogSlug);
  }
}

const ctaHref = sidebarContact?.cta?.target?.type === "email"
  ? `mailto:${sidebarContact.cta.target.value}`
  : sidebarContact?.cta?.target?.type === "phone"
  ? `tel:${sidebarContact.cta.target.value}`
  : sidebarContact?.cta?.target?.value ?? "#";
---

{blog && (
  <section class="pb-spacing-section-sm">
    <div class="container mx-auto px-spacing-container">
      <div class={sidebarContact ? "flex flex-col lg:flex-row gap-spacing-2xl lg:gap-spacing-3xl items-start" : "max-w-3xl mx-auto"}>

        <!-- Main content -->
        <div class={sidebarContact ? "min-w-0 flex-1" : ""}>

          <!-- Category + Date -->
          {(blog.category || blog.publishedAt) && (
            <div class="flex items-center gap-spacing-sm mb-spacing-lg">
              {blog.category && (
                <span class="inline-flex items-center border border-border/30 rounded-md px-2.5 py-1 text-xs font-medium text-muted">
                  {blog.category}
                </span>
              )}
            </div>
          )}

          <!-- Title -->
          <h1 class="text-4xl md:text-5xl font-heading text-foreground mb-spacing-lg">
            {blog.title}
          </h1>

          <!-- Description -->
          {blog.description && (
            <p class="text-lg text-muted leading-relaxed mb-spacing-2xl">
              {blog.description}
            </p>
          )}

          <!-- Cover Image -->
          {blog.image && (
            <div class="mb-spacing-2xl">
              <div class="relative w-full rounded-lg overflow-hidden">
                <img
                  src={blog.image}
                  alt={blog.title}
                  class="w-full h-auto max-h-[400px] object-cover"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          )}

          <!-- Content -->
          <div class="prose prose-lg prose-headings:uppercase prose-headings:font-bold prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl prose-p:text-foreground prose-strong:text-foreground prose-ul:text-foreground prose-li:text-foreground prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
            <Fragment set:html={blog.content} />
          </div>
        </div>

        <!-- Sidebar contact card -->
        {sidebarContact && (
          <aside class="w-full lg:w-72 xl:w-80 shrink-0 lg:sticky lg:top-24">
            <div class="bg-card border border-border/40 rounded-xl p-spacing-xl flex flex-col items-center text-center gap-spacing-md">

              {sidebarContact.image && (
                <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-border/30 shrink-0">
                  <img
                    src={sidebarContact.image}
                    alt={sidebarContact.name ?? ""}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              {(sidebarContact.name || sidebarContact.role) && (
                <div>
                  {sidebarContact.name && (
                    <p class="font-semibold text-foreground leading-tight">{sidebarContact.name}</p>
                  )}
                  {sidebarContact.role && (
                    <p class="text-sm text-muted mt-0.5">{sidebarContact.role}</p>
                  )}
                </div>
              )}

              {(sidebarContact.phone || sidebarContact.email) && (
                <div class="w-full border-t border-border/30 pt-spacing-md flex flex-col gap-spacing-sm">
                  {sidebarContact.phone && (
                    <a href={`tel:${sidebarContact.phone}`} class="flex items-center gap-spacing-sm text-sm text-foreground hover:text-primary transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.61 4.9 2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.5z"/></svg>
                      <span>{sidebarContact.phone}</span>
                    </a>
                  )}
                  {sidebarContact.email && (
                    <a href={`mailto:${sidebarContact.email}`} class="flex items-center gap-spacing-sm text-sm text-foreground hover:text-primary transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      <span class="break-all">{sidebarContact.email}</span>
                    </a>
                  )}
                </div>
              )}

              {sidebarContact.cta && (
                <a
                  href={ctaHref}
                  class="mt-spacing-xs inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline transition-colors"
                >
                  {sidebarContact.cta.label}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              )}

            </div>
          </aside>
        )}

      </div>
    </div>
  </section>
)}

<style>
  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h4) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.75rem;
  }

  .prose :global(strong) {
    font-weight: var(--fw-semibold, 600);
  }

  .prose :global(a) {
    transition: all 0.2s ease;
  }

  .prose :global(img) {
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: var(--radius);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--muted-foreground);
    margin: 2rem 0;
  }

  .prose :global(code) {
    background: var(--secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--secondary);
    padding: 1.5rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
