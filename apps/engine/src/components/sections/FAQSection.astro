---
import type { Section } from "@mshorizon/schema";
import { FAQAccordion, FAQBordered, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const faqItems = section.faqItems || [];
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    {variant === "bordered" ? (
      <FAQBordered
        client:visible
        items={faqItems}
        ctaText={ctaLabel}
        ctaHref={ctaHref}
      />
    ) : (
      <FAQAccordion
        client:visible
        items={faqItems}
        ctaText={ctaLabel}
        ctaHref={ctaHref}
      />
    )}
  </div>
</section>
