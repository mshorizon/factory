---
import type { SectionV15 } from "@mshorizon/schema";
import { FAQAccordion, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const faqItems = section.faqItems || [];
---

<section class="py-[120px]">
  <div class="container mx-auto px-[40px]">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      layout="split"
      align="left"
    />
    <FAQAccordion client:visible items={faqItems} image={section.image} />
  </div>
</section>
