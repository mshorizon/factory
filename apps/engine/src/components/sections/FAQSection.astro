---
import type { Section } from "@mshorizon/schema";
import { FAQAccordion, FAQBordered, FAQSplit, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const faqItems = section.faqItems || [];
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);

// Sections with these backgrounds supply their own padding
const noPaddingBgs = ["light-padded", "gradient", "none"];
const sectionPaddingClass = noPaddingBgs.includes(section.background as string)
  ? "py-0"
  : `py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`;
---

<section class={sectionPaddingClass}>
  <div class="container mx-auto">
    {variant === "split" ? (
      <FAQSplit
        client:visible
        items={faqItems}
        title={header.title}
        subtitle={header.subtitle}
        badge={header.badge}
        ctaText={ctaLabel}
        ctaHref={ctaHref}
      />
    ) : (
      <>
        <SectionHeader
          badge={header.badge}
          title={header.title}
          subtitle={header.subtitle}
          background={section.background}
          badgeVariant={badgeVariant as any}
        />
        {variant === "bordered" ? (
          <FAQBordered
            client:visible
            items={faqItems}
            ctaText={ctaLabel}
            ctaHref={ctaHref}
          />
        ) : (
          <FAQAccordion
            client:visible
            items={faqItems}
            ctaText={ctaLabel}
            ctaHref={ctaHref}
          />
        )}
      </>
    )}
  </div>
</section>
