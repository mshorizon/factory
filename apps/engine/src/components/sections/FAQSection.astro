---
import type { Section } from "@mshorizon/schema";
import { FAQAccordion, FAQBordered, FAQSplit, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const filled = variant === "bordered-filled";
const sectionBadgeVariant = (section as any).badgeVariant || badgeVariant;
const header = getSectionHeader(section);
const faqItems = section.faqItems || [];
const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.href || resolveTarget(section.cta?.target);
const image = (section as any).image as string | undefined;

---

<section>
  <div class="container mx-auto">
    {variant === "split" ? (
      <FAQSplit
        client:visible
        items={faqItems}
        title={header.title}
        subtitle={header.subtitle}
        badge={header.badge}
        ctaText={ctaLabel}
        ctaHref={ctaHref}
      />
    ) : image ? (
      <div class="grid lg:grid-cols-[1fr,448px] lg:gap-x-spacing-3xl items-start">
        <div class="flex flex-col min-w-0">
          <SectionHeader
            badge={header.badge}
            title={header.title}
            subtitle={header.subtitle}
            align="left"
            background={section.background}
            badgeVariant={badgeVariant as any}
          />
          {variant === "bordered" ? (
            <FAQBordered
              client:visible
              items={faqItems}
              ctaText={ctaLabel}
              ctaHref={ctaHref}
            />
          ) : (
            <FAQAccordion
              client:visible
              items={faqItems}
              ctaText={ctaLabel}
              ctaHref={ctaHref}
            />
          )}
        </div>
        <div class="hidden lg:block sticky top-32">
          <img
            src={image}
            alt=""
            class="w-full h-[448px] object-cover rounded-2xl"
          />
        </div>
      </div>
    ) : (
      <>
        <SectionHeader
          badge={header.badge}
          title={header.title}
          subtitle={header.subtitle}
          background={section.background}
          badgeVariant={(filled ? "text" : sectionBadgeVariant) as any}
          badgeClassName={filled ? "text-primary-light" : undefined}
          titleSize={filled ? "text-2xl md:text-3xl lg:text-4xl" : undefined}
        />
        {(variant === "bordered" || filled) ? (
          <FAQBordered
            client:visible
            items={faqItems}
            ctaText={ctaLabel}
            ctaHref={ctaHref}
            filled={filled}
          />
        ) : (
          <FAQAccordion
            client:visible
            items={faqItems}
            ctaText={ctaLabel}
            ctaHref={ctaHref}
          />
        )}
      </>
    )}
  </div>
</section>
