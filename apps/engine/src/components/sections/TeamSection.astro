---
import type { Section } from "@mshorizon/schema";
import { TeamGrid, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const header = getSectionHeader(section);
const members = (section as any).members || [];
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    <TeamGrid client:visible members={members} />
  </div>
</section>
