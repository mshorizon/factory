---
import type { Section } from "@mshorizon/schema";
import { AboutStory, AboutTimeline, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);

// Handle CTA for both v1.0 and v1.5 formats
const ctaLabel = section.cta?.label;
const ctaHref = 'href' in (section.cta || {})
  ? (section.cta as { href: string })?.href
  : "/contact";
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <SectionHeader
      title={header.title}
      align="center"
    />

    {variant === "timeline" ? (
      <AboutTimeline
        client:visible
        timeline={section.timeline || []}
        stats={section.stats}
        cta={ctaLabel}
        ctaHref={ctaHref}
      />
    ) : (
      <AboutStory
        client:visible
        story={section.story}
        stats={section.stats}
        commitment={section.commitment}
        image={section.image}
        cta={ctaLabel}
        ctaHref={ctaHref}
      />
    )}
  </div>
</section>
