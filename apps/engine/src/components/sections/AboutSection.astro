---
import type { Section } from "@mshorizon/schema";
import { AboutStory, AboutTimeline, AboutCareer, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);

const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.target ? resolveTarget(section.cta.target) : "/contact";
---

<section class={`pt-${isHomePage ? "spacing-section" : "spacing-section-sm"} ${isHomePage ? "pb-[120px]" : "pb-spacing-section-sm"} overflow-hidden`}>
  <div class="container mx-auto">
    {variant === "timeline" ? (
      <>
        <SectionHeader
          title={header.title}
          align="center"
          background={section.background}
          badgeVariant={badgeVariant as any}
        />
        <AboutTimeline
          client:visible
          timeline={section.timeline || []}
          stats={section.stats}
          cta={ctaLabel}
          ctaHref={ctaHref}
        />
      </>
    ) : variant === "career" ? (
      <AboutCareer
        client:visible
        title={header.title}
        items={(section.timeline || []).map((item: any) => ({
          year: item.year,
          title: item.title,
          company: item.company,
          description: item.description,
        }))}
      />
    ) : (
      <AboutStory
        client:visible
        badge={header.badge}
        title={header.title}
        story={section.story}
        stats={section.stats}
        commitment={section.commitment}
        image={section.image}
        cta={ctaLabel}
        ctaHref={ctaHref}
        experienceBadge={section.experienceBadge}
        experienceBadgeLabel={section.experienceBadgeLabel}
        background={section.background}
        imagePosition={(section as any).imagePosition}
      />
    )}
  </div>
</section>
