---
import type { Section } from "@mshorizon/schema";
import { AboutStory, AboutTimeline, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);

const ctaLabel = section.cta?.label;
const ctaHref = section.cta?.target ? resolveTarget(section.cta.target) : "/contact";
---

<section class="py-[120px] overflow-hidden">
  <div class="container mx-auto">
    {variant === "timeline" ? (
      <>
        <SectionHeader
          title={header.title}
          align="center"
        />
        <AboutTimeline
          client:visible
          timeline={section.timeline || []}
          stats={section.stats}
          cta={ctaLabel}
          ctaHref={ctaHref}
        />
      </>
    ) : (
      <AboutStory
        client:visible
        badge={header.badge}
        title={header.title}
        story={section.story}
        stats={section.stats}
        commitment={section.commitment}
        image={section.image}
        cta={ctaLabel}
        ctaHref={ctaHref}
        experienceBadge={section.experienceBadge}
        experienceBadgeLabel={section.experienceBadgeLabel}
      />
    )}
  </div>
</section>
