---
import type { Section } from "@mshorizon/schema";
import { ProcessSteps, ProcessVisual, ProcessGrid, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const steps = section.steps || [];
---

<section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      background={section.background}
      badgeVariant={badgeVariant as any}
      className={variant === "grid" ? "[&_h2]:max-w-[700px] [&_h2]:mx-auto" : undefined}
    />
    {variant === "visual" ? (
      <ProcessVisual client:visible steps={steps} />
    ) : variant === "grid" ? (
      <ProcessGrid client:visible steps={steps} />
    ) : (
      <ProcessSteps client:visible steps={steps} />
    )}
  </div>
</section>
