---
import type { SectionV15 } from "@mshorizon/schema";
import { ProcessSteps, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: SectionV15;
}

const { section } = Astro.props;
const header = getSectionHeader(section);
const steps = section.steps || [];
---

<section class="py-[120px]">
  <div class="container mx-auto px-[40px]">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
    />
    <ProcessSteps client:visible steps={steps} />
  </div>
</section>
