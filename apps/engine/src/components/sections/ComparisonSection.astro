---
import type { Section } from "@mshorizon/schema";
import { ComparisonTable, ComparisonTriple, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const rows = (section as any).rows || [];
const leftTitle = (section as any).leftTitle || "Manual Work";
const rightTitle = (section as any).rightTitle || "AI Automation";
const criteria = (section as any).criteria || [];
const comparisonColumns = (section as any).comparisonColumns || [];
---

<section>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      align="center"
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    {variant === "triple" ? (
      <ComparisonTriple
        client:visible
        criteria={criteria}
        columns={comparisonColumns}
      />
    ) : (
      <ComparisonTable
        client:visible
        leftTitle={leftTitle}
        rightTitle={rightTitle}
        rows={rows}
      />
    )}
  </div>
</section>
