---
import type { Section } from "@mshorizon/schema";
import { ContactCentered, ContactSplit, ContactCTA, ContactMinimal, ContactCard, ContactLightPanel, ContactProfessional, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business?: any;
  badgeVariant?: string;
}

const { section, isHomePage = false, business: businessProp, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const businessId = Astro.locals.businessId;
const business = businessProp ?? Astro.locals.businessData;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

// Resolve CTA href from target
const ctaHref = section.cta?.target?.type === "phone"
  ? `tel:${section.cta.target.value || ""}`
  : section.cta?.target?.value
    ? (section.cta.target.value === "home" ? "/" : `/${section.cta.target.value}`)
    : "/contact";
---

{variant === "professional" ? (
  <section
    class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}
    style="background-color: var(--background);"
  >
    <div class="container mx-auto">
      <ContactProfessional
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        info={section.info}
        businessId={businessId}
        business={business}
        turnstileSiteKey={turnstileSiteKey}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : variant === "light-panel" ? (
  <section
    class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}
    style="background: linear-gradient(160deg, color-mix(in srgb, var(--secondary) 60%, transparent) 0%, var(--background) 60%);"
  >
    <div class="container mx-auto">
      <ContactLightPanel
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        info={section.info}
        businessId={businessId}
        business={business}
        turnstileSiteKey={turnstileSiteKey}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : variant === "cta" ? (
  <section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <div class="container mx-auto">
      <ContactCTA
        client:visible
        badge={header.badge}
        title={header.title}
        subtitle={header.subtitle}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : variant === "minimal" ? (
  <section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <div class="container mx-auto">
      <ContactMinimal
        client:visible
        badge={header.badge}
        title={header.title}
        subtitle={header.subtitle}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : variant === "card" ? (
  <section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <div class="container mx-auto">
      <ContactCard
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        info={section.info}
        businessId={businessId}
        business={business}
        turnstileSiteKey={turnstileSiteKey}
        ctaLabel={section.cta?.label}
        ctaHref={ctaHref}
      />
    </div>
  </section>
) : (
  <section class={`pb-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
    <div class="container mx-auto">
      {header.badge && (
        <SectionHeader
          badge={header.badge}
          title={header.title}
          subtitle={header.subtitle}
          background={section.background}
          badgeVariant={badgeVariant as any}
        />
      )}
      {variant === "split" ? (
        <ContactSplit
          client:visible
          title={!header.badge ? header.title : undefined}
          subtitle={!header.badge ? header.subtitle : undefined}
          badge={!header.badge ? header.badge : undefined}
          form={section.form}
          info={section.info}
          labels={section.labels}
          businessId={businessId}
          business={business}
          turnstileSiteKey={turnstileSiteKey}
        />
      ) : (
        <ContactCentered
          client:visible
          title={header.title}
          subtitle={header.subtitle}
          form={section.form}
          businessId={businessId}
          turnstileSiteKey={turnstileSiteKey}
        />
      )}
    </div>
  </section>
)}
