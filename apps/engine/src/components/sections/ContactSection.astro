---
import type { Section } from "@mshorizon/schema";
import { ContactCentered, ContactSplit } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const businessId = Astro.locals.businessId;
const business = Astro.locals.businessData;
---

<section class="py-20">
  <div class="container mx-auto">
    {variant === "split" ? (
      <ContactSplit
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        badge={header.badge}
        form={section.form}
        info={section.info}
        labels={section.labels}
        businessId={businessId}
        business={business}
      />
    ) : (
      <ContactCentered
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        businessId={businessId}
      />
    )}
  </div>
</section>
