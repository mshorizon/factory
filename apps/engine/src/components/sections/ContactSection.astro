---
import type { Section } from "@mshorizon/schema";
import { ContactCentered, ContactSplit } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
---

<section class="bg-background py-16">
  <div class="container mx-auto px-4">
    {variant === "split" ? (
      <ContactSplit
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        info={section.info}
        labels={section.labels}
      />
    ) : (
      <ContactCentered
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
      />
    )}
  </div>
</section>
