---
import type { Section } from "@mshorizon/schema";
import { ContactCentered, ContactSplit } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business?: any;
}

const { section, isHomePage = false, business: businessProp } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const businessId = Astro.locals.businessId;
const business = businessProp ?? Astro.locals.businessData;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<section class={`py-${isHomePage ? "spacing-section" : "spacing-section-sm"}`}>
  <div class="container mx-auto">
    {variant === "split" ? (
      <ContactSplit
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        badge={header.badge}
        form={section.form}
        info={section.info}
        labels={section.labels}
        businessId={businessId}
        business={business}
        turnstileSiteKey={turnstileSiteKey}
      />
    ) : (
      <ContactCentered
        client:visible
        title={header.title}
        subtitle={header.subtitle}
        form={section.form}
        businessId={businessId}
        turnstileSiteKey={turnstileSiteKey}
      />
    )}
  </div>
</section>
