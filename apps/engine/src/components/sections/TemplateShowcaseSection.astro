---
import type { Section } from "@mshorizon/schema";
import { TemplateShowcase, TemplateShowcaseBrowser, SectionHeader } from "@mshorizon/ui";
import { getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
  badgeVariant?: string;
}

const { section, badgeVariant } = Astro.props;
const variant = (section as any).variant ?? "default";
const header = getSectionHeader(section);
const templates = (section as any).templateItems || [];
const pills = (section as any).pills as string[] | undefined;
const footnote = (section as any).footnote as string | undefined;
---

<section>
  <div class="container mx-auto">
    <SectionHeader
      badge={header.badge}
      title={header.title}
      subtitle={header.subtitle}
      background={section.background}
      badgeVariant={badgeVariant as any}
    />
    {variant === "browser" ? (
      <TemplateShowcaseBrowser client:visible templates={templates} pills={pills} />
    ) : (
      <TemplateShowcase client:visible templates={templates} />
    )}
    {footnote && (
      <p class="mt-spacing-2xl italic text-muted text-center text-sm" data-field="footnote">
        {footnote}
      </p>
    )}
  </div>
</section>
