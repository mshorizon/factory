---
import type { Section } from "@mshorizon/schema";
import { EventsDefault, EventsCards, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  isHomePage?: boolean;
  section: Section;
  badgeVariant?: string;
}

const { section, isHomePage = false, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const items = section.items || [];
---

<section>
  <div class="container mx-auto">
    {variant === "cards" ? (
      <EventsCards
        client:visible
        badge={header.badge}
        title={header.title}
        items={items}
      />
    ) : (
      <>
        <SectionHeader
          badge={header.badge}
          title={header.title}
          subtitle={header.subtitle}
          align="center"
          badgeVariant={badgeVariant as any}
        />
        <EventsDefault client:visible items={items} />
      </>
    )}
  </div>
</section>
