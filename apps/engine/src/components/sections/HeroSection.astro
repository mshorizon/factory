---
import type { Section } from "@mshorizon/schema";
import { HeroDefault, HeroSplit, HeroGradient, HeroCards, HeroVideo, HeroMinimal } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const heroImage = section.image || section.backgroundImage;
---

{variant === "split" ? (
  <HeroSplit
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : variant === "gradient" ? (
  <HeroGradient
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : variant === "cards" ? (
  <HeroCards
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : variant === "video" ? (
  <HeroVideo
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : variant === "minimal" ? (
  <HeroMinimal
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : (
  <HeroDefault
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
    fullHeight
  />
)}
