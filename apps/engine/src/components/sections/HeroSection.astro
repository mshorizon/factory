---
import type { Section } from "@mshorizon/schema";
import { HeroDefault, HeroSplit, HeroGradient, HeroCards, HeroVideo, HeroMinimal, HeroArtist, HeroAgency } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const heroImage = section.image || section.backgroundImage;

// Get business phone from locals — only pass to component when CTA explicitly targets phone
const { businessData } = Astro.locals;
const isPhoneCta = section.cta?.target?.type === "phone";
const businessPhone = isPhoneCta ? businessData?.business?.contact?.phone : undefined;

// Resolve CTA targets to hrefs
const cta = section.cta ? {
  label: section.cta.label,
  href: section.cta.href || resolveTarget(section.cta.target),
  variant: section.cta.variant,
} : undefined;

const secondaryCta = section.secondaryCta ? {
  label: section.secondaryCta.label,
  href: section.secondaryCta.href || resolveTarget(section.secondaryCta.target),
  variant: section.secondaryCta.variant,
} : undefined;
---

{variant === "split" ? (
  <HeroSplit
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    testimonial={section.testimonial}
    testimonials={section.testimonials}
    phone={businessPhone}
    background={section.background}
    isHomePage={isHomePage}
    hideDots={section.hideDots}
    badgeLayout={section.badgeLayout}
  />
) : variant === "gradient" ? (
  <HeroGradient
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "cards" ? (
  <HeroCards
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "video" ? (
  <HeroVideo
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "artist" ? (
  <HeroArtist
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "agency" ? (
  <HeroAgency
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
    floatingCards={(section as any).floatingCards}
    trustSignals={(section as any).trustSignals}
    avatarImages={(section as any).avatarImages}
    googleRating={(section as any).googleRating}
  />
) : variant === "minimal" ? (
  <HeroMinimal
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : (
  <HeroDefault
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={cta}
    secondaryCta={secondaryCta}
    fullHeight
    isHomePage={isHomePage}
  />
)}
