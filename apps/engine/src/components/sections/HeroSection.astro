---
import type { Section } from "@mshorizon/schema";
import { HeroDefault, HeroSplit } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
---

{variant === "split" ? (
  <HeroSplit
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={section.image || section.backgroundImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
  />
) : (
  <HeroDefault
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={section.cta}
    secondaryCta={section.secondaryCta}
    fullHeight
  />
)}
