---
import type { Section } from "@mshorizon/schema";
import { HeroDefault, HeroSplit, HeroGradient, HeroCards, HeroVideo, HeroMinimal, HeroArtist, HeroAgency, HeroSacrum } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
}

const { section, isHomePage = false } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const heroImage = section.image || section.backgroundImage;

// Get business phone from locals — only pass to component when CTA explicitly targets phone
const { businessData } = Astro.locals;
const isPhoneCta = section.cta?.target?.type === "phone";
const businessPhone = isPhoneCta ? businessData?.business?.contact?.phone : undefined;

// Resolve CTA targets to hrefs
const cta = section.cta ? {
  label: section.cta.label,
  href: section.cta.href || resolveTarget(section.cta.target),
  variant: section.cta.variant,
} : undefined;

const secondaryCta = section.secondaryCta ? {
  label: section.secondaryCta.label,
  href: section.secondaryCta.href || resolveTarget(section.secondaryCta.target),
  variant: section.secondaryCta.variant,
} : undefined;
---

{variant === "split" ? (
  <HeroSplit
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    testimonial={section.testimonial}
    testimonials={section.testimonials}
    phone={businessPhone}
    background={section.background}
    isHomePage={isHomePage}
    hideDots={section.hideDots}
    badgeLayout={section.badgeLayout}
  />
) : variant === "gradient" ? (
  <HeroGradient
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "cards" ? (
  <HeroCards
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "video" ? (
  <HeroVideo
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    backgroundImage={section.backgroundImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "artist" ? (
  <HeroArtist
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "agency" ? (
  <HeroAgency
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
    floatingCards={(section as any).floatingCards}
    trustSignals={(section as any).trustSignals}
    avatarImages={(section as any).avatarImages}
    googleRating={(section as any).googleRating}
  />
) : variant === "minimal" ? (
  <HeroMinimal
    client:load
    badge={header.badge}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    secondaryCta={secondaryCta}
    isHomePage={isHomePage}
  />
) : variant === "sacrum" ? (
  <HeroSacrum
    client:load
    badge={header.badge}
    badgeColor={section.badgeColor}
    title={header.title || ""}
    subtitle={header.subtitle}
    image={heroImage}
    cta={cta}
    titleAccent={(section as any).titleAccent}
    scheduleCards={(section as any).scheduleCards}
    isHomePage={isHomePage}
  />
) : (
  <Fragment>
    <style is:inline set:html={`@keyframes hero-bg-zoom { from { transform: scale(1.1); } to { transform: scale(1); } }`} />
    <section
      class="hero-default bg-background"
      style="position:relative;z-index:0;overflow:hidden;min-height:100vh;width:100vw;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;margin-top:calc(var(--main-nav-offset,64px) * -1)"
    >
    {section.backgroundImage && (
      <>
        <div
          style={`position:absolute;inset:0;background-image:url('${section.backgroundImage}');background-size:cover;background-position:center;animation:hero-bg-zoom 10s ease-out both;will-change:transform`}
          data-field="backgroundImage"
        />
        <div
          style="position:absolute;inset:0;background-color:color-mix(in oklab, hsl(24 15% 10%) 60%, transparent)"
        />
      </>
    )}
    <div
      class="container mx-auto"
      style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center"
    >
      {header.badge && (
        <div class="mb-spacing-md">
          <span class="inline-flex items-center text-sm font-medium tracking-wide uppercase px-spacing-md py-1 text-primary">
            {header.badge}
          </span>
        </div>
      )}
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading mb-spacing-md tracking-tight text-on-primary"
        data-field="header.title"
      >
        {header.title || ""}
      </h1>
      {header.subtitle && (
        <p
          class="text-lg md:text-xl max-w-2xl mb-spacing-2xl text-on-primary/90 mx-auto"
          data-field="header.subtitle"
        >
          {header.subtitle}
        </p>
      )}
      {(cta || secondaryCta) && (
        <div class="flex flex-wrap gap-spacing-md justify-center">
          {cta && (
            <a
              href={cta.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-on-primary bg-primary rounded-radius shadow-lg shadow-primary/25 hover:bg-primary/90 transition-colors"
              data-field="cta"
            >
              {cta.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold border border-on-primary text-on-primary hover:bg-on-primary hover:text-foreground rounded-radius transition-colors"
              data-field="secondaryCta"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
    </section>
  </Fragment>
)}
