---
import type { Section, BusinessProfile } from "@mshorizon/schema";
import { TestimonialsGrid, TestimonialsGradient, TestimonialsFeatured, TestimonialsCentered, TestimonialsAgency, TestimonialsQuotes, SectionHeader } from "@mshorizon/ui";
import { getSectionVariant, getSectionHeader } from "../../lib/pages";
import { resolveTarget } from "../../lib/target";

interface Props {
  isHomePage?: boolean;
  section: Section;
  business?: BusinessProfile;
  badgeVariant?: string;
}

const { section, isHomePage = false, business, badgeVariant } = Astro.props;
const variant = getSectionVariant(section);
const header = getSectionHeader(section);
const items = section.items || [];
const cta = section.cta;
const ctaHref = cta && business ? resolveTarget(cta.target, business) : undefined;
const showHeader = section.variant !== 'full';
const isQuotes = variant === "quotes";
const headerAlign = (header as any).align || (isQuotes ? "center" : "left");
---

<section>
  <div class="container mx-auto">
    {showHeader && (
      <SectionHeader
        badge={header.badge}
        title={header.title}
        subtitle={header.subtitle}
        layout={isQuotes ? "stacked" : ((header.layout as any) || "split")}
        align={headerAlign}
        background={section.background}
        badgeVariant={(isQuotes ? "accent-no-line" : badgeVariant) as any}
      />
    )}
    <div>
      {variant === "agency" ? (
        <TestimonialsAgency client:visible items={items} clean={(section as any).testimonialsClean} />
      ) : variant === "gradient" ? (
        <TestimonialsGradient client:visible items={items} />
      ) : variant === "featured" ? (
        <TestimonialsFeatured client:visible items={items} sectionImage={section.image} />
      ) : variant === "centered" ? (
        <TestimonialsCentered client:visible items={items} />
      ) : variant === "quotes" ? (
        <TestimonialsQuotes client:visible items={items} ctaLabel={cta?.label} ctaHref={ctaHref} />
      ) : (
        <TestimonialsGrid client:visible items={items} />
      )}
    </div>
    {cta && ctaHref && !isQuotes && (
      <div class="mt-[8rem]">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent font-medium rounded-full hover:opacity-90 transition-opacity w-fit"
          style="color: var(--text-on-primary);"
        >
          {cta.label}
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
