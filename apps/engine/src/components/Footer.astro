---
interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface SocialLink {
  platform: string;
  url: string;
}

interface FooterExtension {
  type: "call";
  headline?: string;
  phone?: string;
}

interface Props {
  businessName: string;
  links?: FooterLink[];
  columns?: FooterColumn[];
  copyright?: string;
  tagline?: string;
  currentLanguage?: string;
  variant?: "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked";
  socialLinks?: SocialLink[];
  extensions?: FooterExtension[];
}

const {
  businessName,
  links = [],
  columns = [],
  copyright,
  tagline,
  currentLanguage,
  variant = "simple",
  socialLinks = [],
  extensions = [],
} = Astro.props;

const callExtension = extensions.find((e) => e.type === "call");

const contactIcons: Record<string, string> = {
  phone: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>',
  mail: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
  mapPin: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
};

function getContactIcon(href: string): string | null {
  if (href.startsWith('tel:')) return contactIcons.phone;
  if (href.startsWith('mailto:')) return contactIcons.mail;
  if (href.includes('maps') || href.includes('google.com/maps')) return contactIcons.mapPin;
  return null;
}

const socialIcons: Record<string, string> = {
  facebook: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>',
  instagram: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>',
  youtube: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>',
  linkedin: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>',
  twitter: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>',
};

const year = new Date().getFullYear();
const copyrightText = copyright || `© ${year} ${businessName}. All rights reserved.`;

const languages = [
  { code: "pl", label: "Polski" },
  { code: "en", label: "English" },
];

// Dark-bg variants use light tone, light-bg variants use dark tone
const isDark = ["simple", "multiColumn", "centered", "branded"].includes(variant);
---

{callExtension && (
  <div class="section-bg-dark overflow-hidden shrink-0">
    <div class="container mx-auto py-spacing-section-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
      <h2 class="font-bold text-3xl md:text-4xl lg:text-5xl uppercase leading-tight text-foreground max-w-xl">
        {callExtension.headline}
      </h2>
      <a
        href={`tel:${callExtension.phone?.replace(/\s/g, '')}`}
        class="inline-flex items-center gap-3 bg-primary text-on-primary font-semibold text-base md:text-lg px-6 py-4 rounded-full hover:opacity-90 transition-opacity shrink-0 self-start md:self-auto"
      >
        {callExtension.phone}
        <span class="inline-flex items-center justify-center w-9 h-9 bg-on-primary/15 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
        </span>
      </a>
    </div>
    <div class="container mx-auto"><div class="border-t border-border/30" /></div>
  </div>
)}

{variant === "minimal" && (
  <footer class="bg-background border-t border-border shrink-0">
    <div class="container mx-auto py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-muted">{copyrightText}</p>
        <div class="flex flex-wrap items-center gap-4">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex flex-wrap items-center gap-4">
              {links.map((link) => (
                <a href={link.href} class="text-sm text-muted hover:text-foreground transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "centered" && (
  <footer class="bg-secondary text-on-primary shrink-0">
    <div class="container mx-auto py-16">
      <div class="flex flex-col items-center text-center">
        <span class="font-bold text-3xl tracking-tight mb-4">{businessName}</span>
        {tagline && <p class="text-on-primary/70 text-lg max-w-md mb-8">{tagline}</p>}
        {links.length > 0 && (
          <nav class="flex flex-wrap justify-center gap-4 mb-8">
            {links.map((link) => (
              <a href={link.href} class="px-4 py-2 text-sm text-on-primary/80 hover:text-on-primary hover:bg-on-primary/10 rounded-radius transition-colors">
                {link.label}
              </a>
            ))}
          </nav>
        )}
        <div class="w-24 h-px bg-on-primary/20 mb-8"></div>
        {currentLanguage && (
          <div class="lang-switcher flex items-center gap-1.5 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-on-primary/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            {languages.map((lang, i) => (
              <>
                {i > 0 && <span class="text-[10px] select-none text-on-primary/20">/</span>}
                <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-on-primary font-medium" : "text-on-primary/40 hover:text-on-primary/70"]}>{lang.label}</button>
              </>
            ))}
          </div>
        )}
        <p class="text-sm text-on-primary/60">{copyrightText}</p>
      </div>
    </div>
  </footer>
)}

{variant === "branded" && (
  <footer class="section-bg-dark relative overflow-hidden shrink-0">
    <div class="container mx-auto py-spacing-3xl">

      {/* Main grid: brand col (wider) + content columns */}
      <div class="footer-grid grid gap-spacing-3xl" style={`--footer-cols: 2fr ${columns.map(() => '1fr').join(' ')}`}>

        {/* Brand Column */}
        <div>
          <span class="font-bold text-2xl tracking-tight block mb-spacing-md text-foreground">{businessName}</span>
          {tagline && <p class="text-muted text-sm leading-relaxed max-w-xs mb-spacing-xl">{tagline}</p>}
          {socialLinks.length > 0 && (
            <div class="flex items-center gap-spacing-lg">
              {socialLinks.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.platform} class="text-muted hover:text-primary transition-colors">
                  <Fragment set:html={socialIcons[social.platform] || ''} />
                </a>
              ))}
            </div>
          )}
        </div>

        {/* Content Columns */}
        {columns.map((column) => (
          <div>
            <h3 class="font-bold text-foreground mb-spacing-xl text-xs uppercase tracking-widest">{column.title}</h3>
            <ul class="space-y-spacing-lg">
              {column.links.map((link) => {
                const icon = getContactIcon(link.href || '');
                return (
                  <li>
                    {icon ? (
                      <a href={link.href} class="flex items-center gap-spacing-sm text-muted hover:text-foreground text-sm transition-colors group">
                        <span class="shrink-0" style="color: var(--primary)" set:html={icon} />
                        {link.label}
                      </a>
                    ) : (
                      <a href={link.href} class="text-muted hover:text-foreground text-sm transition-colors">
                        {link.label}
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>

      {/* Bottom Bar */}
      <div class="mt-spacing-3xl pt-spacing-lg border-t border-border/30 flex flex-col md:flex-row items-center justify-between gap-spacing-md">
        <p class="text-sm text-muted">{copyrightText}</p>
        <div class="flex flex-wrap items-center gap-x-spacing-xl gap-y-2">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-muted/40">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-muted hover:text-foreground"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex flex-wrap gap-spacing-lg">
              {links.map((link) => (
                <a href={link.href} class="text-muted hover:text-foreground text-sm transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>

    </div>
  </footer>
)}

{variant === "stacked" && (
  <footer class="bg-background shrink-0">
    <div class="border-t border-border">
      <div class="container mx-auto py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <span class="font-bold text-2xl text-foreground tracking-tight block">{businessName}</span>
            {tagline && <p class="text-muted mt-2 max-w-md">{tagline}</p>}
          </div>
        </div>
      </div>
    </div>
    {columns.length > 0 && (
      <div class="border-t border-border">
        <div class="container mx-auto py-8">
          <div class="flex flex-wrap justify-center gap-x-12 gap-y-6">
            {columns.map((column) => (
              <div class="text-center">
                <h3 class="font-semibold text-foreground mb-3 text-sm uppercase tracking-wider">{column.title}</h3>
                <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2">
                  {column.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-muted hover:text-primary text-sm transition-colors">
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}
    <div class="border-t border-border bg-primary/5">
      <div class="container mx-auto py-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-muted">{copyrightText}</p>
          <div class="flex items-center gap-6">
            {currentLanguage && (
              <div class="lang-switcher flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {languages.map((lang, i) => (
                  <>
                    {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                    <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                  </>
                ))}
              </div>
            )}
            {links.length > 0 && (
              <nav class="flex gap-6">
                {links.map((link) => (
                  <a href={link.href} class="text-muted hover:text-foreground text-sm transition-colors">
                    {link.label}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "multiColumn" && (
  <footer class="bg-secondary text-on-primary shrink-0">
    <div class="container mx-auto py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div class="lg:col-span-1">
          <span class="font-bold text-2xl tracking-tight block mb-4">{businessName}</span>
          {tagline && <p class="text-on-primary/70 text-sm leading-relaxed">{tagline}</p>}
        </div>
        {columns.map((column) => (
          <div>
            <h3 class="font-semibold text-on-primary mb-4">{column.title}</h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="text-on-primary/70 hover:text-on-primary text-sm transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 pt-8 border-t border-on-primary/10 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-on-primary/60">{copyrightText}</p>
        <div class="flex items-center gap-6">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-on-primary/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-on-primary/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-on-primary font-medium" : "text-on-primary/40 hover:text-on-primary/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex gap-4">
              {links.map((link) => (
                <a href={link.href} class="text-on-primary/60 hover:text-on-primary text-sm transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "simple" && (
  <footer class="bg-secondary text-on-primary shrink-0">
    <div class="container mx-auto py-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex flex-col items-center md:items-start gap-2">
          <span class="font-bold text-xl tracking-tight">{businessName}</span>
        </div>
        {links.length > 0 && (
          <nav class="flex flex-wrap justify-center gap-4">
            {links.map((link) => (
              <a href={link.href} class="px-4 py-2 text-sm text-on-primary/80 hover:text-on-primary hover:bg-on-primary/10 rounded-radius transition-colors">
                {link.label}
              </a>
            ))}
          </nav>
        )}
      </div>
      <div class="mt-8 pt-8 border-t border-on-primary/10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-on-primary/60">{copyrightText}</p>
        {currentLanguage && (
          <div class="lang-switcher flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-on-primary/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            {languages.map((lang, i) => (
              <>
                {i > 0 && <span class="text-[10px] select-none text-on-primary/20">/</span>}
                <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-on-primary font-medium" : "text-on-primary/40 hover:text-on-primary/70"]}>{lang.label}</button>
              </>
            ))}
          </div>
        )}
      </div>
    </div>
  </footer>
)}

<script>
  document.querySelectorAll('.lang-btn').forEach((button) => {
    button.addEventListener('click', () => {
      const lang = (button as HTMLElement).dataset.lang;
      if (lang) {
        document.cookie = `lang=${lang};path=/;max-age=31536000;SameSite=Lax`;
        window.location.href = window.location.pathname;
      }
    });
  });
</script>

<style>
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: var(--footer-cols, 1fr);
    }
  }
</style>
