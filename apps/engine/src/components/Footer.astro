---

interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface SocialLink {
  platform: string;
  url: string;
}

interface FooterExtension {
  type: "call";
  headline?: string;
  phone?: string;
}

interface FooterBackground {
  enabled?: boolean;
  padding?: string;
  borderRadius?: string;
  /** Optional vertical gradient — e.g. "primary-to-primary-dark". Falls back to bg-secondary when absent. */
  gradient?: "primary-to-primary-dark" | string;
  /** Optional custom CSS color override for the footer wrapper — e.g. "#26201c". */
  color?: string;
}

interface ContactData {
  phone?: string;
  email?: string;
  address?: string;
  additionalInfo?: string[];
}

interface HoursRow {
  label: string;
  value: string;
  highlight?: boolean;
}

interface Props {
  businessName: string;
  footerName?: string;
  logoIcon?: string;
  footerLogoIcon?: string;
  links?: FooterLink[];
  columns?: FooterColumn[];
  copyright?: string;
  tagline?: string;
  currentLanguage?: string;
  variant?: "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked" | "gradient" | "darkColumns" | "restaurant";
  socialLinks?: SocialLink[];
  extensions?: FooterExtension[];
  background?: FooterBackground;
  contact?: ContactData;
  /** Restaurant variant extras */
  flag?: string[];
  findUsTitle?: string;
  hoursTitle?: string;
  hours?: HoursRow[];
  signature?: string;
  /** darkColumns: column title style — 'label' (default, tiny uppercase) or 'serif' (large font-heading headings) */
  columnHeadingVariant?: "label" | "serif";
  /** darkColumns: 'embed' (default, live Google Maps iframe) or 'placeholder' (flat neutral panel) */
  mapStyle?: "embed" | "placeholder";
  /** darkColumns: optional uppercase label rendered above the IBAN account number (e.g. "NUMER KONTA") */
  accountLabel?: string;
}

const {
  businessName,
  footerName,
  logoIcon,
  footerLogoIcon,
  links = [],
  columns = [],
  copyright,
  tagline,
  currentLanguage,
  variant = "simple",
  socialLinks = [],
  extensions = [],
  background,
  contact,
  flag = [],
  findUsTitle,
  hoursTitle,
  hours = [],
  signature,
  columnHeadingVariant = "label",
  mapStyle = "embed",
  accountLabel,
} = Astro.props;

const displayName = footerName || businessName;
const effectiveFooterIcon = footerLogoIcon || logoIcon;

const callExtension = extensions.find((e) => e.type === "call");

const contactIcons: Record<string, string> = {
  phone: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>',
  mail: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>',
  mapPin: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>',
  clock: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>',
};

// Larger, outlined (stroke-based) contact icons for the restaurant footer variant
const restaurantContactIcons: Record<string, string> = {
  phone: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  mapPin: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
};

function getContactIcon(href: string): string | null {
  if (href.startsWith('tel:')) return contactIcons.phone;
  if (href.startsWith('mailto:')) return contactIcons.mail;
  if (href.startsWith('geo:')) return contactIcons.mapPin;
  if (href.startsWith('#hours')) return contactIcons.clock;
  if (href.includes('maps') || href.includes('google.com/maps')) return contactIcons.mapPin;
  return null;
}

const socialIcons: Record<string, string> = {
  facebook: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>',
  instagram: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>',
  youtube: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>',
  linkedin: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>',
  twitter: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>',
};

const year = new Date().getFullYear();
const copyrightText = (copyright || `© ${year} ${businessName}. All rights reserved.`).replace("{year}", String(year));

const translations = (Astro.locals as any).t || {};
const cookieSettingsLabel = translations["footer.cookieSettings"] || "Ustawienia cookies";

// Auto-build contact column from contact data — same source as navbar upper-bar
const autoContactLinks: FooterLink[] = [];
if (contact?.phone) {
  autoContactLinks.push({ label: contact.phone, href: `tel:${contact.phone.replace(/\s/g, '')}` });
}
if (contact?.email) {
  autoContactLinks.push({ label: contact.email, href: `mailto:${contact.email}` });
}
if (contact?.address) {
  autoContactLinks.push({
    label: contact.address,
    href: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(contact.address)}`,
  });
}
const contactColumnTitle = translations["footer.columns.contact.title"] || "Contact";
// Drop any JSON-defined contact column with the same title before appending
// the auto-built one, so contact info isn't rendered in two columns.
const effectiveColumns: FooterColumn[] = autoContactLinks.length > 0
  ? [...columns.filter((c) => c.title !== contactColumnTitle), { title: contactColumnTitle, links: autoContactLinks }]
  : columns;

const languages = [
  { code: "pl", label: "Polski" },
  { code: "en", label: "English" },
  { code: "de", label: "Deutsch" },
  { code: "uk", label: "Українська" },
];
---

{callExtension && (
  <div class="section-bg-dark overflow-hidden shrink-0">
    <div class="container mx-auto py-spacing-section-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
      <h2 class="font-bold text-3xl md:text-4xl lg:text-5xl uppercase leading-tight text-foreground max-w-xl">
        {callExtension.headline}
      </h2>
      <a
        href={`tel:${callExtension.phone?.replace(/\s/g, '')}`}
        class="inline-flex items-center gap-3 bg-primary text-on-primary font-semibold text-base md:text-lg px-6 py-4 rounded-full hover:opacity-90 transition-opacity shrink-0 self-start md:self-auto"
      >
        {callExtension.phone}
        <span class="inline-flex items-center justify-center w-9 h-9 bg-white text-secondary rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </span>
      </a>
    </div>
    <div class="container mx-auto"><div class="border-t border-border/30" /></div>
  </div>
)}

{variant === "minimal" && (
  <footer class="bg-background border-t border-border shrink-0">
    <div class="container mx-auto py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-muted">{copyrightText}</p>
        <div class="flex flex-wrap items-center gap-4">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          <button data-cookie-settings class="text-xs text-muted hover:text-foreground transition-colors">{cookieSettingsLabel}</button>
          <span class="text-xs text-muted">Made by <a href="https://hazelgrouse.pl" target="_blank" rel="noopener noreferrer" class="text-foreground font-medium hover:opacity-80 transition-opacity">Hazelgrouse Studio</a></span>
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "centered" && (
  <footer class="bg-secondary text-on-primary shrink-0">
    <div class="container mx-auto py-16">
      <div class="flex flex-col items-center text-center">
        <span class="font-bold text-3xl tracking-tight mb-4">{businessName}</span>
        {tagline && <p class="text-on-primary/70 text-lg max-w-md mb-8">{tagline}</p>}
        <div class="w-24 h-px bg-on-primary/20 mb-8"></div>
        {currentLanguage && (
          <div class="lang-switcher flex items-center gap-1.5 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-on-primary/65"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            {languages.map((lang, i) => (
              <>
                {i > 0 && <span class="text-[10px] select-none text-on-primary/40">/</span>}
                <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-on-primary font-medium" : "text-on-primary/65 hover:text-on-primary"]}>{lang.label}</button>
              </>
            ))}
          </div>
        )}
        <p class="text-sm text-on-primary/60">{copyrightText}</p>
        <div class="flex flex-wrap justify-center items-center gap-4 mt-3">
          <button data-cookie-settings class="text-xs text-on-primary/60 hover:text-on-primary/90 transition-colors">{cookieSettingsLabel}</button>
          <span class="text-xs text-on-primary/60">Made by <a href="https://hazelgrouse.pl" target="_blank" rel="noopener noreferrer" class="text-on-primary font-medium hover:opacity-80 transition-opacity">Hazelgrouse Studio</a></span>
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "branded" && (
  <footer class="section-bg-dark relative overflow-hidden shrink-0">
    <div class="container mx-auto py-spacing-3xl">

      {/* Main grid: brand col (wider) + content columns */}
      <div class="footer-grid grid gap-spacing-3xl" style={`--footer-cols: 2fr ${effectiveColumns.map(() => '1fr').join(' ')}`}>

        {/* Brand Column */}
        <div>
          <div class="flex items-center gap-spacing-sm mb-spacing-md">
            {effectiveFooterIcon && <img src={effectiveFooterIcon} alt="" class="w-6 h-6" />}
            <span class="font-bold text-2xl tracking-tight text-foreground">{displayName}</span>
          </div>
          {tagline && <p class="text-muted text-sm leading-relaxed max-w-xs mb-spacing-xl">{tagline}</p>}
          {socialLinks.length > 0 && (
            <div class="flex items-center gap-spacing-lg">
              {socialLinks.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.platform} class="text-muted hover:text-primary transition-colors">
                  <Fragment set:html={socialIcons[social.platform] || ''} />
                </a>
              ))}
            </div>
          )}
        </div>

        {/* Content Columns */}
        {effectiveColumns.map((column) => (
          <div>
            <h3 class="font-bold text-foreground mb-spacing-xl text-xs uppercase tracking-widest">{column.title}</h3>
            <ul class="space-y-spacing-lg">
              {column.links.map((link) => {
                const icon = getContactIcon(link.href || '');
                return (
                  <li>
                    {icon ? (
                      <a href={link.href} class="flex items-center gap-spacing-sm text-muted hover:text-foreground text-sm transition-colors group">
                        <span class="shrink-0 inline-flex items-center justify-center" style="color: var(--primary)" set:html={icon} />
                        {link.label}
                      </a>
                    ) : (
                      <a href={link.href} class="text-muted hover:text-foreground text-sm transition-colors">
                        {link.label}
                      </a>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>

      {/* Bottom Bar */}
      <div class="mt-spacing-3xl pt-spacing-lg border-t border-border/30 flex flex-col items-center gap-3 md:flex-row md:justify-between">
        <p class="text-sm text-muted text-center md:text-left">{copyrightText}</p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-muted/40">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-muted hover:text-foreground"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          <button data-cookie-settings class="text-xs text-muted hover:text-foreground transition-colors">{cookieSettingsLabel}</button>
          <span class="text-xs text-muted">Made by <a href="https://hazelgrouse.pl" target="_blank" rel="noopener noreferrer" class="text-foreground font-medium hover:opacity-80 transition-opacity">Hazelgrouse Studio</a></span>
        </div>
      </div>

    </div>
  </footer>
)}

{variant === "stacked" && (
  <footer class="bg-background shrink-0">
    <div class="border-t border-border">
      <div class="container mx-auto py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <span class="font-bold text-2xl text-foreground tracking-tight block">{businessName}</span>
            {tagline && <p class="text-muted mt-2 max-w-md">{tagline}</p>}
          </div>
        </div>
      </div>
    </div>
    {effectiveColumns.length > 0 && (
      <div class="border-t border-border">
        <div class="container mx-auto py-8">
          <div class="flex flex-wrap justify-center gap-x-12 gap-y-6">
            {effectiveColumns.map((column) => (
              <div class="text-center">
                <h3 class="font-semibold text-foreground mb-3 text-sm uppercase tracking-wider">{column.title}</h3>
                <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2">
                  {column.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-muted hover:text-primary text-sm transition-colors">
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}
    <div class="border-t border-border bg-primary/5">
      <div class="container mx-auto py-6">
        <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
          <p class="text-sm text-muted text-center sm:text-left">{copyrightText}</p>
          <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
            {currentLanguage && (
              <div class="lang-switcher flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {languages.map((lang, i) => (
                  <>
                    {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                    <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                  </>
                ))}
              </div>
            )}
            <button data-cookie-settings class="text-xs text-muted hover:text-foreground transition-colors">{cookieSettingsLabel}</button>
            <span class="text-xs text-muted">Made by <a href="https://hazelgrouse.pl" target="_blank" rel="noopener noreferrer" class="text-foreground font-medium hover:opacity-80 transition-opacity">Hazelgrouse Studio</a></span>
          </div>
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "multiColumn" && (
  <footer class:list={["shrink-0", background?.enabled ? "p-4" : ""]}>
    <div
      class:list={["text-on-primary", !background?.gradient && "bg-secondary"]}
      style={[
        background?.gradient === "primary-to-primary-dark" ? "background: linear-gradient(to top, var(--primary-dark) 0%, var(--primary) 100%);" : "",
        background?.enabled ? `border-radius: ${background.borderRadius || '12px'};` : "",
      ].filter(Boolean).join(' ')}
    >
      <div class="container mx-auto py-spacing-2xl">
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-spacing-2xl lg:gap-spacing-3xl">
          <div class="md:col-span-1 lg:col-span-2">
            <div class="flex items-center gap-spacing-sm mb-spacing-md">
              {effectiveFooterIcon && <img src={effectiveFooterIcon} alt="" class="w-6 h-6 footer-logo-white" />}
              <span class="text-lg font-medium tracking-tight">{displayName}</span>
            </div>
            {tagline && <p class="text-on-primary/75 text-sm leading-relaxed font-heading max-w-xs">{tagline}</p>}
          </div>
          {effectiveColumns.map((column) => (
            <div>
              <h3 class="text-sm font-medium text-on-primary mb-spacing-md">{column.title}</h3>
              <ul class="space-y-spacing-sm">
                {column.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-on-primary/75 hover:text-on-primary text-sm transition-colors">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="mt-spacing-2xl pt-spacing-lg border-t border-on-primary/10 flex flex-col items-center gap-3 md:flex-row md:justify-between">
          <p class="text-sm text-on-primary/65 text-center md:text-left">{copyrightText}</p>
          <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
            {currentLanguage && (
              <div class="lang-switcher flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-on-primary/65"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {languages.map((lang, i) => (
