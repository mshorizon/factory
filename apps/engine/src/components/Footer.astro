---
interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface Props {
  businessName: string;
  links?: FooterLink[];
  columns?: FooterColumn[];
  copyright?: string;
  tagline?: string;
  currentLanguage?: string;
  variant?: "simple" | "multiColumn" | "minimal" | "centered" | "branded" | "stacked";
}

const {
  businessName,
  links = [],
  columns = [],
  copyright,
  tagline,
  currentLanguage,
  variant = "simple"
} = Astro.props;

const year = new Date().getFullYear();
const copyrightText = copyright || `© ${year} ${businessName}. All rights reserved.`;

const languages = [
  { code: "pl", label: "Polski" },
  { code: "en", label: "English" },
];

// Dark-bg variants use light tone, light-bg variants use dark tone
const isDark = ["simple", "multiColumn", "centered", "branded"].includes(variant);
---

{variant === "minimal" && (
  <footer class="bg-background border-t border-border shrink-0">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-muted">{copyrightText}</p>
        <div class="flex flex-wrap items-center gap-4">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex flex-wrap items-center gap-4">
              {links.map((link) => (
                <a href={link.href} class="text-sm text-muted hover:text-foreground transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "centered" && (
  <footer class="bg-secondary text-white shrink-0">
    <div class="container mx-auto px-4 py-16">
      <div class="flex flex-col items-center text-center">
        <span class="font-bold text-3xl tracking-tight mb-4">{businessName}</span>
        {tagline && <p class="text-white/70 text-lg max-w-md mb-8">{tagline}</p>}
        {links.length > 0 && (
          <nav class="flex flex-wrap justify-center gap-4 mb-8">
            {links.map((link) => (
              <a href={link.href} class="px-4 py-2 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-radius transition-colors">
                {link.label}
              </a>
            ))}
          </nav>
        )}
        <div class="w-24 h-px bg-white/20 mb-8"></div>
        {currentLanguage && (
          <div class="lang-switcher flex items-center gap-1.5 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            {languages.map((lang, i) => (
              <>
                {i > 0 && <span class="text-[10px] select-none text-white/20">/</span>}
                <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-white font-medium" : "text-white/40 hover:text-white/70"]}>{lang.label}</button>
              </>
            ))}
          </div>
        )}
        <p class="text-sm text-white/60">{copyrightText}</p>
      </div>
    </div>
  </footer>
)}

{variant === "branded" && (
  <footer class="bg-secondary text-white relative overflow-hidden shrink-0">
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary via-primary/50 to-primary"></div>
    <div class="container mx-auto px-4 py-16">
      <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8 mb-12">
        <div>
          <span class="font-bold text-4xl tracking-tight block mb-2">{businessName}</span>
          {tagline && <p class="text-white/70 text-lg max-w-md">{tagline}</p>}
        </div>
      </div>
      <div class="h-px bg-gradient-to-r from-primary/50 via-primary to-primary/50 mb-12"></div>
      {columns.length > 0 && (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-12">
          {columns.map((column) => (
            <div>
              <h3 class="font-semibold text-white mb-4 text-lg">{column.title}</h3>
              <ul class="space-y-3">
                {column.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-white/70 hover:text-primary text-sm transition-colors">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
      <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-white/60">{copyrightText}</p>
        <div class="flex items-center gap-6">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-white/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-white font-medium" : "text-white/40 hover:text-white/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex gap-6">
              {links.map((link) => (
                <a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "stacked" && (
  <footer class="bg-background shrink-0">
    <div class="border-t border-border">
      <div class="container mx-auto px-4 py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <span class="font-bold text-2xl text-foreground tracking-tight block">{businessName}</span>
            {tagline && <p class="text-muted mt-2 max-w-md">{tagline}</p>}
          </div>
        </div>
      </div>
    </div>
    {columns.length > 0 && (
      <div class="border-t border-border">
        <div class="container mx-auto px-4 py-8">
          <div class="flex flex-wrap justify-center gap-x-12 gap-y-6">
            {columns.map((column) => (
              <div class="text-center">
                <h3 class="font-semibold text-foreground mb-3 text-sm uppercase tracking-wider">{column.title}</h3>
                <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2">
                  {column.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-muted hover:text-primary text-sm transition-colors">
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}
    <div class="border-t border-border bg-primary/5">
      <div class="container mx-auto px-4 py-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-muted">{copyrightText}</p>
          <div class="flex items-center gap-6">
            {currentLanguage && (
              <div class="lang-switcher flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-foreground/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                {languages.map((lang, i) => (
                  <>
                    {i > 0 && <span class="text-[10px] select-none text-foreground/20">/</span>}
                    <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-foreground font-medium" : "text-foreground/40 hover:text-foreground/70"]}>{lang.label}</button>
                  </>
                ))}
              </div>
            )}
            {links.length > 0 && (
              <nav class="flex gap-6">
                {links.map((link) => (
                  <a href={link.href} class="text-muted hover:text-foreground text-sm transition-colors">
                    {link.label}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "multiColumn" && (
  <footer class="bg-secondary text-white shrink-0">
    <div class="container mx-auto px-4 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div class="lg:col-span-1">
          <span class="font-bold text-2xl tracking-tight block mb-4">{businessName}</span>
          {tagline && <p class="text-white/70 text-sm leading-relaxed">{tagline}</p>}
        </div>
        {columns.map((column) => (
          <div>
            <h3 class="font-semibold text-white mb-4">{column.title}</h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="text-white/70 hover:text-white text-sm transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-white/60">{copyrightText}</p>
        <div class="flex items-center gap-6">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-white/20">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-white font-medium" : "text-white/40 hover:text-white/70"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          {links.length > 0 && (
            <nav class="flex gap-4">
              {links.map((link) => (
                <a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          )}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "simple" && (
  <footer class="bg-secondary text-white shrink-0">
    <div class="container mx-auto px-4 py-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex flex-col items-center md:items-start gap-2">
          <span class="font-bold text-xl tracking-tight">{businessName}</span>
        </div>
        {links.length > 0 && (
          <nav class="flex flex-wrap justify-center gap-4">
            {links.map((link) => (
              <a href={link.href} class="px-4 py-2 text-sm text-white/80 hover:text-white hover:bg-white/10 rounded-radius transition-colors">
                {link.label}
              </a>
            ))}
          </nav>
        )}
      </div>
      <div class="mt-8 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-white/60">{copyrightText}</p>
        {currentLanguage && (
          <div class="lang-switcher flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/40"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            {languages.map((lang, i) => (
              <>
                {i > 0 && <span class="text-[10px] select-none text-white/20">/</span>}
                <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-white font-medium" : "text-white/40 hover:text-white/70"]}>{lang.label}</button>
              </>
            ))}
          </div>
        )}
      </div>
    </div>
  </footer>
)}

<script>
  document.querySelectorAll('.lang-btn').forEach((button) => {
    button.addEventListener('click', () => {
      const lang = (button as HTMLElement).dataset.lang;
      if (lang) {
        document.cookie = `lang=${lang};path=/;max-age=31536000;SameSite=Lax`;
        window.location.href = window.location.pathname;
      }
    });
  });
</script>
