        {/* Opening Hours Column */}
        <div>
          {hoursTitle && <h3 class="text-xs uppercase tracking-[0.2em] text-muted mb-spacing-lg">{hoursTitle}</h3>}
          {hours.length > 0 && (
            <ul class="space-y-spacing-sm">
              {hours.map((row) => (
                <li class="flex items-baseline justify-between gap-spacing-lg text-sm">
