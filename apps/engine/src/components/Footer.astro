)}

{variant === "restaurant" && (
  <footer
    class:list={["border-t border-border/40 shrink-0", !background?.color && "bg-background"]}
    style={background?.color ? `background-color: ${background.color};` : undefined}
  >
    <div class="container mx-auto py-spacing-3xl">
      <div class="grid grid-cols-1 gap-spacing-2xl lg:grid-cols-3 lg:gap-spacing-3xl">

        {/* Brand Column */}
