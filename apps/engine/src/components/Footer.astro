      {/* Bottom Bar */}
      <div class="mt-spacing-3xl pt-8 border-t border-white/10 flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
        <p class="text-sm text-white/60 text-center sm:text-left">{copyrightText}</p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          {currentLanguage && (
            <div class="lang-switcher flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/60"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              {languages.map((lang, i) => (
                <>
                  {i > 0 && <span class="text-[10px] select-none text-white/40">/</span>}
                  <button data-lang={lang.code} class:list={["lang-btn text-xs transition-colors", currentLanguage === lang.code ? "text-white font-medium" : "text-white/60 hover:text-white"]}>{lang.label}</button>
                </>
              ))}
            </div>
          )}
          <button data-cookie-settings class="text-xs text-white/60 hover:text-white transition-colors">{cookieSettingsLabel}</button>
          <span class="text-xs text-white/60">Made by <a href="https://hazelgrouse.pl" target="_blank" rel="noopener noreferrer" class="text-white font-medium hover:opacity-80 transition-opacity">Hazelgrouse Studio</a></span>
        </div>
