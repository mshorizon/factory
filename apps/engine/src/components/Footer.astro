                      />
                    ))}
                  </div>
                </>
              )}
            </div>
          ))}
        </div>

        {/* Bottom Bar */}
        <div class="mt-spacing-2xl pt-spacing-lg border-t border-on-primary/10 flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center">
          <p class="text-sm text-on-primary/65">{copyrightText}</p>
          {tagline && <span class="text-sm text-on-primary/50 italic">{tagline}</span>}
        </div>
      </div>
    </div>
  </footer>
)}

{variant === "gradient" && (
