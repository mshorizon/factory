  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: var(--footer-cols, 1fr);
    }
  }
  /* Force footer logo icon to render in white — footers sit on dark surfaces */
  .footer-logo-white {
    filter: brightness(0) invert(1);
