---
// OverlayScrollbar - Initializes overlay scrollbars on the document body
---

<script>
  import { OverlayScrollbars } from 'overlayscrollbars';

  const options = {
    scrollbars: {
      theme: 'os-theme-dark',
      autoHide: 'scroll',
      autoHideDelay: 800,
      clickScroll: true,
    },
    overflow: {
      x: 'hidden',
    },
  };

  // Initialize immediately (script runs when parsed)
  function initScrollbar() {
    const instance = OverlayScrollbars(document.body);
    if (!instance) {
      OverlayScrollbars(document.body, options);
    }
  }

  // Skip on pages with a full-viewport hero (.hero-fold). OverlayScrollbars
  // wraps document.body and re-parents every child into a new viewport <div>;
  // that re-parent restarts every running CSS animation in the page — the
  // user sees the hero text/image animate, the body gets wrapped, then the
  // animations replay from t=0. Pages without a full-viewport hero are
  // unaffected and still get the custom scrollbars.
  function shouldSkip() {
    return !!document.querySelector('section.hero-fold');
  }

  function safeInit() {
    if (shouldSkip()) return;
    initScrollbar();
  }

  // Initialize as soon as body is available
  if (document.body) {
    safeInit();
  } else {
    document.addEventListener('DOMContentLoaded', safeInit);
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:before-swap', () => {
    // Destroy existing instance before page swap
    const instance = OverlayScrollbars(document.body);
    if (instance) {
      instance.destroy();
    }
  });

  document.addEventListener('astro:page-load', safeInit);
</script>
