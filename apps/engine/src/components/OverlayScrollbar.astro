---
// OverlayScrollbar - Initializes overlay scrollbars on the document body
---

<script>
  import { OverlayScrollbars } from 'overlayscrollbars';

  const options = {
    scrollbars: {
      theme: 'os-theme-dark',
      autoHide: 'scroll',
      autoHideDelay: 800,
      clickScroll: true,
    },
    overflow: {
      x: 'hidden',
    },
  };

  // Initialize immediately (script runs when parsed)
  function initScrollbar() {
    const instance = OverlayScrollbars(document.body);
    if (!instance) {
      OverlayScrollbars(document.body, options);
    }
  }

  // Opt-out signal: BaseLayout's `noCustomScrollbars` prop renders
  // `data-no-custom-scrollbars` on <body>. OverlayScrollbars wraps
  // document.body and re-parents every child into a new viewport <div>;
  // that re-parent restarts every running CSS animation, which corrupts
  // any above-the-fold reveal (e.g. the full-viewport hero's bg-zoom and
  // text fade). Pages that haven't set the attribute still get the
  // custom scrollbars.
  function shouldSkip() {
    return !!document.body && document.body.hasAttribute('data-no-custom-scrollbars');
  }

  function safeInit() {
    if (shouldSkip()) return;
    initScrollbar();
  }

  // Initialize as soon as body is available
  if (document.body) {
    safeInit();
  } else {
    document.addEventListener('DOMContentLoaded', safeInit);
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:before-swap', () => {
    // Destroy existing instance before page swap
    const instance = OverlayScrollbars(document.body);
    if (instance) {
      instance.destroy();
    }
  });

  document.addEventListener('astro:page-load', safeInit);
</script>
