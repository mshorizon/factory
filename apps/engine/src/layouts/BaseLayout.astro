---
import "../styles/global.css";
import type { ThemeV15 } from "@mshorizon/schema";
import OverlayScrollbar from "../components/OverlayScrollbar.astro";
import ScrollToTopButton from "../components/ScrollToTopButton.astro";

// v1.0 Theme structure (legacy)
interface ThemeV10 {
  colors: {
    primary: string;
    secondary: string;
    accent?: string;
    background: string;
    foreground: string;
    muted?: string;
    border?: string;
  };
  typography?: {
    fontFamily?: {
      sans?: string;
      heading?: string;
    };
  };
  borderRadius?: {
    small?: string;
    default?: string;
    large?: string;
    full?: string;
  };
  shadows?: {
    small?: string;
    default?: string;
    large?: string;
  };
}

// Combined theme type that supports both versions
type Theme = ThemeV10 | ThemeV15;

interface Props {
  title: string;
  theme: Theme;
  favicon?: string;
}

const { title, theme, favicon } = Astro.props;

// Helper to detect if theme is v1.5
function isThemeV15(t: Theme): t is ThemeV15 {
  return 'mode' in t && 'colors' in t && 'light' in (t as ThemeV15).colors;
}

// Extract CSS variables based on theme version
let cssVars: Record<string, string>;

if (isThemeV15(theme)) {
  // v1.5 theme structure
  const colors = theme.colors.light;
  cssVars = {
    primary: colors.primary,
    secondary: colors.surface.alt,
    accent: colors.primary,
    background: colors.surface.base,
    foreground: colors.text.main,
    muted: colors.text.muted,
    border: colors.text.muted + "40", // Add alpha for border
    textOnPrimary: colors.text.onPrimary,
    radiusSm: "0.25rem",
    radius: theme.ui.radius,
    radiusLg: "1rem",
    radiusFull: "9999px",
    shadowSm: "0 1px 2px rgba(0,0,0,0.05)",
    shadow: "0 4px 6px rgba(0,0,0,0.1)",
    shadowLg: "0 10px 25px rgba(0,0,0,0.15)",
    fontSans: theme.typography.primary,
    fontHeading: theme.typography.secondary || theme.typography.primary,
  };
} else {
  // v1.0 theme structure (legacy)
  cssVars = {
    primary: theme.colors.primary,
    secondary: theme.colors.secondary,
    accent: theme.colors.accent || theme.colors.primary,
    background: theme.colors.background,
    foreground: theme.colors.foreground,
    muted: theme.colors.muted || "#64748b",
    border: theme.colors.border || "#e2e8f0",
    textOnPrimary: "#ffffff",
    radiusSm: theme.borderRadius?.small || "0.25rem",
    radius: theme.borderRadius?.default || "0.5rem",
    radiusLg: theme.borderRadius?.large || "1rem",
    radiusFull: theme.borderRadius?.full || "9999px",
    shadowSm: theme.shadows?.small || "0 1px 2px rgba(0,0,0,0.05)",
    shadow: theme.shadows?.default || "0 4px 6px rgba(0,0,0,0.1)",
    shadowLg: theme.shadows?.large || "0 10px 25px rgba(0,0,0,0.15)",
    fontSans: theme.typography?.fontFamily?.sans || "system-ui, -apple-system, sans-serif",
    fontHeading: theme.typography?.fontFamily?.heading || "system-ui, -apple-system, sans-serif",
  };
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    {favicon && <link rel="icon" href={favicon} />}
    {!favicon && <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style define:vars={cssVars}>
      :root {
        --primary: var(--primary);
        --secondary: var(--secondary);
        --accent: var(--accent);
        --background: var(--background);
        --foreground: var(--foreground);
        --muted: var(--muted);
        --border: var(--border);
        --text-on-primary: var(--textOnPrimary);
        --radius-sm: var(--radiusSm);
        --radius: var(--radius);
        --radius-lg: var(--radiusLg);
        --radius-full: var(--radiusFull);
        --shadow-sm: var(--shadowSm);
        --shadow: var(--shadow);
        --shadow-lg: var(--shadowLg);
        --font-sans: var(--fontSans);
        --font-heading: var(--fontHeading);
      }
      html, body {
        height: 100%;
      }
      body {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--foreground);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }
    </style>
  </head>
  <body class="flex flex-col min-h-screen" data-overlayscrollbars-initialize>
    <slot />
    <ScrollToTopButton />
    <OverlayScrollbar />
  </body>
</html>
