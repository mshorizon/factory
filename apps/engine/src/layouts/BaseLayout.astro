---
import "../styles/global.css";
import type { Theme } from "@mshorizon/schema";
import ScrollToTopButton from "../components/ScrollToTopButton.astro";
import OverlayScrollbar from "../components/OverlayScrollbar.astro";

interface Props {
  title: string;
  theme: Theme;
  favicon?: string;
  lang?: string;
}

const { title, theme, favicon, lang = "en" } = Astro.props;

// Helper function to darken a hex color
function darkenColor(hex: string, percent: number = 35): string {
  const num = parseInt(hex.replace("#", ""), 16);
  const r = Math.max(0, Math.floor((num >> 16) * (1 - percent / 100)));
  const g = Math.max(0, Math.floor(((num >> 8) & 0x00FF) * (1 - percent / 100)));
  const b = Math.max(0, Math.floor((num & 0x0000FF) * (1 - percent / 100)));
  return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, "0");
}

// Extract CSS variables from theme
const colors = theme.mode === "dark" && theme.colors?.dark ? theme.colors.dark : theme.colors?.light;
const darkColors = theme.colors?.dark || {
  primary: colors?.primary,
  surface: { base: "#16181D", alt: "#2D2F34" },
  text: { main: "#FFFFFF", muted: "#9CA3AF", onPrimary: colors?.text?.onPrimary },
};

// Helper function to calculate 1/4 of a CSS unit
function divideRadius(radius: string, divisor: number = 4): string {
  const match = radius.match(/^([\d.]+)(.*)$/);
  if (!match) return radius;
  const value = parseFloat(match[1]) / divisor;
  const unit = match[2] || 'rem';
  return `${value}${unit}`;
}

const cssVars: Record<string, string> = {
  primary: colors?.primary || "#0066CC",
  primaryDark: (colors as any)?.primaryDark || darkenColor(colors?.primary || "#0066CC"),
  secondary: colors?.surface?.alt || "#003D7A",
  accent: colors?.primary || "#0066CC",
  background: colors?.surface?.base || "#F8FAFC",
  foreground: colors?.text?.main || "#0F172A",
  muted: colors?.text?.muted || "#64748B",
  border: (colors?.text?.muted || "#64748B") + "40",
  textOnPrimary: colors?.text?.onPrimary || "#FFFFFF",
  darkBackground: darkColors.surface?.base || "#16181D",
  darkForeground: darkColors.text?.main || "#FFFFFF",
  darkMuted: darkColors.text?.muted || "#9CA3AF",
  darkBorder: (darkColors.text?.muted || "#9CA3AF") + "40",
  radiusSm: "0.25rem",
  radius: theme.ui?.radius || "0.5rem",
  radiusSecondary: divideRadius(theme.ui?.radius || "0.5rem", 4),
  radiusLg: "1rem",
  radiusFull: "9999px",
  shadowSm: "0 1px 2px rgba(0,0,0,0.05)",
  shadow: "0 4px 6px rgba(0,0,0,0.1)",
  shadowLg: "0 10px 25px rgba(0,0,0,0.15)",
  fontSans: theme.typography?.primary || "system-ui, -apple-system, sans-serif",
  fontHeading: theme.typography?.secondary || theme.typography?.primary || "system-ui, -apple-system, sans-serif",
  headingTransform: theme.preset === "bold" ? "uppercase" : "none",
  headingLetterSpacing: theme.preset === "bold" ? "-0.02em" : "normal",
};

// Extract Google Font names from font-family strings
function extractGoogleFonts(...fontStrings: string[]): string[] {
  const systemFonts = new Set(['system-ui', '-apple-system', 'sans-serif', 'serif', 'monospace', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial']);
  const fonts = new Set<string>();
  for (const str of fontStrings) {
    for (const part of str.split(',')) {
      const name = part.trim().replace(/^['"]|['"]$/g, '');
      if (name && !systemFonts.has(name)) {
        fonts.add(name);
      }
    }
  }
  return [...fonts];
}

const googleFonts = extractGoogleFonts(cssVars.fontSans, cssVars.fontHeading);
const googleFontsUrl = googleFonts.length > 0
  ? `https://fonts.googleapis.com/css2?${googleFonts.map(f => `family=${f.replace(/ /g, '+')}:wght@400;500;600;700;800`).join('&')}&display=swap`
  : null;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    {favicon && <link rel="icon" href={favicon} />}
    {!favicon && <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {googleFontsUrl && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link rel="stylesheet" href={googleFontsUrl} />
    )}
    <title>{title}</title>
    <style define:vars={cssVars}>
      :root {
        --primary: var(--primary);
        --primary-dark: var(--primaryDark);
        --secondary: var(--secondary);
        --accent: var(--accent);
        --background: var(--background);
        --foreground: var(--foreground);
        --muted: var(--muted);
        --border: var(--border);
        --text-on-primary: var(--textOnPrimary);
        --dark-background: var(--darkBackground);
        --dark-foreground: var(--darkForeground);
        --dark-muted: var(--darkMuted);
        --dark-border: var(--darkBorder);
        --radius-sm: var(--radiusSm);
        --radius: var(--radius);
        --radius-secondary: var(--radiusSecondary);
        --radius-lg: var(--radiusLg);
        --radius-full: var(--radiusFull);
        --shadow-sm: var(--shadowSm);
        --shadow: var(--shadow);
        --shadow-lg: var(--shadowLg);
        --font-sans: var(--fontSans);
        --font-heading: var(--fontHeading);
        --heading-transform: var(--headingTransform);
        --heading-letter-spacing: var(--headingLetterSpacing);
      }
      html, body {
        height: 100%;
      }
      body {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--foreground);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }
    </style>
    <style is:global>
      h1, h2 {
        text-transform: var(--heading-transform);
        letter-spacing: var(--heading-letter-spacing);
      }
      .section-bg-dark {
        --background: var(--dark-background);
        --foreground: var(--dark-foreground);
        --muted: var(--dark-muted);
        --border: var(--dark-border);
        background-color: var(--background);
        color: var(--foreground);
      }
      .section-bg-primary {
        --background: var(--primary);
        --foreground: var(--text-on-primary);
        --muted: var(--text-on-primary);
        background-color: var(--primary);
        color: var(--foreground);
      }
    </style>
  </head>
  <body class="flex flex-col min-h-screen" data-overlayscrollbars-initialize>
    <slot />
    <ScrollToTopButton />
    <OverlayScrollbar />
    <script is:inline>
      // Preview iframe enhancements - only active inside preview iframe
      if (window.parent !== window) {
        // Preserve _preview=1 on all same-origin navigation
        document.addEventListener('click', function(e) {
          var anchor = e.target.closest ? e.target.closest('a') : null;
          if (!anchor || !anchor.href) return;
          try {
            var url = new URL(anchor.href, window.location.origin);
            if (url.origin !== window.location.origin) return;
            if (url.searchParams.get('_preview') === '1') return;
            e.preventDefault();
            url.searchParams.set('_preview', '1');
            window.location.href = url.toString();
          } catch (err) {}
        });
        var overlay = null;
        function getOverlay() {
          if (!overlay) {
            overlay = document.createElement('div');
            overlay.id = 'section-highlight-overlay';
            overlay.style.cssText = 'position:absolute;pointer-events:none;z-index:9999;border:2px solid #3b82f6;background:rgba(59,130,246,0.08);border-radius:4px;transition:opacity 0.15s;opacity:0;';
            document.body.appendChild(overlay);
          }
          return overlay;
        }
        function positionOverlay(el) {
          var ov = getOverlay();
          el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          var rect = el.getBoundingClientRect();
          ov.style.top = (rect.top + window.scrollY) + 'px';
          ov.style.left = (rect.left + window.scrollX) + 'px';
          ov.style.width = rect.width + 'px';
          ov.style.height = rect.height + 'px';
          ov.style.opacity = '1';
        }
        window.addEventListener('message', function(e) {
          if (!e.data || e.data.source !== 'admin-panel') return;
          var ov = getOverlay();
          if (e.data.type === 'highlight-field') {
            var sectionEl = document.querySelector('[data-section-index="' + e.data.index + '"]');
            if (!sectionEl) return;
            // Try field-level first, then fall back to section
            var el = sectionEl.querySelector('[data-field="' + e.data.field + '"]');
            positionOverlay(el || sectionEl);
          } else if (e.data.type === 'highlight-section') {
            var el = document.querySelector('[data-section-index="' + e.data.index + '"]');
            if (el) positionOverlay(el);
          } else if (e.data.type === 'clear-highlight') {
            ov.style.opacity = '0';
          }
        });
      }
    </script>
  </body>
</html>
