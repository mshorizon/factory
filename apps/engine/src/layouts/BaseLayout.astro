---
import "../styles/global.css";
import type { Theme } from "@mshorizon/schema";
import ScrollToTopButton from "../components/ScrollToTopButton.astro";
import OverlayScrollbar from "../components/OverlayScrollbar.astro";
import CookieConsentBanner from "../components/CookieConsentBanner.astro";
import SmoothScroll from "../components/SmoothScroll.astro";

interface Props {
  title: string;
  theme: Theme;
  favicon?: string;
  lang?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  siteName?: string;
  jsonLd?: object | object[];
}

const { title, theme, favicon, lang = "en", description, canonical, ogImage, ogType = 'website', siteName, jsonLd } = Astro.props;

// Umami analytics - skip in preview mode and when not configured
const isPreview = Astro.url.searchParams.get("_preview") === "1";
const umamiWebsiteId = Astro.locals.site?.umamiWebsiteId;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;

// Helper function to darken a hex color
function darkenColor(hex: string, percent: number = 35): string {
  const num = parseInt(hex.replace("#", ""), 16);
  const r = Math.max(0, Math.floor((num >> 16) * (1 - percent / 100)));
  const g = Math.max(0, Math.floor(((num >> 8) & 0x00FF) * (1 - percent / 100)));
  const b = Math.max(0, Math.floor((num & 0x0000FF) * (1 - percent / 100)));
  return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, "0");
}

// Extract CSS variables from theme
const colors = theme.mode === "dark" && theme.colors?.dark ? theme.colors.dark : theme.colors?.light;
const darkColors = theme.colors?.dark || {
  primary: colors?.primary,
  surface: { base: "#16181D", alt: "#2D2F34" },
  text: { main: "#FFFFFF", muted: "#9CA3AF", onPrimary: colors?.text?.onPrimary },
};

// Helper function to calculate 1/4 of a CSS unit
function divideRadius(radius: string, divisor: number = 4): string {
  const match = radius.match(/^([\d.]+)(.*)$/);
  if (!match) return radius;
  const value = parseFloat(match[1]) / divisor;
  const unit = match[2] || 'rem';
  return `${value}${unit}`;
}

const cssVars: Record<string, string> = {
  primary: colors?.primary || "#0066CC",
  primaryDark: (colors as any)?.primaryDark || darkenColor(colors?.primary || "#0066CC"),
  secondary: colors?.surface?.alt || "#003D7A",
  accent: colors?.primary || "#0066CC",
  background: colors?.surface?.base || "#F8FAFC",
  card: colors?.surface?.card || "#FAFAFA",
  foreground: colors?.text?.main || "#0F172A",
  muted: colors?.text?.muted || "#64748B",
  border: (colors?.text?.muted || "#64748B") + "40",
  textOnPrimary: colors?.text?.onPrimary || "#FFFFFF",
  darkBackground: darkColors.surface?.base || "#16181D",
  darkCard: darkColors.surface?.card || "#1C1E23",
  darkForeground: darkColors.text?.main || "#FFFFFF",
  darkMuted: darkColors.text?.muted || "#9CA3AF",
  darkBorder: (darkColors.text?.muted || "#9CA3AF") + "40",
  radiusSm: "0.25rem",
  radius: theme.ui?.radius || "0.5rem",
  radiusSecondary: divideRadius(theme.ui?.radius || "0.5rem", 4),
  radiusLg: "1rem",
  radiusFull: "9999px",
  shadowSm: "0 1px 2px rgba(0,0,0,0.05)",
  shadow: "0 4px 6px rgba(0,0,0,0.1)",
  shadowLg: "0 10px 25px rgba(0,0,0,0.15)",
  fontSans: theme.typography?.primary || "system-ui, -apple-system, sans-serif",
  fontHeading: theme.typography?.secondary || theme.typography?.primary || "system-ui, -apple-system, sans-serif",
  headingTransform: theme.preset === "bold" ? "uppercase" : "none",
  headingLetterSpacing: theme.preset === "bold" ? "-0.02em" : "normal",
  headingWeight: (theme as any).headingWeight || "700",
  navFontSize: (theme as any).navFontSize || "16px",
  navLogoSize: (theme as any).navLogoSize || "24px",
  navLogoWeight: (theme as any).navLogoWeight || "600",
  spacingXs: theme.ui?.spacing?.xs || "0.5rem",
  spacingSm: theme.ui?.spacing?.sm || "0.75rem",
  spacingMd: theme.ui?.spacing?.md || "1rem",
  spacingLg: theme.ui?.spacing?.lg || "1.5rem",
  spacingXl: theme.ui?.spacing?.xl || "2rem",
  spacing2xl: theme.ui?.spacing?.["2xl"] || "3rem",
  spacing3xl: theme.ui?.spacing?.["3xl"] || "4rem",
  spacingSectionSm: theme.ui?.spacing?.["section-sm"] || "5rem",
  spacingSection: theme.ui?.spacing?.section || "10rem",
  spacingContainer: theme.ui?.spacing?.container || "2.5rem",
};

// Extract Google Font names from font-family strings
function extractGoogleFonts(...fontStrings: string[]): string[] {
  const systemFonts = new Set(['system-ui', '-apple-system', 'sans-serif', 'serif', 'monospace', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial']);
  const fonts = new Set<string>();
  for (const str of fontStrings) {
    for (const part of str.split(',')) {
      const name = part.trim().replace(/^['"]|['"]$/g, '');
      if (name && !systemFonts.has(name)) {
        fonts.add(name);
      }
    }
  }
  return [...fonts];
}

const googleFonts = extractGoogleFonts(cssVars.fontSans, cssVars.fontHeading);
const googleFontsUrl = googleFonts.length > 0
  ? `https://fonts.googleapis.com/css2?${googleFonts.map(f => `family=${f.replace(/ /g, '+')}:wght@400;500;600;700;800`).join('&')}&display=swap`
  : null;

// CSS vars as inline style on <html> to win over :root in global.css (inline > stylesheet specificity).
// Layout rules go in a separate <style> tag.
const htmlStyle = `--primary:${cssVars.primary};--primary-dark:${cssVars.primaryDark};--secondary:${cssVars.secondary};--accent:${cssVars.accent};--background:${cssVars.background};--card:${cssVars.card};--foreground:${cssVars.foreground};--muted:${cssVars.muted};--border:${cssVars.border};--text-on-primary:${cssVars.textOnPrimary};--dark-background:${cssVars.darkBackground};--dark-card:${cssVars.darkCard};--dark-foreground:${cssVars.darkForeground};--dark-muted:${cssVars.darkMuted};--dark-border:${cssVars.darkBorder};--radius-sm:${cssVars.radiusSm};--radius:${cssVars.radius};--radius-secondary:${cssVars.radiusSecondary};--radius-lg:${cssVars.radiusLg};--radius-full:${cssVars.radiusFull};--shadow-sm:${cssVars.shadowSm};--shadow:${cssVars.shadow};--shadow-lg:${cssVars.shadowLg};--font-sans:${cssVars.fontSans};--font-heading:${cssVars.fontHeading};--heading-transform:${cssVars.headingTransform};--heading-letter-spacing:${cssVars.headingLetterSpacing};--spacing-xs:${cssVars.spacingXs};--spacing-sm:${cssVars.spacingSm};--spacing-md:${cssVars.spacingMd};--spacing-lg:${cssVars.spacingLg};--spacing-xl:${cssVars.spacingXl};--spacing-2xl:${cssVars.spacing2xl};--spacing-3xl:${cssVars.spacing3xl};--spacing-section-sm:${cssVars.spacingSectionSm};--spacing-section:${cssVars.spacingSection};--spacing-container:${cssVars.spacingContainer};--heading-weight:${cssVars.headingWeight};--nav-font-size:${cssVars.navFontSize};--nav-logo-size:${cssVars.navLogoSize};--nav-logo-weight:${cssVars.navLogoWeight}`;
---

<html lang={lang} style={htmlStyle} data-badge-variant={(theme as any).badgeVariant || "accent"} data-nav-links-position={(theme as any).navLinksPosition || "center"} class={(() => { const st = (theme as any).scrollType; return st === 'momentum' ? 'scroll-momentum' : st === 'smooth' ? 'scroll-smooth' : ''; })()}>
  <head>
    <meta charset="utf-8" />
    {favicon && <link rel="icon" href={favicon} />}
    {!favicon && <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {canonical && <meta property="og:url" content={canonical} />}
    {siteName && <meta property="og:site_name" content={siteName} />}
    <meta property="og:locale" content={lang === 'pl' ? 'pl_PL' : 'en_US'} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <!-- JSON-LD Structured Data -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="manifest" href="/api/manifest.webmanifest" />
    {googleFontsUrl && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link rel="preload" href={googleFontsUrl} as="style" />
      <link rel="stylesheet" href={googleFontsUrl} media="print" onload="this.media='all'" />
      <noscript><link rel="stylesheet" href={googleFontsUrl} /></noscript>
    )}
    <title>{title}</title>
    <style>html,body{height:100%}body{font-family:var(--font-sans);background-color:var(--background);color:var(--foreground);display:flex;flex-direction:column;min-height:100vh}main{flex:1}</style>
    <style is:global>
      h1, h2 {
        text-transform: var(--heading-transform);
        letter-spacing: var(--heading-letter-spacing);
      }
      .section-bg-dark {
        --background: var(--dark-background);
        --card: var(--dark-card);
        --foreground: var(--dark-foreground);
        --muted: var(--dark-muted);
        --border: var(--dark-border);
        background-color: var(--background);
        color: var(--foreground);
      }
      .section-bg-primary {
        --background: var(--primary);
        --foreground: var(--text-on-primary);
        --muted: var(--text-on-primary);
        background-color: var(--primary);
        color: var(--foreground);
      }
    </style>
    {!isPreview && umamiWebsiteId && umamiUrl && (
      <script define:vars={{ umamiUrl, umamiWebsiteId }} is:inline>
        (function () {
          function loadUmami() {
            if (document.querySelector('script[data-website-id]')) return;
            var s = document.createElement('script');
            s.defer = true;
            s.src = umamiUrl + '/script.js';
            s.setAttribute('data-website-id', umamiWebsiteId);
            document.head.appendChild(s);
          }

          function checkConsent() {
            try {
              var consent = JSON.parse(localStorage.getItem('cookie-consent') || 'null');
              if (consent && consent.analytics) loadUmami();
            } catch (e) {}
          }

          // Check on load
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', checkConsent);
          } else {
            checkConsent();
          }

          // Re-check when consent is saved (CookieConsent dispatches storage event)
          window.addEventListener('storage', function (e) {
            if (e.key === 'cookie-consent') checkConsent();
          });
        })();
      </script>
    )}
  </head>
  <body class="flex flex-col min-h-screen" data-overlayscrollbars-initialize>
    <slot />
    <ScrollToTopButton />
    <OverlayScrollbar />
    <CookieConsentBanner />
    <SmoothScroll />
    <script is:inline>
      // Register Service Worker for PWA support
      if ('serviceWorker' in navigator && window.parent === window) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
      (function() {
        var els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = el.getAttribute('data-reveal-delay') || '0';
              el.style.setProperty('--reveal-delay', delay + 'ms');
              el.classList.add('is-visible');
              observer.unobserve(el);
            }
          });
        }, { rootMargin: '-60px 0px' });
        els.forEach(function(el) { observer.observe(el); });
      })();
    </script>
    <script is:inline>
      // Preview iframe enhancements - only active inside preview iframe
      if (window.parent !== window) {
        // Preserve _preview=1 on all same-origin navigation
        document.addEventListener('click', function(e) {
          var anchor = e.target.closest ? e.target.closest('a') : null;
          if (!anchor || !anchor.href) return;
          try {
            var url = new URL(anchor.href, window.location.origin);
            if (url.origin !== window.location.origin) return;
            if (url.searchParams.get('_preview') === '1') return;
            e.preventDefault();
            url.searchParams.set('_preview', '1');
            window.location.href = url.toString();
          } catch (err) {}
        });
        var overlay = null;
        function getOverlay() {
          if (!overlay) {
            overlay = document.createElement('div');
            overlay.id = 'section-highlight-overlay';
            overlay.style.cssText = 'position:absolute;pointer-events:none;z-index:9999;border:2px solid #3b82f6;background:rgba(59,130,246,0.08);border-radius:4px;transition:opacity 0.15s;opacity:0;';
            document.body.appendChild(overlay);
          }
          return overlay;
        }
        function positionOverlay(el) {
          var ov = getOverlay();
          el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          var rect = el.getBoundingClientRect();
          ov.style.top = (rect.top + window.scrollY) + 'px';
          ov.style.left = (rect.left + window.scrollX) + 'px';
          ov.style.width = rect.width + 'px';
          ov.style.height = rect.height + 'px';
          ov.style.opacity = '1';
        }
        window.addEventListener('message', function(e) {
          if (!e.data || e.data.source !== 'admin-panel') return;
          var ov = getOverlay();
          if (e.data.type === 'highlight-field') {
            var sectionEl = document.querySelector('[data-section-index="' + e.data.index + '"]');
            if (!sectionEl) return;
            // Try field-level first, then fall back to section
            var el = sectionEl.querySelector('[data-field="' + e.data.field + '"]');
            positionOverlay(el || sectionEl);
          } else if (e.data.type === 'highlight-section') {
            var el = document.querySelector('[data-section-index="' + e.data.index + '"]');
            if (el) positionOverlay(el);
          } else if (e.data.type === 'clear-highlight') {
            ov.style.opacity = '0';
          }
        });
      }
    </script>
  </body>
</html>
