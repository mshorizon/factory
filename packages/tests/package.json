{
  "name": "@mshorizon/tests",
  "version": "1.0.0",
  "description": "Visual regression and validation tests",
  "type": "module",
  "scripts": {
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:update": "playwright test --update-snapshots",
    "test:validate": "tsx src/validate-templates.ts",
    "test": "pnpm run test:validate && pnpm run test:visual"
  },
  "dependencies": {
    "@mshorizon/db": "workspace:*",
    "@mshorizon/schema": "workspace:*",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
