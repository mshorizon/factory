{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mshorizon.com/schemas/business-v15.schema.json",
  "title": "BusinessProfile V1.5",
  "type": "object",
  "definitions": {
    "target": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["page", "phone", "external"],
          "title": "Target Type"
        },
        "value": { "type": "string", "title": "Target Value" }
      }
    },
    "cta": {
      "type": "object",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "link": {
      "type": "object",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "footerColumn": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "title": "Column Title" },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/link" }
        }
      }
    },
    "sectionHeader": {
      "type": "object",
      "properties": {
        "badge": { "type": "string", "title": "Badge Text" },
        "title": { "type": "string", "title": "Title" },
        "subtitle": { "type": "string", "title": "Subtitle" }
      }
    },
    "section": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "title": "Section Type",
          "enum": ["hero", "services", "categories", "about", "contact", "shop", "gallery", "testimonials"]
        },
        "variant": { "type": "string", "title": "Variant" },
        "header": { "$ref": "#/definitions/sectionHeader" },
        "backgroundImage": { "type": "string", "title": "Background Image URL" },
        "image": { "type": "string", "title": "Image URL" },
        "cta": { "$ref": "#/definitions/cta" },
        "secondaryCta": { "$ref": "#/definitions/cta" },
        "items": {
          "type": "array",
          "title": "Items",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" },
              "icon": { "type": "string" },
              "image": { "type": "string" }
            }
          }
        },
        "story": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "commitment": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "info": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "hours": { "type": "string" }
          }
        },
        "form": {
          "type": "object",
          "properties": {
            "namePlaceholder": { "type": "string" },
            "emailPlaceholder": { "type": "string" },
            "messagePlaceholder": { "type": "string" },
            "submitButton": { "type": "string" }
          }
        }
      },
      "required": ["type"]
    },
    "page": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "title": "Page Title" },
        "sections": {
          "type": "array",
          "title": "Sections",
          "items": { "$ref": "#/definitions/section" }
        }
      },
      "required": ["title", "sections"]
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "string",
      "title": "Schema Version",
      "default": "1.5",
      "const": "1.5"
    },
    "business": {
      "type": "object",
      "title": "Business Information",
      "properties": {
        "id": { "type": "string", "title": "Business ID" },
        "name": { "type": "string", "title": "Business Name" },
        "industry": {
          "type": "string",
          "title": "Industry",
          "enum": ["plumber", "barber", "restaurant", "shop", "service", "specialist"]
        },
        "assets": {
          "type": "object",
          "title": "Assets",
          "properties": {
            "favicon": { "type": "string", "title": "Favicon URL" },
            "logo": { "type": "string", "title": "Logo URL" }
          }
        },
        "contact": {
          "type": "object",
          "title": "Contact Information",
          "properties": {
            "address": { "type": "string", "title": "Address" },
            "phone": { "type": "string", "title": "Phone" },
            "email": { "type": "string", "format": "email", "title": "Email" },
            "hours": { "type": "string", "title": "Business Hours" }
          }
        }
      },
      "required": ["id", "name", "industry"]
    },
    "theme": {
      "type": "object",
      "title": "Theme Settings",
      "properties": {
        "preset": {
          "type": "string",
          "title": "Theme Preset",
          "enum": ["industrial", "wellness", "minimal", "elegant", "modern", "classic", "bold"]
        },
        "mode": {
          "type": "string",
          "title": "Color Mode",
          "enum": ["light", "dark"],
          "default": "light"
        },
        "colors": {
          "type": "object",
          "title": "Color Schemes",
          "properties": {
            "light": {
              "type": "object",
              "title": "Light Mode Colors",
              "properties": {
                "primary": {
                  "type": "string",
                  "title": "Primary Color",
                  "pattern": "^#[0-9A-Fa-f]{6}$",
                  "default": "#0066CC"
                },
                "surface": {
                  "type": "object",
                  "title": "Surface Colors",
                  "properties": {
                    "base": {
                      "type": "string",
                      "title": "Base Surface",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    },
                    "alt": {
                      "type": "string",
                      "title": "Alt Surface",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    }
                  }
                },
                "text": {
                  "type": "object",
                  "title": "Text Colors",
                  "properties": {
                    "main": {
                      "type": "string",
                      "title": "Main Text",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    },
                    "muted": {
                      "type": "string",
                      "title": "Muted Text",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    },
                    "onPrimary": {
                      "type": "string",
                      "title": "Text on Primary",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    }
                  }
                }
              }
            },
            "dark": {
              "type": "object",
              "title": "Dark Mode Colors",
              "properties": {
                "primary": {
                  "type": "string",
                  "title": "Primary Color",
                  "pattern": "^#[0-9A-Fa-f]{6}$"
                },
                "surface": {
                  "type": "object",
                  "properties": {
                    "base": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
                    "alt": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
                  }
                },
                "text": {
                  "type": "object",
                  "properties": {
                    "main": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
                    "muted": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
                    "onPrimary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
                  }
                }
              }
            }
          }
        },
        "typography": {
          "type": "object",
          "title": "Typography",
          "properties": {
            "primary": { "type": "string", "title": "Primary Font Family" },
            "secondary": { "type": "string", "title": "Secondary Font Family" }
          }
        },
        "ui": {
          "type": "object",
          "title": "UI Settings",
          "properties": {
            "radius": { "type": "string", "title": "Border Radius", "default": "0.5rem" }
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "title": "Layout Configuration",
      "properties": {
        "navbar": {
          "type": "object",
          "title": "Navbar",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Navbar Variant",
              "enum": ["standard", "centered"],
              "default": "standard"
            }
          }
        },
        "footer": {
          "type": "object",
          "title": "Footer",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Footer Variant",
              "enum": ["simple", "multiColumn", "minimal", "centered", "branded", "stacked"],
              "default": "simple"
            },
            "copyright": { "type": "string", "title": "Copyright Text" },
            "tagline": { "type": "string", "title": "Tagline" },
            "links": {
              "type": "array",
              "title": "Footer Links",
              "items": { "$ref": "#/definitions/link" }
            },
            "columns": {
              "type": "array",
              "title": "Footer Columns",
              "items": { "$ref": "#/definitions/footerColumn" }
            }
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "title": "Navigation",
      "properties": {
        "cta": {
          "$ref": "#/definitions/cta",
          "title": "Navigation CTA"
        }
      }
    },
    "pages": {
      "type": "object",
      "title": "Pages",
      "additionalProperties": { "$ref": "#/definitions/page" }
    }
  },
  "required": ["schemaVersion", "business", "theme"]
}
