{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mshorizon.com/schemas/business.schema.json",
  "title": "BusinessProfile",
  "type": "object",
  "definitions": {
    "target": {
      "type": "object",
      "title": "Target",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["page", "section", "external", "phone", "email"],
          "title": "TargetType"
        },
        "value": { "type": "string", "title": "Target Value" }
      }
    },
    "cta": {
      "type": "object",
      "title": "Cta",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "link": {
      "type": "object",
      "title": "Link",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "footerColumn": {
      "type": "object",
      "title": "FooterColumn",
      "properties": {
        "title": { "type": "string", "title": "Column Title" },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/link" }
        }
      }
    },
    "sectionHeader": {
      "type": "object",
      "title": "SectionHeader",
      "properties": {
        "badge": { "type": "string", "title": "Badge Text" },
        "title": { "type": "string", "title": "Title" },
        "subtitle": { "type": "string", "title": "Subtitle" },
        "layout": { "type": "string", "title": "Header Layout", "enum": ["stacked", "split", "most-minimalistic", "none"] }
      }
    },
    "productCustomizationOption": {
      "type": "object",
      "title": "ProductCustomizationOption",
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" },
        "priceModifier": { "type": "number" }
      },
      "required": ["value", "label"]
    },
    "productCustomization": {
      "type": "object",
      "title": "ProductCustomization",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["select"] },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/productCustomizationOption" }
        }
      },
      "required": ["id", "label", "type", "options"]
    },
    "product": {
      "type": "object",
      "title": "Product",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "ProductAttribute",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            },
            "required": ["key", "value"]
          }
        },
        "inStock": { "type": "boolean" },
        "customizations": {
          "type": "array",
          "items": { "$ref": "#/definitions/productCustomization" }
        }
      },
      "required": ["id", "title", "price"]
    },
    "service": {
      "type": "object",
      "title": "Service",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "price": { "type": "number" },
        "priceLabel": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "available": { "type": "boolean" },
        "blogSlug": { "type": "string", "title": "Blog Slug (links to a blog-standalone post shown after service details)" }
      },
      "required": ["id", "title", "slug"]
    },
    "section": {
      "type": "object",
      "title": "Section",
      "properties": {
        "type": {
          "type": "string",
          "title": "SectionType",
          "enum": ["hero", "services", "categories", "about", "about-summary", "mission", "contact", "shop", "gallery", "testimonials", "process", "serviceArea", "trustBar", "galleryBA", "faq", "features", "ctaBanner", "blog", "blog-standalone", "map", "ref", "booking", "pricing", "project", "comparison", "team", "events", "files", "templateShowcase"]
        },
        "sectionId": { "type": "string", "title": "Shared Section ID (used when type is ref)" },
        "blogSlug": { "type": "string", "title": "Blog Slug (used when type is blog-standalone)" },
        "blogSlugs": {
          "type": "array",
          "title": "Blog Slugs (filter — when type is blog, render only these blogs in the given order; supports standalone blogs)",
          "items": { "type": "string" }
        },
        "sidebarContact": {
          "type": "object",
          "title": "Sidebar Contact Card",
          "properties": {
            "name": { "type": "string", "title": "Name" },
            "role": { "type": "string", "title": "Role / Title" },
            "image": { "type": "string", "title": "Avatar Image URL" },
            "phone": { "type": "string", "title": "Phone" },
            "email": { "type": "string", "title": "Email" },
            "cta": { "$ref": "#/definitions/cta" }
          }
        },
        "variant": { "type": "string", "title": "Variant" },
        "background": {
          "type": "string",
          "title": "Section Background",
          "enum": ["light", "dark", "dark-padded", "light-padded", "primary", "gradient", "transparent"]
        },
        "header": { "$ref": "#/definitions/sectionHeader" },
        "paddingTop": { "type": "string", "title": "Section Top Padding Override (e.g. '120px', '8rem')" },
        "paddingBottom": { "type": "string", "title": "Section Bottom Padding Override (e.g. '120px', '8rem')" },
        "backgroundImage": { "type": "string", "title": "Background Image URL" },
        "image": { "type": "string", "title": "Image URL" },
        "hideDots": { "type": "boolean", "title": "Hide Decorative Dots" },
        "imagePosition": { "type": "string", "title": "Image Position", "enum": ["left", "right"] },
        "badgeLayout": { "type": "string", "title": "Badge Layout Direction", "enum": ["row", "column"] },
        "badgeVariant": { "type": "string", "title": "Section-level Badge Variant Override", "enum": ["accent", "accent-no-line", "outlined", "text"] },
        "badgeColor": { "type": "string", "title": "Badge Text Color Override" },
        "descriptionColor": { "type": "string", "title": "Description Text Color Override" },
        "ctaColor": { "type": "string", "title": "CTA Text Color Override" },
        "statsInverted": { "type": "boolean", "title": "Invert stat colors (light bg, dark text)" },
        "cta": { "$ref": "#/definitions/cta" },
        "secondaryCta": { "$ref": "#/definitions/cta" },
        "detailsLabel": { "type": "string", "title": "Details Button Label (e.g. 'See details', 'Learn more')" },
        "testimonial": {
          "type": "object",
          "title": "Testimonial",
          "properties": {
            "title": { "type": "string" },
            "quote": { "type": "string" },
            "image": { "type": "string", "title": "Avatar Image URL" }
          }
        },
        "testimonials": {
          "type": "array",
          "title": "Testimonials",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "quote": { "type": "string" },
              "image": { "type": "string", "title": "Avatar Image URL" }
            }
          }
        },
        "items": {
          "type": "array",
          "title": "Items",
          "items": {
            "type": "object",
            "title": "ServiceItem",
            "properties": {
              "id": { "type": "string" },
              "slug": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" },
              "icon": { "type": "string" },
              "image": { "type": "string" },
              "tags": {
                "type": "array",
                "title": "Feature Tags",
                "items": { "type": "string" }
              },
              "author": { "type": "string", "title": "Author Name" },
              "role": { "type": "string", "title": "Author Role" },
              "metric": { "type": "string", "title": "Metric" },
              "metricLabel": { "type": "string", "title": "Metric Label" },
              "dateStart": { "type": "string", "title": "Start Date" },
              "dateEnd": { "type": "string", "title": "End Date" },
              "href": { "type": "string", "title": "Link URL" },
              "linkLabel": { "type": "string", "title": "Link Label" }
            }
          }
        },
        "story": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "StatItem",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "commitment": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "timeline": {
          "type": "array",
          "title": "Timeline",
          "items": {
            "type": "object",
            "title": "TimelineItem",
            "properties": {
              "year": { "type": "string" },
              "title": { "type": "string" },
              "company": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "info": {
          "type": "object",
          "title": "ContactInfo",
          "properties": {
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "hours": { "type": "string" },
            "hoursDetailed": {
              "type": "array",
              "title": "Detailed Hours",
              "description": "Per-day opening hours, one line each (e.g., 'poniedziałek 9:00 – 15:00'). Rendered as a multi-line block under the single 'hours' line.",
              "items": { "type": "string" }
            },
            "receptionHours": {
              "type": "string",
              "title": "Reception Hours",
              "description": "Separate schedule for client reception (e.g., 'środa 9:00 – 17:00')."
            },
            "receptionLabel": {
              "type": "string",
              "title": "Reception Label",
              "description": "Localized label for the reception hours block (e.g., 'Client reception'). Rendered above receptionHours."
            },
            "additionalInfo": {
              "type": "array",
              "title": "Additional Info",
              "description": "Extra contact info lines (e.g., bank account, EPUAP address).",
              "items": { "type": "string" }
            },
            "notice": {
              "type": "object",
              "title": "Contact Notice",
              "description": "Highlighted notice block displayed below the contact info (e.g., bank transfer instructions).",
              "properties": {
                "title": { "type": "string" },
                "highlight": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        },
        "form": {
          "type": "object",
          "title": "ContactForm",
          "properties": {
            "namePlaceholder": { "type": "string" },
            "emailPlaceholder": { "type": "string" },
            "messagePlaceholder": { "type": "string" },
            "submitButton": { "type": "string" },
            "nameLabel": { "type": "string" },
            "emailLabel": { "type": "string" },
            "messageLabel": { "type": "string" },
            "selectFields": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "label": { "type": "string" },
                  "placeholder": { "type": "string" },
                  "options": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "labels": {
          "type": "object",
          "title": "Labels",
          "additionalProperties": { "type": "string" }
        },
        "exploreLabel": { "type": "string", "title": "Explore Label" },
        "products": {
          "type": "array",
          "title": "Products",
          "items": { "$ref": "#/definitions/product" }
        },
        "currency": { "type": "string", "title": "Currency" },
        "ctaLabel": { "type": "string", "title": "CTA Label" },
        "outOfStockCtaLabel": { "type": "string", "title": "Out of Stock CTA Label" },
        "outOfStockCtaHref": { "type": "string", "title": "Out of Stock CTA Href" },
        "steps": {
          "type": "array",
          "title": "Process Steps",
          "items": {
            "type": "object",
            "title": "ProcessStep",
            "properties": {
              "number": { "type": "integer" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" },
              "image": { "type": "string" },
              "video": { "type": "string", "title": "Video URL" },
              "badges": {
                "type": "array",
                "title": "Visual Badges",
                "items": { "type": "string" }
              }
            }
          }
        },
        "areas": {
          "type": "array",
          "title": "Service Areas",
          "items": { "type": "string" }
        },
        "pairs": {
          "type": "array",
          "title": "Before/After Pairs",
          "items": {
            "type": "object",
            "title": "BeforeAfterPair",
            "properties": {
              "title": { "type": "string" },
              "before": { "type": "string" },
              "after": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "trustSignals": {
          "type": "array",
          "title": "Trust Signals",
          "items": {
            "type": "object",
            "title": "TrustSignal",
            "properties": {
              "icon": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "clientLogos": {
          "type": "array",
          "title": "Client Logos",
          "description": "Logo images for scrolling trust bar",
          "items": {
            "type": "object",
            "title": "ClientLogo",
            "properties": {
              "name": { "type": "string" },
              "image": { "type": "string" }
            },
            "required": ["name", "image"]
          }
        },
        "googleRating": { "$ref": "#/definitions/googleRating" },
        "faqItems": {
          "type": "array",
          "title": "FAQ Items",
          "items": {
            "type": "object",
            "title": "FAQItem",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        },
        "blogPosts": {
          "type": "array",
          "title": "Blog Posts",
          "items": {
            "type": "object",
            "title": "BlogPost",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "image": { "type": "string" },
              "date": { "type": "string" },
              "href": { "type": "string" }
            }
          }
        },
        "marqueeText": {
          "type": "string",
          "title": "Marquee Text"
        },
        "pricingTiers": {
          "type": "array",
          "title": "Pricing Tiers",
          "items": {
            "type": "object",
            "title": "PricingTier",
            "properties": {
              "name": { "type": "string", "title": "Tier Name" },
              "price": { "type": "string", "title": "Price" },
              "period": { "type": "string", "title": "Billing Period" },
              "description": { "type": "string", "title": "Description" },
              "features": {
                "type": "array",
                "title": "Features",
                "items": { "type": "string" }
              },
              "cta": { "$ref": "#/definitions/cta" },
              "highlighted": { "type": "boolean", "title": "Highlighted" },
              "badge": { "type": "string", "title": "Badge Text" },
              "annualPrice": { "type": "string", "title": "Annual Price" },
              "icon": { "type": "string", "title": "Tier Icon" }
            },
            "required": ["name", "price"]
          }
        },
        "projects": {
          "type": "array",
          "title": "Projects",
          "items": {
            "type": "object",
            "title": "ProjectItem",
            "properties": {
              "title": { "type": "string", "title": "Title" },
              "description": { "type": "string", "title": "Description" },
              "image": { "type": "string", "title": "Image URL" },
              "logo": { "type": "string", "title": "Logo Image URL" },
              "date": { "type": "string", "title": "Date" },
              "metric": { "type": "string", "title": "Key Metric" },
              "metricLabel": { "type": "string", "title": "Metric Label" },
              "metrics": {
                "type": "array",
                "title": "Metric Badges",
                "items": { "type": "string" }
              },
              "url": { "type": "string", "title": "Live Website URL" },
              "cta": {
                "type": "object",
                "title": "CTA Link",
                "properties": {
                  "label": { "type": "string", "title": "CTA Label" },
                  "href": { "type": "string", "title": "CTA URL" }
                }
              }
            }
          }
        },
        "leftTitle": { "type": "string", "title": "Left Column Title (e.g. Manual Work)" },
        "rightTitle": { "type": "string", "title": "Right Column Title (e.g. AI Automation)" },
        "rows": {
          "type": "array",
          "title": "Comparison Rows",
          "items": {
            "type": "object",
            "title": "ComparisonRow",
            "properties": {
              "left": { "type": "string", "title": "Left (Problem)" },
              "right": { "type": "string", "title": "Right (Solution)" }
            }
          }
        },
        "members": {
          "type": "array",
          "title": "Team Members",
          "items": {
            "type": "object",
            "title": "TeamMember",
            "properties": {
              "name": { "type": "string", "title": "Name" },
              "role": { "type": "string", "title": "Role" },
              "image": { "type": "string", "title": "Photo URL" },
              "linkedin": { "type": "string", "title": "LinkedIn URL" }
            }
          }
        },
        "fileGroups": {
          "type": "array",
          "title": "File Groups",
          "items": {
            "type": "object",
            "title": "FileGroup",
            "properties": {
              "title": { "type": "string", "title": "Group Title" },
              "files": {
                "type": "array",
                "title": "Files",
                "items": {
                  "type": "object",
                  "title": "FileItem",
                  "properties": {
                    "name": { "type": "string", "title": "File Name" },
                    "type": { "type": "string", "title": "File Type (e.g. pdf, docx)" },
                    "url": { "type": "string", "title": "Download URL" }
                  },
                  "required": ["name", "url"]
                }
              }
            },
            "required": ["title", "files"]
          }
        },
        "templateItems": {
          "type": "array",
          "title": "Template Items",
          "items": {
            "type": "object",
            "title": "TemplateItem",
            "properties": {
              "name": { "type": "string", "title": "Template Name" },
              "description": { "type": "string", "title": "Description" },
              "screenshot": { "type": "string", "title": "Screenshot URL" },
              "demoUrl": { "type": "string", "title": "Live Demo URL" },
              "tags": {
                "type": "array",
                "title": "Tags",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "description", "screenshot", "demoUrl"]
          }
        },
        "area": {
          "type": "object",
          "title": "Service Area Configuration",
          "properties": {
            "country": {
              "type": "string",
              "title": "Country",
              "enum": ["polska"]
            },
            "region": {
              "type": "string",
              "title": "Region",
              "enum": ["mazowsze", "slaskie", "malopolskie", "wielkopolskie", "dolnoslaskie", "pomorskie", "kujawsko-pomorskie", "zachodnio-pomorskie", "lubelskie", "podkarpackie", "warminsko-mazurskie", "lodzkie", "swietokrzyskie", "podlaskie", "opolskie", "lubuskie"]
            }
          }
        }
      },
      "required": ["type"]
    },
    "page": {
      "type": "object",
      "title": "Page",
      "properties": {
        "title": { "type": "string", "title": "Page Title" },
        "navLabel": { "type": "string", "title": "Nav Label" },
        "navOrder": { "type": "number", "title": "Nav Order" },
        "hideFromNav": { "type": "boolean", "title": "Hide From Nav" },
        "sections": {
          "type": "array",
          "title": "Sections",
          "items": { "$ref": "#/definitions/section" }
        }
      },
      "required": ["title", "sections"]
    },
    "googleRating": {
      "type": "object",
      "title": "GoogleRating",
      "properties": {
        "score": { "type": "number" },
        "count": { "type": "integer" }
      }
    },
    "themeColorMode": {
      "type": "object",
      "title": "ThemeColorMode",
      "properties": {
        "primary": {
          "type": "string",
          "title": "Primary Color",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#0066CC"
        },
        "primaryLight": {
          "type": "string",
          "title": "Primary Light Color",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "primaryDark": {
          "type": "string",
          "title": "Primary Dark Color",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "surface": {
          "type": "object",
          "title": "Surface Colors",
          "properties": {
            "base": {
              "type": "string",
              "title": "Base Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "alt": {
              "type": "string",
              "title": "Alt Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "card": {
              "type": "string",
              "title": "Card Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "gradient": {
              "type": "string",
              "title": "Gradient Surface",
              "description": "Optional surface tint used as the top stop of light-padded section gradients.",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            }
          }
        },
        "text": {
          "type": "object",
          "title": "Text Colors",
          "properties": {
            "main": {
              "type": "string",
              "title": "Main Text",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "muted": {
              "type": "string",
              "title": "Muted Text",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "onPrimary": {
              "type": "string",
              "title": "Text on Primary",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            }
          }
        }
      }
    },
    "bookingDayHours": {
      "type": "object",
      "title": "BookingDayHours",
      "properties": {
        "enabled": { "type": "boolean", "title": "Open", "default": true },
        "open": { "type": "string", "title": "Opening Time", "default": "09:00" },
        "close": { "type": "string", "title": "Closing Time", "default": "17:00" }
      }
    },
    "themeSpacing": {
      "type": "object",
      "title": "ThemeSpacing",
      "properties": {
        "xs": {
          "type": "string",
          "title": "Extra Small Spacing",
          "default": "0.5rem"
        },
        "sm": {
          "type": "string",
          "title": "Small Spacing",
          "default": "0.75rem"
        },
        "md": {
          "type": "string",
          "title": "Medium Spacing",
          "default": "1rem"
        },
        "lg": {
          "type": "string",
          "title": "Large Spacing",
          "default": "1.5rem"
        },
        "xl": {
          "type": "string",
          "title": "Extra Large Spacing",
          "default": "2rem"
        },
        "2xl": {
          "type": "string",
          "title": "2XL Spacing",
          "default": "3rem"
        },
        "3xl": {
          "type": "string",
          "title": "3XL Spacing",
          "default": "4rem"
        },
        "section-sm": {
          "type": "string",
          "title": "Small Section Spacing",
          "default": "5rem"
        },
        "section": {
          "type": "string",
          "title": "Section Spacing",
          "default": "7.5rem"
        },
        "container": {
          "type": "string",
          "title": "Container Spacing",
          "default": "2.5rem"
        }
      }
    }
  },
  "properties": {
    "business": {
      "type": "object",
      "title": "Business",
      "properties": {
        "id": { "type": "string", "title": "Business ID" },
        "name": { "type": "string", "title": "Business Name" },
        "industry": {
          "type": "string",
          "title": "Industry"
        },
        "assets": {
          "type": "object",
          "title": "BusinessAssets",
          "properties": {
            "favicon": { "type": "string", "title": "Favicon URL" },
            "logo": { "type": "string", "title": "Logo URL" },
            "icon": { "type": "string", "title": "Icon URL" },
            "footerIcon": { "type": "string", "title": "Footer Icon URL", "description": "Icon used in the footer. Falls back to icon when absent." },
            "iconLucide": { "type": "string", "title": "Icon Lucide Name", "description": "Lucide icon name rendered inline with text-primary color (e.g. 'scale', 'gavel'). Takes precedence over icon." }
          }
        },
        "contact": {
          "type": "object",
          "title": "BusinessContact",
          "properties": {
            "address": { "type": "string", "title": "Address" },
            "phone": { "type": "string", "title": "Phone" },
            "email": { "type": "string", "format": "email", "title": "Email" },
            "hours": { "type": "string", "title": "Business Hours" },
            "additionalInfo": {
              "type": "array",
              "title": "Additional Info",
              "description": "Extra info strings shown next to phone/email/address in the navbar upper bar, each rendered with an 'i' info icon (e.g., registration numbers, license IDs).",
              "items": { "type": "string" }
            },
            "location": {
              "type": "object",
              "title": "Geographic Location",
              "properties": {
                "latitude": { "type": "number", "title": "Latitude" },
                "longitude": { "type": "number", "title": "Longitude" },
                "googlePlaceQuery": { "type": "string", "title": "Google Place Query", "description": "Business name/address query for Google Maps native panel (e.g. 'Kancelaria Notarialna Garwolin'). When set, the map shows Google's native info card with reviews and directions instead of the custom overlay." }
              },
              "required": ["latitude", "longitude"]
            }
          }
        },
        "socials": {
          "type": "object",
          "title": "Socials",
          "additionalProperties": { "type": "string" }
        },
        "serviceArea": {
          "type": "array",
          "title": "Service Area",
          "items": { "type": "string" }
        },
        "googleRating": { "$ref": "#/definitions/googleRating" },
        "trustSignals": {
          "type": "array",
          "title": "Trust Signals",
          "items": {
            "type": "object",
            "properties": {
              "icon": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "industry"]
    },
    "theme": {
      "type": "object",
      "title": "Theme",
      "properties": {
        "preset": {
          "type": "string",
          "title": "Theme Preset",
          "enum": ["industrial", "wellness", "minimal", "elegant", "modern", "classic", "bold"]
        },
        "globalVariant": {
          "type": "string",
          "title": "Global Variant"
        },
        "majorTheme": {
          "type": "string",
          "title": "Major Theme",
          "enum": ["template-specialist", "template-tech", "template-art", "template-law", "template-tech-agency"]
        },
        "mode": {
          "type": "string",
          "title": "Color Mode",
          "enum": ["light", "dark"],
          "default": "light"
        },
        "colors": {
          "type": "object",
          "title": "Color Schemes",
          "properties": {
            "light": { "$ref": "#/definitions/themeColorMode" },
            "dark": { "$ref": "#/definitions/themeColorMode" }
          }
        },
        "typography": {
          "type": "object",
          "title": "Typography",
          "properties": {
            "primary": { "type": "string", "title": "Primary Font Family" },
            "secondary": { "type": "string", "title": "Secondary Font Family" },
            "baseSize": { "type": "string", "title": "Base Font Size" }
          }
        },
        "ui": {
          "type": "object",
          "title": "UI Settings",
          "properties": {
            "radius": { "type": "string", "title": "Border Radius", "default": "0.5rem" },
            "spacing": { "$ref": "#/definitions/themeSpacing" },
            "spacingScale": { "type": "number", "title": "Spacing Scale" },
            "buttonStyle": { "type": "string", "title": "Button Style" }
          }
        },
        "headingWeight": { "type": "string", "title": "Heading Font Weight", "default": "700" },
        "maxFontWeight": { "type": "string", "title": "Max Font Weight", "description": "Caps the maximum font-weight used anywhere on the site (e.g. \"400\" forces all text to weight 400 or lower).", "default": "900" },
        "navFontSize": { "type": "string", "title": "Navbar Font Size", "default": "16px" },
        "navLogoSize": { "type": "string", "title": "Navbar Logo Font Size", "default": "24px" },
        "navLogoWeight": { "type": "string", "title": "Navbar Logo Font Weight", "default": "600" },
        "navLinksPosition": { "type": "string", "title": "Navbar Links Position", "enum": ["center", "right"], "default": "center" },
        "scrollType": { "type": "string", "title": "Scroll Type", "enum": ["native", "smooth", "momentum"], "default": "smooth" },
        "badgeVariant": { "type": "string", "title": "Section Badge Variant", "enum": ["accent", "accent-no-line", "outlined", "text"], "default": "accent" },
        "badgeFontSize": { "type": "string", "title": "Badge Font Size", "default": "16px" }
      }
    },
    "layout": {
      "type": "object",
      "title": "Layout",
      "properties": {
        "navbar": {
          "type": "object",
          "title": "Navbar",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Navbar Variant",
              "enum": ["standard", "centered", "transparent"],
              "default": "standard"
            },
            "logoText": {
              "type": "string",
              "title": "Logo Text Override",
              "description": "Override the business name displayed in the navbar"
            },
            "hideBorderOnTop": {
              "type": "boolean",
              "title": "Hide Border When At Top",
              "description": "Hide the bottom border when scroll is at the very top of the page",
              "default": false
            },
            "hideCta": {
              "type": "boolean",
              "title": "Hide CTA Button",
              "description": "Hide the call-to-action button in the navbar",
              "default": false
            },
            "showSocials": {
              "type": "boolean",
              "title": "Show Social Media Icons in Extension",
              "description": "Show social media icons in the upper bar extension",
              "default": true
            },
            "showAvailability": {
              "type": "boolean",
              "title": "Show Availability in Extension",
              "description": "Show availability badge in the upper bar extension",
              "default": true
            },
            "showAddress": {
              "type": "boolean",
              "title": "Show Address in Extension",
              "description": "Show address in the upper bar extension",
              "default": true
            },
            "showAdditionalInfo": {
              "type": "boolean",
              "title": "Show Additional Info in Extension",
              "description": "Show additionalInfo items in the upper bar extension",
              "default": true
            },
            "extensions": {
              "type": "array",
              "title": "Navbar Extensions",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["upper-bar"], "title": "Extension Type" }
                },
                "required": ["type"]
              }
            }
          }
        },
        "footer": {
          "type": "object",
          "title": "FooterConfig",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Footer Variant",
              "enum": ["simple", "multiColumn", "minimal", "centered", "branded", "stacked", "gradient", "darkColumns"],
              "default": "simple"
            },
            "copyright": { "type": "string", "title": "Copyright Text" },
            "tagline": { "type": "string", "title": "Tagline" },
            "links": {
              "type": "array",
              "title": "Footer Links",
              "items": { "$ref": "#/definitions/link" }
            },
            "columns": {
              "type": "array",
              "title": "Footer Columns",
              "items": { "$ref": "#/definitions/footerColumn" }
            },
            "name": { "type": "string", "title": "Footer Display Name", "description": "Overrides business name in footer" },
            "background": {
              "type": "object",
              "title": "Footer Background",
              "properties": {
                "enabled": { "type": "boolean", "title": "Enable Background Container", "default": false },
                "padding": { "type": "string", "title": "Container Padding", "default": "16px" },
                "borderRadius": { "type": "string", "title": "Container Border Radius", "default": "12px" },
                "gradient": { "type": "string", "title": "Background Gradient", "description": "Gradient preset e.g. primary-to-primary-dark" }
              }
            },
            "extensions": {
              "type": "array",
              "title": "Footer Extensions",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["call"], "title": "Extension Type" },
                  "headline": { "type": "string", "title": "Headline" },
                  "phone": { "type": "string", "title": "Phone" }
                },
                "required": ["type"]
              }
            }
          }
        },
        "hideBreadcrumbs": {
          "type": "boolean",
          "title": "Hide Breadcrumbs",
          "description": "Hide breadcrumb navigation on service detail pages",
          "default": false
        }
      }
    },
    "navigation": {
      "type": "object",
      "title": "Navigation",
      "properties": {
        "links": {
          "type": "array",
          "title": "Navigation Links",
          "items": { "$ref": "#/definitions/link" }
        },
        "cta": {
          "$ref": "#/definitions/cta",
          "title": "Navigation CTA"
        }
      }
    },
    "pages": {
      "type": "object",
      "title": "Pages",
      "additionalProperties": { "$ref": "#/definitions/page" }
    },
    "sharedSections": {
      "type": "object",
      "title": "Shared Sections",
      "description": "Named sections that can be referenced from any page via { type: 'ref', sectionId: '<key>' }",
      "additionalProperties": { "$ref": "#/definitions/section" }
    },
    "data": {
      "type": "object",
      "title": "Data",
      "properties": {
        "services": {
          "type": "array",
          "title": "Services",
          "items": { "$ref": "#/definitions/service" }
        },
        "products": {
          "type": "array",
          "title": "Products",
          "items": { "$ref": "#/definitions/product" }
        }
      }
    },
    "booking": {
      "type": "object",
      "title": "Booking",
      "properties": {
        "enabled": { "type": "boolean", "title": "Enable Booking", "default": false },
        "services": {
          "type": "array",
          "title": "Booking Services",
          "items": {
            "type": "object",
            "title": "BookingService",
            "properties": {
              "id": { "type": "string", "title": "Service ID" },
              "name": { "type": "string", "title": "Service Name" },
              "duration": { "type": "integer", "title": "Duration (minutes)", "default": 60 },
              "price": { "type": "number", "title": "Price" },
              "description": { "type": "string", "title": "Description" }
            },
            "required": ["id", "name", "duration"]
          }
        },
        "hours": {
          "type": "object",
          "title": "Business Hours",
          "properties": {
            "mon": { "$ref": "#/definitions/bookingDayHours" },
            "tue": { "$ref": "#/definitions/bookingDayHours" },
            "wed": { "$ref": "#/definitions/bookingDayHours" },
            "thu": { "$ref": "#/definitions/bookingDayHours" },
            "fri": { "$ref": "#/definitions/bookingDayHours" },
            "sat": { "$ref": "#/definitions/bookingDayHours" },
            "sun": { "$ref": "#/definitions/bookingDayHours" }
          }
        },
        "slotInterval": { "type": "integer", "title": "Slot Interval (minutes)", "default": 60 },
        "leadTime": { "type": "integer", "title": "Lead Time (minutes)", "default": 60 },
        "maxAdvance": { "type": "integer", "title": "Max Advance Booking (days)", "default": 30 },
        "bufferMinutes": { "type": "integer", "title": "Buffer between appointments (minutes)", "default": 0 },
        "blackoutDates": {
          "type": "array",
          "title": "Blackout Dates (YYYY-MM-DD)",
          "items": { "type": "string" }
        }
      }
    },
    "notifications": {
      "type": "object",
      "title": "Notifications",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Contact Form Notification Email",
          "description": "Override email for receiving contact form submissions. Use when the public contact email (business.contact.email) has delivery issues (e.g. strict government/corporate mail servers). Leave empty to use business.contact.email."
        },
        "sms": {
          "type": "object",
          "title": "SMS Notifications",
          "properties": {
            "enabled": { "type": "boolean", "title": "Enable SMS Notifications", "default": false },
            "provider": {
              "type": "string",
              "title": "SMS Provider",
              "enum": ["smsapi", "twilio"],
              "default": "smsapi"
            },
            "phoneNumber": { "type": "string", "title": "Recipient Phone Number (with country code, e.g. +48500600700)" },
            "apiToken": { "type": "string", "title": "Provider API Token / Auth Key" },
            "senderName": { "type": "string", "title": "Sender Name (optional, max 11 chars)" },
            "template": {
              "type": "string",
              "title": "Message Template",
              "default": "New message from {{name}} ({{email}}): {{message}}"
            }
          }
        },
        "push": {
          "type": "object",
          "title": "Web Push Notifications",
          "properties": {
            "enabled": { "type": "boolean", "title": "Enable Web Push Notifications", "default": false }
          }
        }
      }
    }
  },
  "required": ["business", "theme"]
}
