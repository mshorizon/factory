{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mshorizon.com/schemas/business.schema.json",
  "title": "BusinessProfile",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "industry": { "enum": ["barber", "plumber", "auto-dealer", "dentist", "honey-producer"] },
    "branding": {
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "themeId": { "type": "string" }
      },
      "required": ["primaryColor", "themeId"]
    },
    "sections": {
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "backgroundImage": { "type": "string" }
          },
          "required": ["title"]
        }
      }
    }
  },
  "required": ["id", "name", "industry", "branding", "sections"]
}
