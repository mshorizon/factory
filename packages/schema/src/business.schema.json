{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mshorizon.com/schemas/business.schema.json",
  "title": "BusinessProfile",
  "type": "object",
  "definitions": {
    "target": {
      "type": "object",
      "title": "Target",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["page", "section", "external", "phone", "email"],
          "title": "TargetType"
        },
        "value": { "type": "string", "title": "Target Value" }
      }
    },
    "cta": {
      "type": "object",
      "title": "Cta",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "link": {
      "type": "object",
      "title": "Link",
      "properties": {
        "label": { "type": "string", "title": "Label" },
        "target": { "$ref": "#/definitions/target" }
      },
      "required": ["label"]
    },
    "footerColumn": {
      "type": "object",
      "title": "FooterColumn",
      "properties": {
        "title": { "type": "string", "title": "Column Title" },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/link" }
        }
      }
    },
    "sectionHeader": {
      "type": "object",
      "title": "SectionHeader",
      "properties": {
        "badge": { "type": "string", "title": "Badge Text" },
        "title": { "type": "string", "title": "Title" },
        "subtitle": { "type": "string", "title": "Subtitle" }
      }
    },
    "productCustomizationOption": {
      "type": "object",
      "title": "ProductCustomizationOption",
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" },
        "priceModifier": { "type": "number" }
      },
      "required": ["value", "label"]
    },
    "productCustomization": {
      "type": "object",
      "title": "ProductCustomization",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["select"] },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/productCustomizationOption" }
        }
      },
      "required": ["id", "label", "type", "options"]
    },
    "product": {
      "type": "object",
      "title": "Product",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "ProductAttribute",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            },
            "required": ["key", "value"]
          }
        },
        "inStock": { "type": "boolean" },
        "customizations": {
          "type": "array",
          "items": { "$ref": "#/definitions/productCustomization" }
        }
      },
      "required": ["id", "title", "price"]
    },
    "service": {
      "type": "object",
      "title": "Service",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "price": { "type": "number" },
        "priceLabel": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "available": { "type": "boolean" }
      },
      "required": ["id", "title", "slug"]
    },
    "section": {
      "type": "object",
      "title": "Section",
      "properties": {
        "type": {
          "type": "string",
          "title": "SectionType",
          "enum": ["hero", "services", "categories", "about", "about-summary", "mission", "contact", "shop", "gallery", "testimonials", "process", "serviceArea", "trustBar", "galleryBA", "faq", "features", "ctaBanner", "blog", "map", "ref", "booking", "pricing", "project"]
        },
        "sectionId": { "type": "string", "title": "Shared Section ID (used when type is ref)" },
        "variant": { "type": "string", "title": "Variant" },
        "background": {
          "type": "string",
          "title": "Section Background",
          "enum": ["light", "dark", "primary"]
        },
        "header": { "$ref": "#/definitions/sectionHeader" },
        "backgroundImage": { "type": "string", "title": "Background Image URL" },
        "image": { "type": "string", "title": "Image URL" },
        "cta": { "$ref": "#/definitions/cta" },
        "secondaryCta": { "$ref": "#/definitions/cta" },
        "testimonial": {
          "type": "object",
          "title": "Testimonial",
          "properties": {
            "title": { "type": "string" },
            "quote": { "type": "string" },
            "image": { "type": "string", "title": "Avatar Image URL" }
          }
        },
        "testimonials": {
          "type": "array",
          "title": "Testimonials",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "quote": { "type": "string" },
              "image": { "type": "string", "title": "Avatar Image URL" }
            }
          }
        },
        "items": {
          "type": "array",
          "title": "Items",
          "items": {
            "type": "object",
            "title": "ServiceItem",
            "properties": {
              "id": { "type": "string" },
              "slug": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" },
              "icon": { "type": "string" },
              "image": { "type": "string" }
            }
          }
        },
        "story": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "StatItem",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "commitment": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "timeline": {
          "type": "array",
          "title": "Timeline",
          "items": {
            "type": "object",
            "title": "TimelineItem",
            "properties": {
              "year": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "info": {
          "type": "object",
          "title": "ContactInfo",
          "properties": {
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "hours": { "type": "string" }
          }
        },
        "form": {
          "type": "object",
          "title": "ContactForm",
          "properties": {
            "namePlaceholder": { "type": "string" },
            "emailPlaceholder": { "type": "string" },
            "messagePlaceholder": { "type": "string" },
            "submitButton": { "type": "string" }
          }
        },
        "labels": {
          "type": "object",
          "title": "Labels",
          "additionalProperties": { "type": "string" }
        },
        "exploreLabel": { "type": "string", "title": "Explore Label" },
        "products": {
          "type": "array",
          "title": "Products",
          "items": { "$ref": "#/definitions/product" }
        },
        "currency": { "type": "string", "title": "Currency" },
        "ctaLabel": { "type": "string", "title": "CTA Label" },
        "outOfStockCtaLabel": { "type": "string", "title": "Out of Stock CTA Label" },
        "outOfStockCtaHref": { "type": "string", "title": "Out of Stock CTA Href" },
        "steps": {
          "type": "array",
          "title": "Process Steps",
          "items": {
            "type": "object",
            "title": "ProcessStep",
            "properties": {
              "number": { "type": "integer" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "areas": {
          "type": "array",
          "title": "Service Areas",
          "items": { "type": "string" }
        },
        "pairs": {
          "type": "array",
          "title": "Before/After Pairs",
          "items": {
            "type": "object",
            "title": "BeforeAfterPair",
            "properties": {
              "title": { "type": "string" },
              "before": { "type": "string" },
              "after": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "trustSignals": {
          "type": "array",
          "title": "Trust Signals",
          "items": {
            "type": "object",
            "title": "TrustSignal",
            "properties": {
              "icon": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "googleRating": { "$ref": "#/definitions/googleRating" },
        "faqItems": {
          "type": "array",
          "title": "FAQ Items",
          "items": {
            "type": "object",
            "title": "FAQItem",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        },
        "blogPosts": {
          "type": "array",
          "title": "Blog Posts",
          "items": {
            "type": "object",
            "title": "BlogPost",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "image": { "type": "string" },
              "date": { "type": "string" },
              "href": { "type": "string" }
            }
          }
        },
        "marqueeText": {
          "type": "string",
          "title": "Marquee Text"
        },
        "pricingTiers": {
          "type": "array",
          "title": "Pricing Tiers",
          "items": {
            "type": "object",
            "title": "PricingTier",
            "properties": {
              "name": { "type": "string", "title": "Tier Name" },
              "price": { "type": "string", "title": "Price" },
              "period": { "type": "string", "title": "Billing Period" },
              "description": { "type": "string", "title": "Description" },
              "features": {
                "type": "array",
                "title": "Features",
                "items": { "type": "string" }
              },
              "cta": { "$ref": "#/definitions/cta" },
              "highlighted": { "type": "boolean", "title": "Highlighted" },
              "badge": { "type": "string", "title": "Badge Text" }
            },
            "required": ["name", "price"]
          }
        },
        "projects": {
          "type": "array",
          "title": "Projects",
          "items": {
            "type": "object",
            "title": "ProjectItem",
            "properties": {
              "title": { "type": "string", "title": "Title" },
              "description": { "type": "string", "title": "Description" },
              "image": { "type": "string", "title": "Image URL" },
              "date": { "type": "string", "title": "Date" },
              "metric": { "type": "string", "title": "Key Metric" },
              "metricLabel": { "type": "string", "title": "Metric Label" }
            }
          }
        },
        "area": {
          "type": "object",
          "title": "Service Area Configuration",
          "properties": {
            "country": {
              "type": "string",
              "title": "Country",
              "enum": ["polska"]
            },
            "region": {
              "type": "string",
              "title": "Region",
              "enum": ["mazowsze", "slaskie", "malopolskie", "wielkopolskie", "dolnoslaskie", "pomorskie", "kujawsko-pomorskie", "zachodnio-pomorskie", "lubelskie", "podkarpackie", "warminsko-mazurskie", "lodzkie", "swietokrzyskie", "podlaskie", "opolskie", "lubuskie"]
            }
          }
        }
      },
      "required": ["type"]
    },
    "page": {
      "type": "object",
      "title": "Page",
      "properties": {
        "title": { "type": "string", "title": "Page Title" },
        "hideFromNav": { "type": "boolean", "title": "Hide From Nav" },
        "sections": {
          "type": "array",
          "title": "Sections",
          "items": { "$ref": "#/definitions/section" }
        }
      },
      "required": ["title", "sections"]
    },
    "googleRating": {
      "type": "object",
      "title": "GoogleRating",
      "properties": {
        "score": { "type": "number" },
        "count": { "type": "integer" }
      }
    },
    "themeColorMode": {
      "type": "object",
      "title": "ThemeColorMode",
      "properties": {
        "primary": {
          "type": "string",
          "title": "Primary Color",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#0066CC"
        },
        "surface": {
          "type": "object",
          "title": "Surface Colors",
          "properties": {
            "base": {
              "type": "string",
              "title": "Base Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "alt": {
              "type": "string",
              "title": "Alt Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "card": {
              "type": "string",
              "title": "Card Surface",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            }
          }
        },
        "text": {
          "type": "object",
          "title": "Text Colors",
          "properties": {
            "main": {
              "type": "string",
              "title": "Main Text",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "muted": {
              "type": "string",
              "title": "Muted Text",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "onPrimary": {
              "type": "string",
              "title": "Text on Primary",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            }
          }
        }
      }
    },
    "bookingDayHours": {
      "type": "object",
      "title": "BookingDayHours",
      "properties": {
        "enabled": { "type": "boolean", "title": "Open", "default": true },
        "open": { "type": "string", "title": "Opening Time", "default": "09:00" },
        "close": { "type": "string", "title": "Closing Time", "default": "17:00" }
      }
    },
    "themeSpacing": {
      "type": "object",
      "title": "ThemeSpacing",
      "properties": {
        "xs": {
          "type": "string",
          "title": "Extra Small Spacing",
          "default": "0.5rem"
        },
        "sm": {
          "type": "string",
          "title": "Small Spacing",
          "default": "0.75rem"
        },
        "md": {
          "type": "string",
          "title": "Medium Spacing",
          "default": "1rem"
        },
        "lg": {
          "type": "string",
          "title": "Large Spacing",
          "default": "1.5rem"
        },
        "xl": {
          "type": "string",
          "title": "Extra Large Spacing",
          "default": "2rem"
        },
        "2xl": {
          "type": "string",
          "title": "2XL Spacing",
          "default": "3rem"
        },
        "3xl": {
          "type": "string",
          "title": "3XL Spacing",
          "default": "4rem"
        },
        "section-sm": {
          "type": "string",
          "title": "Small Section Spacing",
          "default": "5rem"
        },
        "section": {
          "type": "string",
          "title": "Section Spacing",
          "default": "7.5rem"
        },
        "container": {
          "type": "string",
          "title": "Container Spacing",
          "default": "2.5rem"
        }
      }
    }
  },
  "properties": {
    "business": {
      "type": "object",
      "title": "Business",
      "properties": {
        "id": { "type": "string", "title": "Business ID" },
        "name": { "type": "string", "title": "Business Name" },
        "industry": {
          "type": "string",
          "title": "Industry"
        },
        "assets": {
          "type": "object",
          "title": "BusinessAssets",
          "properties": {
            "favicon": { "type": "string", "title": "Favicon URL" },
            "logo": { "type": "string", "title": "Logo URL" },
            "icon": { "type": "string", "title": "Icon URL" }
          }
        },
        "contact": {
          "type": "object",
          "title": "BusinessContact",
          "properties": {
            "address": { "type": "string", "title": "Address" },
            "phone": { "type": "string", "title": "Phone" },
            "email": { "type": "string", "format": "email", "title": "Email" },
            "hours": { "type": "string", "title": "Business Hours" },
            "location": {
              "type": "object",
              "title": "Geographic Location",
              "properties": {
                "latitude": { "type": "number", "title": "Latitude" },
                "longitude": { "type": "number", "title": "Longitude" }
              },
              "required": ["latitude", "longitude"]
            }
          }
        },
        "socials": {
          "type": "object",
          "title": "Socials",
          "additionalProperties": { "type": "string" }
        },
        "serviceArea": {
          "type": "array",
          "title": "Service Area",
          "items": { "type": "string" }
        },
        "googleRating": { "$ref": "#/definitions/googleRating" },
        "trustSignals": {
          "type": "array",
          "title": "Trust Signals",
          "items": {
            "type": "object",
            "properties": {
              "icon": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "industry"]
    },
    "theme": {
      "type": "object",
      "title": "Theme",
      "properties": {
        "preset": {
          "type": "string",
          "title": "Theme Preset",
          "enum": ["industrial", "wellness", "minimal", "elegant", "modern", "classic", "bold"]
        },
        "globalVariant": {
          "type": "string",
          "title": "Global Variant"
        },
        "majorTheme": {
          "type": "string",
          "title": "Major Theme",
          "enum": ["specialist", "portfolio-tech"]
        },
        "mode": {
          "type": "string",
          "title": "Color Mode",
          "enum": ["light", "dark"],
          "default": "light"
        },
        "colors": {
          "type": "object",
          "title": "Color Schemes",
          "properties": {
            "light": { "$ref": "#/definitions/themeColorMode" },
            "dark": { "$ref": "#/definitions/themeColorMode" }
          }
        },
        "typography": {
          "type": "object",
          "title": "Typography",
          "properties": {
            "primary": { "type": "string", "title": "Primary Font Family" },
            "secondary": { "type": "string", "title": "Secondary Font Family" },
            "baseSize": { "type": "string", "title": "Base Font Size" }
          }
        },
        "ui": {
          "type": "object",
          "title": "UI Settings",
          "properties": {
            "radius": { "type": "string", "title": "Border Radius", "default": "0.5rem" },
            "spacing": { "$ref": "#/definitions/themeSpacing" },
            "spacingScale": { "type": "number", "title": "Spacing Scale" },
            "buttonStyle": { "type": "string", "title": "Button Style" }
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "title": "Layout",
      "properties": {
        "navbar": {
          "type": "object",
          "title": "Navbar",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Navbar Variant",
              "enum": ["standard", "centered"],
              "default": "standard"
            },
            "extensions": {
              "type": "array",
              "title": "Navbar Extensions",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["upper-bar"], "title": "Extension Type" }
                },
                "required": ["type"]
              }
            }
          }
        },
        "footer": {
          "type": "object",
          "title": "FooterConfig",
          "properties": {
            "variant": {
              "type": "string",
              "title": "Footer Variant",
              "enum": ["simple", "multiColumn", "minimal", "centered", "branded", "stacked"],
              "default": "simple"
            },
            "copyright": { "type": "string", "title": "Copyright Text" },
            "tagline": { "type": "string", "title": "Tagline" },
            "links": {
              "type": "array",
              "title": "Footer Links",
              "items": { "$ref": "#/definitions/link" }
            },
            "columns": {
              "type": "array",
              "title": "Footer Columns",
              "items": { "$ref": "#/definitions/footerColumn" }
            },
            "extensions": {
              "type": "array",
              "title": "Footer Extensions",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["call"], "title": "Extension Type" },
                  "headline": { "type": "string", "title": "Headline" },
                  "phone": { "type": "string", "title": "Phone" }
                },
                "required": ["type"]
              }
            }
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "title": "Navigation",
      "properties": {
        "links": {
          "type": "array",
          "title": "Navigation Links",
          "items": { "$ref": "#/definitions/link" }
        },
        "cta": {
          "$ref": "#/definitions/cta",
          "title": "Navigation CTA"
        }
      }
    },
    "pages": {
      "type": "object",
      "title": "Pages",
      "additionalProperties": { "$ref": "#/definitions/page" }
    },
    "sharedSections": {
      "type": "object",
      "title": "Shared Sections",
      "description": "Named sections that can be referenced from any page via { type: 'ref', sectionId: '<key>' }",
      "additionalProperties": { "$ref": "#/definitions/section" }
    },
    "data": {
      "type": "object",
      "title": "Data",
      "properties": {
        "services": {
          "type": "array",
          "title": "Services",
          "items": { "$ref": "#/definitions/service" }
        },
        "products": {
          "type": "array",
          "title": "Products",
          "items": { "$ref": "#/definitions/product" }
        }
      }
    },
    "booking": {
      "type": "object",
      "title": "Booking",
      "properties": {
        "enabled": { "type": "boolean", "title": "Enable Booking", "default": false },
        "services": {
          "type": "array",
          "title": "Booking Services",
          "items": {
            "type": "object",
            "title": "BookingService",
            "properties": {
              "id": { "type": "string", "title": "Service ID" },
              "name": { "type": "string", "title": "Service Name" },
              "duration": { "type": "integer", "title": "Duration (minutes)", "default": 60 },
              "price": { "type": "number", "title": "Price" },
              "description": { "type": "string", "title": "Description" }
            },
            "required": ["id", "name", "duration"]
          }
        },
        "hours": {
          "type": "object",
          "title": "Business Hours",
          "properties": {
